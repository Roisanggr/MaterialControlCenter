            // Expose ke global scope untuk onclick pagination
            window.loadAllScrapData = loadAllScrapData;
            window.goToPage = goToPage;
            window.showPaginationLoader = showPaginationLoader;
            window.hidePaginationLoader = hidePaginationLoader;

            // Pagination helper: show/hide loader and navigate pages
            function showPaginationLoader() {
                var el = document.getElementById('paginationLoader');
                if (el) el.classList.remove('hidden');
            }
            function hidePaginationLoader() {
                var el = document.getElementById('paginationLoader');
                if (el) el.classList.add('hidden');
            }

            function goToPage(page, size) {
                try {
                    _currentPage = page;
                    loadAllScrapData(page, size, currentFilters || {});
                } catch (e) {
                    console.error('goToPage error', e);
                    hidePaginationLoader();
                }
            }

        })();
    </script>
