@section scripts{


    <script src="~/assets/js/main.js"></script>

    <script>

        $(document).ready(function () {
            loadData(1, pageSize, {}); // filters default empty object
            loadScrapTotals();
            initInitiatorAutocompleteForAllScrap();
        });

        filterButton.addEventListener('click', function (e) {
            e.preventDefault(); // mencegah href="#" reload halaman
            filterList.classList.toggle('hidden'); // toggle class hidden
        });


        function loadData(pageNumber = 1, pageSize, filters = currentFilters) {
            return $.ajax({
                url: urlGetSourceDataScrap,
                type: "GET",
                data: {
                    pageNumber: pageNumber,
                    pageSize: pageSize,
                    "statusList[0]": 1,
                    "statusList[1]": 4,
                    "statusList[2]": 5,
                    "statusList[3]": 9,
                    "statusList[4]": 16,

                    initiatorKpk: filters.initiatorKpk || "",
                    facility: filters.facility || "",
                    createdDateFrom: filters.createdDateFrom || "",
                    createdDateTo: filters.createdDateTo || "",
                    scrapCode: filters.scrapCode || "",
                    tc: filters.tc || "",
                    totalFrom: filters.totalFrom || "",
                    totalTo: filters.totalTo || ""
                },
                dataType: "json"
            }).done(function (res) {
                renderTable(res.Data);
                renderPagination(res.TotalCount, res.PageNumber, res.PageSize);
            }).fail(function (xhr, status, error) {
                console.error("Error loading data:", error);
            });
        }

        function initInitiatorAutocompleteForAllScrap() {
            const $input = $("#scrapInitiatorNameFilter");
            const $results = $("#scrapInitiatorResults");
            const $kpkHidden = $("#scrapInitiatorKpkFilter");

            $input.on("input", function () {
                const query = $(this).val().trim();

                if (query.length < 3) {
                    $results.empty().addClass("hidden");
                    $kpkHidden.val("");
                    return;
                }

                fetchData(urlGetEmployee, { keyword: query }, function (res) {
                    $results.empty();

                    if (res.success && Array.isArray(res.data)) {
                        const limited = res.data.slice(0, 5);
                        limited.forEach(item => {
                            const option = $("<div>")
                                .addClass("dropdown-item hover:bg-success/[0.85] cursor-pointer p-2 rounded text-sm")
                                .text(capitalizeWords(item.name) + " (" + item.kpk + ")")
                                .on("click", function () {
                                    $kpkHidden.val(item.kpk);
                                    $input.val(capitalizeWords(item.name));
                                    $results.empty().addClass("hidden");
                                });

                            $results.append(option);
                        });

                        $results.removeClass("hidden");
                    } else {
                        $results.addClass("hidden");
                    }
                });
            });

            $(document).on("click", function (e) {
                if (!$(e.target).closest("#scrapInitiatorNameFilter, #scrapInitiatorResults").length) {
                    $results.empty().addClass("hidden");
                }
            });
        }

        async function loadScrapTotals() {
            try {
                const statusArray = [1, 4, 9]; // hanya status yang ingin diambil
                const data = {};

                // Tambahkan statusList dengan format indexed agar MVC bisa bind
                statusArray.forEach((s, i) => data[`statusList[${i}]`] = s);

                const response = await $.ajax({
                    url: urlGetScrapTotals,
                    type: 'GET',
                    data: data, // hanya statusList dikirim
                    dataType: 'json'
                });

                // Update DOM dengan data dari server
                $("#totalValueAll").empty().text(formatRupiahShort(response.TotalValueAll));
                $("#totalQtyAll").empty().text(response.TotalQtyAll.toLocaleString("id-ID"));
                $("#totalValuePending").empty().text(formatRupiahShort(response.TotalValuePending));
                $("#totalValueApprove").empty().text(formatRupiahShort(response.TotalValueApproved));

            } catch (err) {
                console.error("Error fetch scrap totals:", err);
            }
        }

    </script>

}
