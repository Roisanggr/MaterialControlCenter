                    <style>
                        .dr-day {
                            font-size: 12px;
                            text-align: center;
                            padding: 5px 2px;
                            cursor: pointer;
                            border-radius: 4px;
                            color: #333;
                            user-select: none;
                        }

                            .dr-day:hover:not(.empty) {
                                background: #f0f0f0;
                            }

                            .dr-day.start, .dr-day.end {
                                background: #4a90d9 !important;
                                color: #fff !important;
                                border-radius: 50%;
                                font-weight: 500;
                            }

                            .dr-day.in-range {
                                background: #d0e8f8;
                                color: #1a5f9a;
                                border-radius: 0;
                            }

                            .dr-day.start.has-end {
                                border-radius: 50% 0 0 50%;
                            }

                            .dr-day.end.has-start {
                                border-radius: 0 50% 50% 0;
                            }

                            .dr-day.today {
                                color: #4a90d9;
                                font-weight: 500;
                            }
                    </style>

                    <script>
                        (function () {
                            var MONTHS = ['January', 'February', 'March', 'April', 'May', 'June',
                                'July', 'August', 'September', 'October', 'November', 'December'];
                            var DAYS = ['Su', 'Mo', 'Tu', 'We', 'Th', 'Fr', 'Sa'];
                            var now = new Date();
                            var viewYear = now.getFullYear(), viewMonth = now.getMonth();
                            var startDate = null, endDate = null, hoverDate = null, selecting = false;

                            function sameDay(a, b) {
                                return a && b && a.getFullYear() === b.getFullYear()
                                    && a.getMonth() === b.getMonth() && a.getDate() === b.getDate();
                            }
                            function fmt(d) {
                                if (!d) return '';
                                return ('0' + d.getDate()).slice(-2) + '/'
                                    + ('0' + (d.getMonth() + 1)).slice(-2) + '/' + d.getFullYear();
                            }
                            function fmtISO(d) {
                                if (!d) return '';
                                return d.getFullYear() + '-'
                                    + ('0' + (d.getMonth() + 1)).slice(-2) + '-'
                                    + ('0' + d.getDate()).slice(-2);
                            }
                            function getWeekNum(d) {
                                var jan1 = new Date(d.getFullYear(), 0, 1);
                                return Math.ceil(((d - jan1) / 86400000 + jan1.getDay() + 1) / 7);
                            }

                            function render() {
                                document.getElementById('monthLabel').textContent = MONTHS[viewMonth] + ' ' + viewYear;
                                var grid = document.getElementById('calGrid');
                                grid.innerHTML = '';

                                // DOW header
                                var headerRow = document.createElement('div');
                                headerRow.style.cssText = 'display:grid;grid-template-columns:28px repeat(7,1fr);gap:2px;margin-bottom:4px;';
                                var wkHead = document.createElement('div');
                                headerRow.appendChild(wkHead);
                                DAYS.forEach(function (d) {
                                    var el = document.createElement('div');
                                    el.style.cssText = 'font-size:11px;color:#888;text-align:center;padding:3px 0;font-weight:500;';
                                    el.textContent = d;
                                    headerRow.appendChild(el);
                                });
                                grid.appendChild(headerRow);

                                var first = new Date(viewYear, viewMonth, 1);
                                var startDow = first.getDay();
                                var daysInMonth = new Date(viewYear, viewMonth + 1, 0).getDate();

                                var effEnd = endDate || (selecting && hoverDate ? hoverDate : null);
                                var rStart = startDate && effEnd ? (startDate <= effEnd ? startDate : effEnd) : startDate;
                                var rEnd = startDate && effEnd ? (startDate <= effEnd ? effEnd : startDate) : null;

                                var row = null; var col = 0;
                                function newRow(date) {
                                    row = document.createElement('div');
                                    row.style.cssText = 'display:grid;grid-template-columns:28px repeat(7,1fr);gap:2px;margin-bottom:2px;';
                                    var wk = document.createElement('div');
                                    wk.style.cssText = 'font-size:10px;color:#bbb;display:flex;align-items:center;justify-content:center;';
                                    if (date) wk.textContent = getWeekNum(date);
                                    row.appendChild(wk); grid.appendChild(row); col = 0;
                                }
                                newRow(first);

                                for (var i = 0; i < startDow; i++) {
                                    var e = document.createElement('div');
                                    e.className = 'dr-day empty'; row.appendChild(e); col++;
                                }

                                for (var d = 1; d <= daysInMonth; d++) {
                                    if (col > 0 && col % 7 === 0) newRow(new Date(viewYear, viewMonth, d));
                                    var dt = new Date(viewYear, viewMonth, d);
                                    var el = document.createElement('div');
                                    el.className = 'dr-day';
                                    el.textContent = d;
                                    el.dataset.date = dt.toISOString();

                                    var isStart = rStart && sameDay(dt, rStart);
                                    var isEnd = rEnd && sameDay(dt, rEnd);
                                    var inRange = rStart && rEnd && dt > rStart && dt < rEnd;

                                    if (isStart && isEnd) { el.classList.add('start', 'end'); }
                                    else {
                                        if (isStart) { el.classList.add('start'); if (rEnd) el.classList.add('has-end'); }
                                        if (isEnd) { el.classList.add('end'); if (rStart) el.classList.add('has-start'); }
                                        if (inRange) el.classList.add('in-range');
                                    }
                                    if (sameDay(dt, now) && !isStart && !isEnd) el.classList.add('today');
                                    row.appendChild(el); col++;
                                }

                                document.getElementById('inputStart').value = startDate ? fmt(startDate) : '';
                                document.getElementById('inputEnd').value = endDate ? fmt(endDate) : '';
                                document.getElementById('scrapDateStart').value = startDate ? fmtISO(startDate) : '';
                                document.getElementById('scrapDateEnd').value = endDate ? fmtISO(endDate) : '';
                            }

                            var calGrid = document.getElementById('calGrid');

                            calGrid.addEventListener('mouseover', function (e) {
                                var el = e.target.closest ? e.target.closest('.dr-day:not(.empty)') : null;
                                if (!el) return;
                                if (selecting) { hoverDate = new Date(el.dataset.date); render(); }
                            });
                            calGrid.addEventListener('mouseleave', function () {
                                if (selecting) { hoverDate = null; render(); }
                            });
                            calGrid.addEventListener('click', function (e) {
                                var el = e.target.closest ? e.target.closest('.dr-day:not(.empty)') : null;
                                if (!el || !el.dataset.date) return;
                                var clicked = new Date(el.dataset.date);
                                if (!selecting || !startDate) {
                                    startDate = clicked; endDate = null; selecting = true; hoverDate = null;
                                } else {
                                    if (clicked < startDate) { endDate = startDate; startDate = clicked; }
                                    else { endDate = clicked; }
                                    selecting = false; hoverDate = null;
                                    document.getElementById('calPopup').style.display = 'none';
                                }
                                render();
                            });

                            document.getElementById('prevBtn').addEventListener('click', function () {
                                viewMonth--; if (viewMonth < 0) { viewMonth = 11; viewYear--; } render();
                            });
                            document.getElementById('nextBtn').addEventListener('click', function () {
                                viewMonth++; if (viewMonth > 11) { viewMonth = 0; viewYear++; } render();
                            });
                            document.getElementById('clearBtn').addEventListener('click', function () {
                                startDate = null; endDate = null; selecting = false; hoverDate = null; render();
                                document.getElementById('calPopup').style.display = 'none';
                            });

                            document.getElementById('inputStart').addEventListener('click', function () {
                                var p = document.getElementById('calPopup');
                                p.style.display = p.style.display === 'none' ? 'block' : 'none';
                            });
                            document.getElementById('inputEnd').addEventListener('click', function () {
                                if (startDate && !endDate) { selecting = true; }
                                document.getElementById('calPopup').style.display = 'block';
                            });

                            document.addEventListener('click', function (e) {
                                if (!document.getElementById('dateRangePicker').contains(e.target)) {
                                    document.getElementById('calPopup').style.display = 'none';
                                }
                            });

                            render();
                        })();
                    </script>
                    <!-- date range test -->
