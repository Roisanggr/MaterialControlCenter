                            <div id="calPopup" style="display:none;position:absolute;z-index:999;margin-top:4px;
            background:#fff;border:1px solid #ddd;border-radius:8px;
            box-shadow:0 4px 20px rgba(0,0,0,0.12);width:280px;">

                                <div style="display:flex;align-items:center;justify-content:space-between;
                background:#4a90d9;color:#fff;padding:10px 14px;
                border-radius:8px 8px 0 0;font-size:14px;font-weight:500;">
