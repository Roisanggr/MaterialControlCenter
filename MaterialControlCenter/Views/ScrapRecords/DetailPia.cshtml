        async function handleNameInput(inputEl) {
            const keyword = inputEl.value.trim();
            const container = inputEl.nextElementSibling;
            if (!keyword || keyword.length < 2) {
                container.classList.add("hidden");
                container.innerHTML = "";
                return;
            }
            const resp = await fetch(`${urlGetEmployee}?keyword=${encodeURIComponent(keyword)}`);
            const data = await resp.json();
            if (data.success && data.data.length > 0) {
                container.classList.remove("hidden");
                container.innerHTML = data.data.map(emp =>
                    `<div class="p-1 hover:bg-success dark:hover:bg-darkmuted cursor-pointer"
                      onclick="selectEmployee('${emp.kpk}', '${emp.name}', this)">
                      ${emp.kpk} - ${emp.name}
                 </div>`
                ).join("");
            } else {
                container.classList.add("hidden");
                container.innerHTML = "";
            }
        }

        function selectEmployee(empKpk, name, el) {
            const container = el.parentElement;
            const inputEl = container.previousElementSibling;
            inputEl.value = name;
            container.classList.add("hidden");
            container.innerHTML = "";
            const step = inputEl.dataset.step;
            currentKpkList[step - 1] = empKpk;
        }

        document.getElementById("saveUpdateApproval").addEventListener("click", async () => {
            const inputs = document.querySelectorAll("#approverList input[data-approvalid]");
            const updates = [];
            inputs.forEach(input => {
                const approvalId = parseInt(input.dataset.approvalid, 10);
                const step = parseInt(input.dataset.step, 10);
                const newKpk = currentKpkList[step - 1];
                if (approvalId && newKpk) {
                    updates.push({ ApprovalListId: approvalId, NewKpk: newKpk });
                }
            });
            if (updates.length === 0) {
                Swal.fire("Info", "No approval changes found.", "info");
                return;
            }
            showDynamicSwal({ title: "Confirm Update", text: "Are you sure you want to save the changes to approvals?", icon: "question", confirmText: "Yes, Save", cancelText: "Cancel" })
            .then(async (result) => {
                if (!result.isConfirmed) return;
                try {
                    Swal.fire({ title: "Saving...", text: "Please wait while we process the data", allowOutsideClick: false, didOpen: () => { Swal.showLoading(); } });
                    const resp = await fetch(urlUpdateApprovals, {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify(updates)
                    });
                    const res = await resp.json();
                    if (res.success) {
                        Swal.fire({ title: "Success", text: "Approvals updated successfully.", icon: "success", timer: 1500, showConfirmButton: false })
                        .then(() => {
                            closeModal('modalsUpdateApproval');
                            loadApprovalProgress(docId);
                            checkAndRenderApproveReject(docId);
                        });
                    } else {
                        Swal.fire("Failed", res.message || "Approval update failed.", "error");
                    }
                } catch (err) {
                    console.error("Error updating approvals:", err);
                    Swal.fire("Error", "An error occurred while updating approvals.", "error");
                }
            });
        });

        function renderPagination(totalCount, pageNumber, size) {
            const ul = document.getElementById("buttonPagination");
            const totalPages = Math.ceil(totalCount / size);
            ul.innerHTML = "";

            if (totalPages <= 1) return;

            // Previous button
            if (pageNumber > 1) {
                const li = document.createElement("li");
                const btn = document.createElement("button");
                btn.className = "px-3 py-1 text-xs rounded border border-gray-300 hover:bg-gray-100";
                btn.textContent = "‹";
                btn.onclick = function() { 
                    loadData(pageNumber - 1, size, currentFilters);
                };
                li.appendChild(btn);
                ul.appendChild(li);
            }

            // Page numbers
            const start = Math.max(1, pageNumber - 2);
            const end = Math.min(totalPages, pageNumber + 2);
            for (let p = start; p <= end; p++) {
                const isActive = p === pageNumber;
                const li = document.createElement("li");
                const btn = document.createElement("button");
                btn.className = `px-3 py-1 text-xs rounded border ${isActive
                    ? "bg-info text-white border-info"
                    : "border-gray-300 hover:bg-gray-100"}`;
                btn.textContent = p;
                btn.onclick = function() { 
                    loadData(p, size, currentFilters);
                };
                li.appendChild(btn);
                ul.appendChild(li);
            }

            // Next button
            if (pageNumber < totalPages) {
                const li = document.createElement("li");
                const btn = document.createElement("button");
                btn.className = "px-3 py-1 text-xs rounded border border-gray-300 hover:bg-gray-100";
                btn.textContent = "›";
                btn.onclick = function() { 
                    loadData(pageNumber + 1, size, currentFilters);
                };
                li.appendChild(btn);
                ul.appendChild(li);
            }
        }

        window.loadData = loadData;

        async function downloadExcel() {
            if (!docId) return;

