                let eyeIconHtml = "";
                if (hasUserDelegates) {
                    eyeIconHtml = `
                <button
                    id="listdelegate-${app.Centralized_ApprovalList_ID}"
                    class="inline-block size-2 rounded-full absolute ltr:right-0.5 rtl:left-0.5 bottom-[1px] border border-white"
                    data-delegates='${JSON.stringify(app.UserDelegateList)}'
