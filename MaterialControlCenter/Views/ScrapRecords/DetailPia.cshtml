                >
                    <i class="fa-solid fa-eye text-purple text-[3px] hover:bg-muted/[0.85] hover:border-purple/[0.85]"></i>
                </button>`;
                }

                const li = document.createElement("li");
                li.innerHTML = `
                <div class="flex items-center gap-3">
                    <div class="relative rounded-full shrink-0">
                        <div class="rounded-full h-7 w-7 flex items-center justify-center text-xs font-semibold uppercase bg-purple/20 text-purple">
                            ${initials}
                        </div>
                        ${eyeIconHtml}
                    </div>
