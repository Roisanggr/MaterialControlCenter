            approvals.forEach(app => {
                let statusId = rejectEncountered ? 3 : app.Centralized_StatusList_ID;
                const initials = (app.ApproverName || "?")
                    .split(" ").map(n => n[0]).join("").toUpperCase();
                const { statusText, badgeClass } = getApprovalStatus(statusId);
                if (statusId === 3) rejectEncountered = true;

                let delegateHtml = "";
                if (app.DelegateNames && app.DelegateNames.length > 0) {
                    const names = app.DelegateNames.join(", ");
                    delegateHtml = `<p class="text-xs text-muted">Represented by: ${capitalizeWords(names)}</p>`;
