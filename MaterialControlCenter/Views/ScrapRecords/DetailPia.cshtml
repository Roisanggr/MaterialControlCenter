            <div class="p-5 border rounded border-black/10 dark:border-darkborder">
                <div class="mb-2 text-sm font-bold text-purple-600">Step ${step}</div>
                <div class="flex gap-4 mb-4">
                    <div class="flex-1">
                        ${nameField}
                        <p class="text-xs text-muted dark:text-darkmuted">${approvedDate ? "Approved At: " + approvedDate : "Pending"}</p>
                        <p class="text-xs font-semibold ${statusClass}">Status: ${statusLabel}</p>
                    </div>
                </div>
            </div>`;
            });
