        // ── Overview Chart ─────────────────────────────────────────────────────────
        function renderBarChart(chartId, seriesData, labelsData, chartHeight = 310) {
            var allValues = seriesData.flatMap(s => s.data);
            var maxVal = Math.max(...allValues);
            if (!maxVal || maxVal <= 0) maxVal = 10;
            var maxTicks = 6;
            var rawStep = Math.ceil(maxVal / maxTicks);
            function niceStep(value) {
                var exponent = Math.floor(Math.log10(value));
                var fraction = value / Math.pow(10, exponent);
                let niceFraction;
                if (fraction <= 1) niceFraction = 1;
                else if (fraction <= 2) niceFraction = 2;
                else if (fraction <= 5) niceFraction = 5;
                else niceFraction = 10;
                return niceFraction * Math.pow(10, exponent);
            }
            var step = niceStep(rawStep);
            var tickAmount = Math.ceil(maxVal / step);
            var options = {
                series: seriesData,
                chart: {
                    height: chartHeight,
                    type: 'bar',
                    toolbar: { show: false }
                },
                plotOptions: {
                    bar: { horizontal: true, barHeight: '60%' }
                },
                dataLabels: { enabled: false },
                grid: { borderColor: "#e8e8e8" },
                fill: { opacity: 0.8 },
                xaxis: {
                    categories: labelsData,
                    min: 0,
                    max: (tickAmount + 1) * step,
                    tickAmount: tickAmount + 1,
                    labels: { formatter: val => formatRupiah(val) },
                    axisBorder: { color: "#e0e6ed" }
                },
                yaxis: { opposite: false },
                tooltip: {
                    y: { formatter: function (val) { return formatRupiah(val); } }
                }
            };
            var chartElement = document.querySelector(chartId);
            if (chartElement) {
                chartElement.innerHTML = "";
                var chart = new ApexCharts(chartElement, options);
                chart.render();
                return chart;
            } else {
                console.warn(`Chart element ${chartId} not found`);
            }
        }

        // ── Approval Progress ──────────────────────────────────────────────────────
        async function fetchPiaApprovals(piaId) {
            if (!piaId) return null;
            const url = urlGetPiaApprovals;
            const res = await fetch(`${url}?documentType=PIA&documentId=${piaId}`);
            const data = await res.json();
            if (!data.Data || data.Data.length === 0) return null;
            return {
                approvals: data.Data[0].Approvals,
                initiatorKpk: data.Data[0].InitiatorKpk,
                initiatorName: data.Data[0].InitiatorName,
                currentStatus: data.Data[0].CurrentStatus,
                deletedAt: data.Data[0].DeletedAt
            };
        }

        function getApprovalStatus(statusId) {
            const map = {
                1: { statusText: "Pending",  badgeClass: "bg-warning" },
                2: { statusText: "Approved", badgeClass: "bg-success" },
                3: { statusText: "Rejected", badgeClass: "bg-danger" }
            };
            return map[statusId] || { statusText: "Unknown", badgeClass: "bg-muted" };
        }

