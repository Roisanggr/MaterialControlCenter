        async function loadApprovalProgress(piaId) {
            const result = await fetchPiaApprovals(piaId);
            const approvals = result?.approvals ?? [];
            renderApprovalProgress(approvals);
        }

        function setCurrentApproval(approvalListId, sourceDataID) {
            currentApproval = approvalListId;
            currentSourceDataID = sourceDataID;
        }

        async function getDelegateKpkIfAny(originalKpk) {
            const currentDayType = getCurrentDayType();
            originalApproverKpk = originalKpk;
            try {
                const res = await $.getJSON(getDelegatesUrl, { searchUserKpk: originalKpk });
                if (!res.success) return [originalKpk];
                const matchedDelegates = res.data.filter(d =>
                    d.DelegateTime === currentDayType || d.DelegateTime === "Everyday"
                );
                if (matchedDelegates.length > 0) {
                    const delegateKpks = matchedDelegates.map(d => d.DelegateKpk);
                    isDelegateActive = true;
                    return [originalKpk, ...delegateKpks];
                } else {
                    return [originalKpk];
                }
            } catch (err) {
                console.error("Error ambil delegasi:", err);
                return [originalKpk];
            }
        }

        async function checkAndRenderApproveReject(piaId) {
            const result = await fetchPiaApprovals(piaId);
            const approveRejectField = document.getElementById("approveRejectField");
            const updateApprovalBtn = document.getElementById("updateApproval");
            const buttonDelete = document.getElementById("deleteButtonForInitiator");
            approveRejectField.classList.add("hidden");
            updateApprovalBtn.classList.add("hidden");
            if (buttonDelete) buttonDelete.classList.add("hidden");

            if (!result || !result.approvals) return;
            renderCurrentStatus(result.currentStatus);

            const approvals = result.approvals;
            if (result.currentStatus === 16) return;
            if (result.currentStatus === 5) return;

            if (result.initiatorKpk === kpk && (result.currentStatus === 1 || result.currentStatus === 4)) {
                if (buttonDelete) buttonDelete.classList.remove("hidden");
                if (approvals.length > 0) {
                    setCurrentApproval(null, approvals[0].Centralized_SourceData_ID);
                }
            }

            approvals.sort((a, b) => a.Centralized_ApprovalList_Step - b.Centralized_ApprovalList_Step);
            const nextStepPending = approvals.find(a => a.Centralized_StatusList_ID === 1);
            if (!nextStepPending) return;
            const maxStep = Math.max(...approvals.map(a => a.Centralized_ApprovalList_Step));
            isLastApprovalStep = nextStepPending.Centralized_ApprovalList_Step === maxStep;
            const originalKpkApproval = nextStepPending.OriginalKpkApproval;
            const approverKpks = await getDelegateKpkIfAny(originalKpkApproval);

            const stepIndex = approvals.indexOf(nextStepPending);
            if (stepIndex > 0) {
                const prevStep = approvals[stepIndex - 1];
                if (prevStep.Centralized_StatusList_ID !== 2) return;
            }
            if (approverKpks.map(x => x.toString()).includes(kpk.toString())) {
                approveRejectField.classList.remove("hidden");
                updateApprovalBtn.classList.remove("hidden");
                setCurrentApproval(nextStepPending.Centralized_ApprovalList_ID, nextStepPending.Centralized_SourceData_ID);
            }
        }

        async function handleDecision(status) {
            if (!currentApproval || !currentSourceDataID) return;
            const baseUrl = isLastApprovalStep
                ? '@Url.Action("TriggerApprovalManual", "AutomateFlow")'
                : '@Url.Action("TriggerApproval", "AutomateFlow")';
            const urlTrigger = baseUrl
                + "?approvalListId=" + currentApproval
                + "&status=" + status
                + "&sourceDataID=" + currentSourceDataID;
            const urlInsertDelegate = '@Url.Action("InsertDelegateApprovalRecord", "UpdateData")';
            const result = await showDynamicSwal({
                title: "Are you sure?",
                text: status == 3 ? "Do you want to reject this?" : "Do you want to approve this?",
                icon: "warning",
                confirmText: "Yes, Continue",
                cancelText: "Cancel"
            });
            if (!result.isConfirmed) return;
            Swal.fire({
                title: "Processing...",
                text: "Please wait. This process usually takes a few seconds, but may take up to 1 minute during gateway delays.",
                allowOutsideClick: false,
                didOpen: () => Swal.showLoading()
            });
            try {
                if (isDelegateActive && kpk !== originalApproverKpk) {
                    const insertRes = await $.post(urlInsertDelegate, {
                        approvalListId: currentApproval,
                        statusListId: status,
                        delegateKpk: kpk
                    });
                    if (!insertRes.success) {
                        Swal.close();
                        Swal.fire({ icon: "error", title: "Delegate Insert Failed", text: insertRes.message || "Failed to insert delegate record." });
                        return;
                    }
                }
                const response = await $.get(urlTrigger);
                if (response.success) {
                    Swal.close();
                    if (response.flowStatus !== 200) {
                        await Swal.fire({
                            icon: "warning",
                            title: "Email Delivery Failed – Switched to Manual Approval",
                            text: "The system could not send the notification email to the next approver due to a gateway connection issue. The approval process is still continued using the manual approach.",
                        });
                    } else {
                        await Swal.fire({ icon: "success", title: "Success", text: response.message });
                    }
                    await loadApprovalProgress(docId);
                    checkAndRenderApproveReject(docId);
                } else {
                    Swal.close();
                    Swal.fire({ icon: "error", title: "Error", text: response.message });
                }
            } catch (err) {
                Swal.close();
                Swal.fire({ icon: "error", title: "Request Failed", text: "Something went wrong while sending the request." });
                console.error(err);
            }
        }

        function UpdateApprovalOpenModals() {
