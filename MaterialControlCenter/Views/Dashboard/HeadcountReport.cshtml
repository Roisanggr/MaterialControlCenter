        </div>

        <div class="gap-6 p-5 bg-white border rounded dark:bg-darklight dark:border-darkborder border-black/10">
            <h2 class="mb-4 text-base font-semibold text-black capitalize dark:text-white/80">Top 5 Remarks By Total</h2>
            <div id="chart6" dir="ltr">
