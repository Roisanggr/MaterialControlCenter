                <div class="card flex-1 basis-1/4 min-w-[200px] p-3">
                    <h2 class="mb-2 text-sm font-semibold text-black capitalize dark:text-white/80">Total From</h2>
                    <form class="space-y-2">
                        <div class="space-y-1">
                            <input id="scrapStartFromFilter" type="number" class="form-input w-full text-sm p-2" placeholder="Minimum Total">
                        </div>
                    </form>
                </div>

                <div class="card flex-1 basis-1/4 min-w-[200px] p-3">
                    <h2 class="mb-2 text-sm font-semibold text-black capitalize dark:text-white/80">Total To</h2>
                    <form class="space-y-2">
                        <div class="space-y-1">
                            <input id="scrapEndTotalFilter" type="number" class="form-input w-full text-sm p-2" placeholder="Maximum Total">
                        </div>
                    </form>
                </div>


                <div class="flex w-full justify-end gap-2 mt-2">
                    <!-- Apply Filters icon -->
                    <button id="applyFiltersScrapHeadCountButtonScrapDetail"
                            class="px-2 py-1 bg-success text-white rounded shadow hover:bg-success/[0.85] transition flex items-center justify-center text-sm mb-2">
                        <i class="ri-check-line text-sm mr-1"></i>
                        Apply
                    </button>

                    <!-- Reset Filters icon -->
                    <button id="resetFiltersScrapHeadCountButtonScrapDetail"
                            class="px-2 py-1 bg-danger text-white rounded shadow hover:bg-danger/[0.85] transition flex items-center justify-center text-sm mb-2">
                        <i class="ri-refresh-line text-sm mr-1"></i>
                        Reset
                    </button>
                </div>
            </div>
                <div class="overflow-auto">
                    <table class="min-w-[640px] w-full">
                        <thead>
                            <tr class="ltr:text-left rtl:text-right">
                                <th>Document ID</th>
                                <th>Part Number</th>
                                <th>Description</th>
                                <th>Quantity</th>
                                <th>Total</th>
                                <th>Supervisor</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody id="subordinateScrapPartList">
                            <tr class="text-muted">
                                <td colspan="4" class="py-6 text-center">
                                    <div class="flex justify-center items-center gap-2">
                                        <!-- Spinner -->
                                        <div class="animate-spin inline-block size-8 border-[3px] border-l-transparent border-muted rounded-full"></div>
