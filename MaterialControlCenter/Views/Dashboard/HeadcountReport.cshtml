                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M4 6h4v4H4V6zm6 0h4v4h-4V6zm6 0h4v4h-4V6zM4 12h4v4H4v-4zm6
                                        0h4v4h-4v-4zm6 0h4v4h-4v-4zM4 18h4v4H4v-4zm6 0h4v4h-4v-4zm6 0h4v4h-4v-4z" />
                            </svg>
                        </a>

                        <ul id="scrapCodeSectionReportingList"
                            x-show="dropdown"
                            @@click.away="dropdown = false"
                            x-transition.duration.300ms
                            class="absolute bg-white shadow rounded p-2 mt-2 whitespace-nowrap z-50 w-48">
                            <li class="text-gray-500 px-3 py-1">Loading...</li>
                        </ul>
                    </div>

                </div>
            </div>
            <div>
                <div id="chart5" class="-ml-4" dir="ltr">
                    <div class="flex flex-col items-center justify-center mt-20 space-y-4">
                        <!-- Spinner -->
                        <div class="flex flex-wrap items-center justify-center gap-4">

                            <div class="animate-spin inline-block size-8 border-[3px] border-l-transparent border-muted rounded-full"></div>
                        </div>

                        <!-- Text -->
