                </div>
            </div>
            <div class="col-span-12 gap-6 p-5 bg-white border rounded dark:bg-darklight dark:border-darkborder border-black/10 2xl:col-span-3">
                <h2 class="mb-4 text-base font-semibold text-black capitalize dark:text-white/80">Most Scrap Part Numbers</h2>
                <div id="mostScrapPartNumber" class="flex flex-col gap-3">
                    <div class="flex gap-2 p-3 bg-gray-100 rounded-md dark:bg-darkborder/50 animate-pulse">
                        <!-- Icon skeleton -->
                        <span class="flex items-center justify-center rounded size-10 bg-muted"></span>

                        <!-- Text skeleton -->
                        <div class="overflow-hidden grow">
                            <div class="bg-muted/50 h-4 w-40 mb-2 rounded"></div>
                            <ul class="flex items-center gap-3 text-xs">
                                <li class="bg-muted/50 h-3 w-20 rounded"></li>
                                <li class="bg-muted/50 h-3 w-16 rounded"></li>
