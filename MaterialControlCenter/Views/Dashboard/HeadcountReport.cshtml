                <div class="card flex-1 basis-1/4 min-w-[200px] p-3">
                    <h2 class="mb-2 text-sm font-semibold text-black capitalize dark:text-white/80">Part Number</h2>
                    <form class="space-y-2">
                        <div class="space-y-1">
                            <input id="scrapPartNumberFilter" type="text" class="form-input w-full text-sm p-2" placeholder="Part Number">
                        </div>
                    </form>
                </div>

                <div class="card flex-1 basis-1/4 min-w-[200px] p-3">
                    <h2 class="mb-2 text-sm font-semibold text-black capitalize dark:text-white/80">Supervisor</h2>
                    <form class="space-y-2">
