            <div id="areachart" dir="ltr">
                <div class="flex flex-col items-center justify-center mt-20 space-y-4">
                    <!-- Spinner -->
                    <div class="flex flex-wrap items-center justify-center gap-4">
                      
                        <div class="animate-spin inline-block size-8 border-[3px] border-l-transparent border-muted rounded-full"></div>
                    </div>

                    <!-- Text -->
                    <p class="text-muted font-medium text-lg">Loading...</p>
                </div>


            </div>
        </div>
        <div class="p-5 bg-white border rounded border-black/10 dark:bg-darklight dark:border-darkborder">
            <h2 class="mb-4 text-base font-semibold text-black capitalize dark:text-white/80">Top Scrap by Part Number</h2>
            <div id="topScrapByPartNumber" class="grid grid-cols-1 gap-4">
