                    </div>

                    <!-- Progress skeleton -->
                    <div class="flex items-center justify-between gap-4">
                        <div class="relative w-full h-1 bg-muted rounded-2xl">
                            <div class="bg-muted h-full w-[65%] rounded-2xl"></div>
                        </div>
                        <!-- Number skeleton -->
                        <p class="bg-muted/50 h-4 w-10 rounded"></p>
                    </div>
                </div>
                <div class="space-y-1 animate-pulse">
                    <div class="flex items-center gap-4">
                        <!-- Icon / avatar -->
                        <span class="flex items-center justify-center rounded size-10 bg-muted"></span>

                        <!-- Text skeleton -->
                        <div class="overflow-hidden grow">
                            <div class="bg-muted/50 h-4 w-70 mb-2 rounded"></div>
                            <ul class="flex items-center gap-3 text-xs">
                                <li class="bg-muted/50 h-3 w-20 rounded"></li>
                                <li class="bg-muted/50 h-3 w-16 rounded"></li>
                            </ul>
                        </div>
                    </div>

                    <!-- Progress skeleton -->
                    <div class="flex items-center justify-between gap-4">
                        <div class="relative w-full h-1 bg-muted rounded-2xl">
                            <div class="bg-muted h-full w-[65%] rounded-2xl"></div>
                        </div>
                        <!-- Number skeleton -->
                        <p class="bg-muted/50 h-4 w-10 rounded"></p>
                    </div>
                </div>
                <div class="space-y-1 animate-pulse">
                    <div class="flex items-center gap-4">
                        <!-- Icon / avatar -->
                        <span class="flex items-center justify-center rounded size-10 bg-muted"></span>

                        <!-- Text skeleton -->
                        <div class="overflow-hidden grow">
                            <div class="bg-muted/50 h-4 w-70 mb-2 rounded"></div>
                            <ul class="flex items-center gap-3 text-xs">
                                <li class="bg-muted/50 h-3 w-20 rounded"></li>
                                <li class="bg-muted/50 h-3 w-16 rounded"></li>
                            </ul>
                        </div>
                    </div>

                    <!-- Progress skeleton -->
                    <div class="flex items-center justify-between gap-4">
                        <div class="relative w-full h-1 bg-muted rounded-2xl">
                            <div class="bg-muted h-full w-[65%] rounded-2xl"></div>
                        </div>
                        <!-- Number skeleton -->
                        <p class="bg-muted/50 h-4 w-10 rounded"></p>
                    </div>
                </div>
                <div class="space-y-1 animate-pulse">
                    <div class="flex items-center gap-4">
                        <!-- Icon / avatar -->
                        <span class="flex items-center justify-center rounded size-10 bg-muted"></span>

                        <!-- Text skeleton -->
                        <div class="overflow-hidden grow">
                            <div class="bg-muted/50 h-4 w-70 mb-2 rounded"></div>
                            <ul class="flex items-center gap-3 text-xs">
                                <li class="bg-muted/50 h-3 w-20 rounded"></li>
                                <li class="bg-muted/50 h-3 w-16 rounded"></li>
                            </ul>
                        </div>
                    </div>

                    <!-- Progress skeleton -->
                    <div class="flex items-center justify-between gap-4">
                        <div class="relative w-full h-1 bg-muted rounded-2xl">
                            <div class="bg-muted h-full w-[65%] rounded-2xl"></div>
                        </div>
                        <!-- Number skeleton -->
