                    <div x-data="{ dropdown: false}" class="ltr:ml-auto rtl:mr-auto dropdown">
                        <a href="javaScript:;" class="text-dark dark:text-white" @@click="dropdown = !dropdown" @@keydown.escape="dropdown = false">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-5 h-5">
                                <path fill="currentColor" d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.1 0-2 .9-2 2v14c0
                                    1.1.9 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V9h14v11zm0-13H5V6h14v1z" />
                            </svg>

                        </a>
                        <ul x-show="dropdown" @@click.away="dropdown = false" x-transition="" x-transition.duration.300ms="" class=" whitespace-nowrap ltr:right-0 rtl:left-0 text-dark ">
