        function populateDetailReasonCodeDropdown(rowIndex, facility, selectedTC) {
            const $dropdown = $(`#reasonCode-${rowIndex}`);
            if (!$dropdown.length) return;

            $dropdown.empty().append('<option value="">Loading...</option>').prop('disabled', true);

            $.ajax({
                url: "@Url.Action("GetPiaCodeByLocation", "DataForms")",
                type: "GET",
                dataType: "json",
                data: { location: facility, TC: selectedTC },
                success: function (response) {
                    $dropdown.empty().append('<option value="">-- Select Reason Code --</option>');

                    if (response.success && Array.isArray(response.data) && response.data.length > 0) {
                        response.data.forEach(function (item) {
                            const piaCodeValue = (item.pia_code || item.PiaCode || item.Code || "").toString().trim();
                            if (!piaCodeValue) return;

                            const displayText = item.ShowScrapCode
                                ? `${item.ShowScrapCode} - ${item.Name} (${item.Location || 'All'})`
                                : `${piaCodeValue} - ${item.Name} (${item.Location || 'All'})`;

                            $dropdown.append(`<option value="${piaCodeValue}">${displayText}</option>`);
                        });
                        $dropdown.prop('disabled', false);
                    } else {
                        $dropdown.append('<option value="">-- No Reason Code Available --</option>');
                        $dropdown.prop('disabled', true);
                    }
                },
                error: function () {
                    $dropdown.empty().append('<option value="">-- Error Loading Reason Code --</option>');
                    $dropdown.prop('disabled', true);
                }
            });
        }

