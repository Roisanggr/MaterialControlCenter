        function initSupervisorDropdown(inputSelector, resultsSelector, kpkSelector, nameSelector, apiUrl) {
            const $input = $(inputSelector);
            const $results = $(resultsSelector);
            const isPreviewManager = inputSelector === "#previewSupervisorInitiatorName";
            let latestManagerRequestId = 0;

            $input.on("input", function () {
                const query = $(this).val().trim();

                if (query.length < 3) {
                    $results.empty().hide();
                    if (isPreviewManager) {
                        $results.removeData("requestId");
                    }
                    return;
                }

                if (isPreviewManager) {
                    latestManagerRequestId += 1;
                    const requestId = latestManagerRequestId;
                    $results.empty().show();
                    $results.html('<div class="px-3 py-2 text-xs text-muted flex items-center gap-2"><div class="animate-spin inline-block size-4 border-[2px] border-l-transparent border-purple rounded-full"></div><span>Searching manager...</span></div>');
                    $results.data("requestId", requestId);
                }

                fetchData(apiUrl, { keyword: query }, function (res) {
                    if (isPreviewManager && $results.data("requestId") !== latestManagerRequestId) {
                        return;
                    }
                    $results.empty();

                    if (res.success && Array.isArray(res.data)) {
                        res.data.forEach(item => {
                            const option = $("<div>")
                                .addClass("dropdown-item hover:bg-success/[0.85] cursor-pointer p-2 rounded")
                                .text(capitalizeWords(item.name) + " (" + item.kpk + ")")
                                .on("click", function () {
                                    $(kpkSelector).val(item.kpk);
                                    $(nameSelector).val(capitalizeWords(item.name));
                                    $results.empty().hide();

                                    if (isPreviewManager) {
                                        evaluateAutoShowDetailFormFromPreview();
                                    }
                                });


                            $results.append(option);
                        });

                        $results.show();
                    } else {
                        $results.hide();
                    }
                });
            });
        }

