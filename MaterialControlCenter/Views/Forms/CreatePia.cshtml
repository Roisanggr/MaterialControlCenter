        function populateTcOptions(selectedType, selectedFacility) {
            const tcDropdown = document.getElementById("tcDropdown");
            const filteredTc = piaDocumentRules
                .filter(function (item) {
                    return (item.Type_Desc || "").trim() === selectedType &&
                        (item.Facility || "").trim() === selectedFacility &&
                        (item.TC || "").trim() !== "";
                })
                .map(function (item) { return (item.TC || "").trim(); })
                .filter(function (value, index, array) { return array.indexOf(value) === index; })
                .sort(function (a, b) { return parseInt(a, 10) - parseInt(b, 10); });

            tcDropdown.innerHTML = '<option value="">-- Select TC --</option>';

            if (filteredTc.length === 0) {
                tcDropdown.disabled = true;
                return;
            }

            filteredTc.forEach(function (tc) {
                tcDropdown.append(new Option(tc, tc));
            });

            tcDropdown.disabled = false;
            if (filteredTc.length === 1) {
                tcDropdown.value = filteredTc[0];
                $("#tcDropdown").trigger("change");
            }
        }

        function populateDropdown(dropdown, data, options = {}) {
            const {
                valueField = "id",
                placeholder = "-- Select Data --",
                formatFn = (item) => item.name,
                dataAttributes = {}
            } = options;

            dropdown.empty();
            dropdown.append(`<option value="">${placeholder}</option>`);

            $.each(data, function (i, item) {
                let displayText = formatFn(item);
                let value = item[valueField];

                // Build data attributes string
                let dataAttrsStr = "";
                for (let [attrKey, attrValueKey] of Object.entries(dataAttributes)) {
                    let attrValue = item[attrValueKey] || "";
                    dataAttrsStr += ` data-${attrKey}="${attrValue}"`;
                }

                dropdown.append(`<option value="${value}"${dataAttrsStr}>${displayText}</option>`);
            });
        }

