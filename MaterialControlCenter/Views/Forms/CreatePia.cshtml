                if (!partNumber) return;

                if (value !== "") hasValue = true;

                if (!specialRemarksCache[partNumber]) {
                    specialRemarksCache[partNumber] = {
                        excelRow: null,
                        remark: ""
                    };
                }
                specialRemarksCache[partNumber].remark = value;

                const partIndex = $(`#listOfPartnumber input[value="${partNumber}"]`)
                    .attr("id")
                    ?.split("-")[1];

                if (partIndex) {
                    const partRemarkInput = $(`#specialRemark-${partIndex}`);
                    if (partRemarkInput.length) {
                        partRemarkInput.val(value);
                    }
                }
            });

            if (!hasValue) {
                showSpecialCodeToast("At least one remark must be filled", "error");
