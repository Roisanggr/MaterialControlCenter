@{
    ViewBag.Title = "Forms";
    ViewBag.pTitle = "Create PIA";
    ViewBag.xData = "forms";
    ViewBag.ActiveItem = "forms-createPia";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<!-- New Layout Form -->
<div class="flex flex-col gap-4 mb-8">
    <div class="flex justify-center items-center bg-muted/20 h-32">
        <h2 class="text-base font-semibold text-black capitalize dark:text-white/80 p-2 rounded text-center">
            PIA Header Form
        </h2>
    </div>

    <div class="card p-4 md:p-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <div class="space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-5 gap-3 items-center">
                    <label class="md:col-span-1 text-sm font-bold text-black dark:text-white/80">Type</label>
                    <div id="previewTypeOfPiaDropdownWrapper" class="md:col-span-4">
                        <select id="previewTypeOfPiaDropdown" class="form-input w-full">
                            <option value="">-- Select Type --</option>
                        </select>
                        <div class="preview-loading-state mt-2 flex items-center gap-2 text-xs text-muted">
                            <div class="animate-spin inline-block size-4 border-[2px] border-l-transparent border-purple rounded-full"></div>
                            <span>Loading Type...</span>
                        </div>
                    </div>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-5 gap-3 items-center">
                    <label class="md:col-span-1 text-sm font-bold text-black dark:text-white/80">Manager</label>
                    <div id="previewSupervisorWrapper" class="md:col-span-4">
                        <input type="hidden" id="previewSupervisorInitiatorKpk" />
                        <input type="text" id="previewSupervisorInitiatorName" class="form-input w-full" placeholder="Search Manager..." autocomplete="off" />
                        <div id="previewSupervisorResults" class="dropdown-results absolute w-100 bg-white border border-muted rounded mt-1 z-50 hidden" style="max-height: 200px; overflow-y: auto;"></div>
                    </div>
                </div>
            </div>
            <div class="space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-5 gap-3 items-center">
                    <label class="md:col-span-1 text-sm font-bold text-black dark:text-white/80">Facility</label>
                    <div id="previewFacilityDropdownWrapper" class="md:col-span-4">
                        <select id="previewFacilityDropdown" class="form-input w-full">
                            <option value="">-- Select Facility --</option>
                        </select>
                        <div class="preview-loading-state mt-2 flex items-center gap-2 text-xs text-muted">
                            <div class="animate-spin inline-block size-4 border-[2px] border-l-transparent border-purple rounded-full"></div>
                            <span>Loading Facility...</span>
                        </div>
                    </div>
                </div>
                <div id="previewTcCompanionCard" class="grid grid-cols-1 md:grid-cols-5 gap-3 items-center">
                    <label class="md:col-span-1 text-sm font-bold text-black dark:text-white/80">TC Companion</label>
                    <div id="previewTcCompanionDropdownWrapper" class="md:col-span-4">
                        <select id="previewTcCompanionDropdown" class="form-input w-full" disabled>
                            <option value="">Not Required</option>
                            <option value="62">TCC - 62</option>
                            <option value="70">TCC - 70</option>
                            <option value="71">TCC - 71</option>
                        </select>
                        <div class="preview-loading-state mt-2 flex items-center gap-2 text-xs text-muted">
                            <div class="animate-spin inline-block size-4 border-[2px] border-l-transparent border-purple rounded-full"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div id="previewExcelDropZone" class="mt-6 rounded-xl border border-dashed border-muted bg-white p-5 min-h-[140px] flex items-center justify-center text-center cursor-pointer select-none transition hover:border-info hover:bg-info/5">
            <div>
                <p class="text-sm font-medium text-black dark:text-white/80">Drop or click file here to fill the whole form</p>
                <p class="text-xs text-muted">Supports: .xlsx, .xls</p>
            </div>
        </div>
    </div>
</div>

<!-- Start All Card -->
<div id="legacyPiaContainer" class="flex flex-col gap-4 min-h-[calc(100vh-212px)] hidden" style="display: none;">
    <div id="legacyPiaHeaderTitle" class="flex justify-center items-center bg-muted/20 h-32">
        <h2 class="text-base font-semibold text-black capitalize dark:text-white/80 p-2 rounded text-center">
            PIA Header Form
        </h2>
    </div>


    <!-- 4 kolom -->
    <div id="legacyPiaHeaderFields" class="flex flex-wrap gap-4 justify-between">

        <div class="card flex-1 basis-1/3 min-w-[300px]">
            <h2 class="mb-4 text-base font-semibold text-black capitalize dark:text-white/80">Type Of PIA</h2>
            <div id="typeOfPiaDropdownWrapper" class="space-y-4">
                <select id="typeOfPiaDropdown" class="form-input" required>
                    <option value="">-- Select Type --</option>
                </select>
            </div>

        </div>
        <div class="card flex-1 basis-1/3 min-w-[300px]">

            <div class="flex gap-4">

                <div class="w-full">
                    <h2 class="mb-4 text-base font-semibold text-black capitalize dark:text-white/80">Facility</h2>
                    <div class="space-y-4">
                        <select id="facilityDropdown" class="form-input" required>

                            <option value="">-- Select Facility --</option>
                        </select>
                        <input id="facilityInitiator" type="text" class="form-input w-full hidden" placeholder="Facility" required>
                    </div>
                </div>

                <input type="hidden" id="supervisorInitiatorKpk" name="supervisorInitiatorKpk" />
                <div class="w-full">
                    <h2 class="mb-4 text-base font-semibold text-black capitalize dark:text-white/80">Manager</h2>
                    <div class="space-y-4">

                        <input type="text" id="supervisorInitiatorName" name="supervisorInitiatorName" placeholder="Search Manager..." class="form-input w-full" autocomplete="off" />
                        <div id="supervisorResults" class="dropdown-results absolute w-100 bg-white border border-muted rounded mt-1 z-50 hidden" style="max-height: 200px; overflow-y: auto;"></div>
                    </div>
                </div>
            </div>
        </div>

        <div id="tcCompanionCard" class="card flex-1 basis-1/3 min-w-[300px] hidden" style="display: none;">
            <h2 class="mb-4 text-base font-semibold text-black capitalize dark:text-white/80">TC Companion</h2>
            <div class="space-y-4">
                <select id="tcCompanionDropdown" class="form-input">
                    <option value="">Not Required</option>
                    <option value="62">TCC - 62</option>
                    <option value="70">TCC - 70</option>
                    <option value="71">TCC - 71</option>
                </select>
            </div>
        </div>

        <div id="piaCodeTcResultCard" class="card flex-1 basis-1/3 min-w-[300px] hidden" style="display: none;">
            <h2 class="mb-4 text-base font-semibold text-black capitalize dark:text-white/80">TC</h2>
            <div class="space-y-4">
                <select id="tcDropdown" class="form-input" required>
                </select>
            </div>
        </div>
        <div id="piaCodeWCResultCard" class="card flex-1 basis-1/3 min-w-[300px] hidden" style="display: none;">
            <h2 class="mb-4 text-base font-semibold text-black capitalize dark:text-white/80">WC</h2>
            <div id="wcDropdownWrapper" class="space-y-4">
                <select id="wcDropdown" class="form-input" required>
                    <option value="">-- Select WC --</option>

                </select>
            </div>
        </div>
        <div id="piaCodeResultCard" class="card flex-1 basis-1/3 min-w-[300px] hidden" style="display: none;">
            <h2 class="mb-4 text-base font-semibold text-black capitalize dark:text-white/80">Reason Code</h2>
            <div id="piaCodeDropdownWrapper" class="space-y-4">
                <select id="piaCodeDropdown" class="form-input" required>
                    <option value="">-- Select PIA Code --</option>
                </select>
            </div>
        </div>
        <div id="piaCodeRemarksResultCard" class="card flex-1 basis-1/3 min-w-[300px] hidden" style="display: none;">
            <h2 class="mb-4 text-base font-semibold text-black capitalize dark:text-white/80">Remarks</h2>
            <div id="remarksDropdownWrapper" class="space-y-4">
                <select id="remarksDropdown" class="form-input" required>
                    <option value="">-- Select Remarks --</option>
                </select>
            </div>
        </div>
    </div>

    <div id="sectionContainer" class="flex justify-center items-center bg-muted/20 h-32">
        <button id="continueBtnCreatePia"
                class="flex items-center justify-center gap-2 px-6 py-2 bg-info text-white rounded-lg shadow w-full hover:bg-info/[0.85] transition">
            Continue to Next Step

            <svg xmlns="http://www.w3.org/2000/svg"
                 class="w-5 h-5"
                 fill="none"
                 viewBox="0 0 24 24"
                 stroke="currentColor"
                 stroke-width="2">
                <path stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M9 5l7 7-7 7" />
            </svg>
        </button>
    </div>

    <div id="formContainerDetailsPartNumber" class="space-y-4 mt-4 hidden">
        <div class="flex justify-start pt-4 gap-4">
            <!-- Button kiri -->
            <button id="addRowBtn"
                    class="flex items-center justify-center gap-2 px-6 py-2 bg-success text-white rounded-lg shadow hover:bg-success/[0.85] transition">

                <svg xmlns="http://www.w3.org/2000/svg"
                     class="w-5 h-5"
                     fill="none"
                     viewBox="0 0 24 24"
                     stroke="currentColor"
                     stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                </svg>
                Add Row
            </button>

            <input type="file" id="excelFile" accept=".xlsx,.xls" class="hidden" />
            <button id="importExcel"
                    class="flex items-center justify-center gap-2 px-6 py-2 bg-info text-white rounded-lg shadow hover:bg-info/[0.85] transition">
                <svg xmlns="http://www.w3.org/2000/svg"
                     class="w-5 h-5"
                     fill="none"
                     viewBox="0 0 24 24"
                     stroke="currentColor"
                     stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M12 12V4m0 0l-4 4m4-4l4 4" />
                </svg>
                Import Excel
            </button>

            <button id="openModalsForAnalyzedCaseMaterial"
                    class="flex items-center justify-center gap-2 px-6 py-2 bg-warning text-white rounded-lg shadow hover:bg-warning/[0.85] transition hidden">
                <svg xmlns="http://www.w3.org/2000/svg"
                     class="w-5 h-5"
                     fill="none"
                     viewBox="0 0 24 24"
                     stroke="currentColor"
                     stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M9 12h6m-6 4h4m6.414-9.414a2 2 0 00-2.828 0L11 12.172V15h2.828l5.586-5.586a2 2 0 000-2.828z" />
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M5 19a2 2 0 002 2h10a2 2 0 002-2V7l-4-4H7a2 2 0 00-2 2v14z" />
                </svg>
                Add Notes
            </button>

            <button id="selectCompanionTC"
                    class="flex items-center justify-center gap-2 px-6 py-2 bg-muted text-white rounded-lg shadow hover:bg-muted/[0.85] transition hidden">
                <svg xmlns="http://www.w3.org/2000/svg"
                     class="w-5 h-5"
                     fill="none"
                     viewBox="0 0 24 24"
                     stroke="currentColor"
                     stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M10 13a5 5 0 007.07 0l1.41-1.41a5 5 0 00-7.07-7.07L10 5" />
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M14 11a5 5 0 00-7.07 0L5.51 12.41a5 5 0 007.07 7.07L14 19" />
                </svg>
                TC Companion
            </button>
        </div>

        <div class="overflow-x-auto">
            <table class="min-w-[1200px] w-full table-auto border border-muted border-collapse">
                <thead>
                    <tr class="ltr:text-left rtl:text-right">
                        <th class="border border-muted">#</th>
                        <th class="border border-muted">Part Number</th>
                        <th class="border border-muted">Description</th>
                        <th class="border border-muted">UM</th>
                        <th class="border border-muted">PP</th>
                        <th class="border border-muted">Base Value</th>
                        <th class="border border-muted">Physical Quantity</th>
                        <th class="border border-muted">System Quantity</th>
                        <th class="border border-muted">Variance Quantity</th>
                        <th class="border border-muted">Total Value</th>
                        <th class="border border-muted">Reason Code</th>
                        <th class="border border-muted">WC</th>
                        <th class="border border-muted">Remarks</th>
                        <th class="border border-muted" data-column="leader">Leader</th>
                    </tr>
                </thead>
                <tbody id="listOfPartnumber">
                </tbody>
            </table>
        </div>

        <div class="flex justify-between items-center bg-muted/20 h-32 px-6">
            <h2 class="text-base font-semibold text-black capitalize dark:text-white/80 p-2 rounded">
                Total Qty PIA: <span id="totalQty">0</span>
            </h2>

            <h2 class="text-base font-semibold text-black capitalize dark:text-white/80 p-2 rounded">
                Total PIA: <span id="totalRupiah">Rp 0,00</span>
            </h2>
        </div>

        <div class="card mt-2 p-3">
            <h2 class="text-sm font-semibold text-black dark:text-white/80 mb-2">
                Approval Chain
            </h2>
            <div id="approvalBadgesContainer"
                 class="flex flex-wrap gap-2 items-center min-h-[36px]">
                <span class="text-xs text-muted italic">
                    Approvers will appear here once parts are added.
                </span>
            </div>
        </div>

        <div id="buttonSubmitDraft" class="flex justify-between items-center bg-muted/20 h-36 px-4">
            <button id="submitBtnCreatePia" type="button"
                    class="flex items-center justify-center gap-2 px-6 py-2 bg-success text-white rounded-lg shadow w-full mr-2 hover:bg-success/[0.85] transition">
                <svg xmlns="http://www.w3.org/2000/svg"
                     class="w-5 h-5"
                     fill="none"
                     viewBox="0 0 24 24"
                     stroke="currentColor"
                     stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                Submit PIA
            </button>

            <button id="draftBtnCreatePia"
                    class="px-6 py-2 bg-warning text-white rounded-lg shadow w-full ml-2 hover:bg-warning transition hidden">
                Draft PIA
            </button>
        </div>
    </div>
</div>

<div id="addNotesForSpecialCodeRemarks" class="fixed inset-0 bg-black/80 z-[99998] hidden overflow-y-auto w-3000">
    <div class="flex items-start justify-center min-h-screen px-4">
        <div class="relative w-full max-w-5xl p-0 my-8 overflow-hidden bg-white border rounded-xl shadow-lg border-black/10">
            <!-- Header -->
            <div class="flex items-center justify-between px-5 py-3 bg-white border-b border-black/10">
                <h5 class="text-lg font-semibold">Special Code Remarks</h5>
            </div>

            <!-- Body -->
            <div class="p-5 space-y-5">
                <div id="toastContainerrSpecialCodeRemarks" class="flex justify-center mb-2"></div>
                <div>
                    <label class="mb-2 text-sm font-semibold">Document Remarks</label>

                    <input type="text" id="inputAddNotesForSpecialCodeRemarks" name="inputNotesSpecialRemarks" placeholder="Type your remarks for this document..."
                           class="form-input w-full rounded border border-black/10" />
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full border border-black/20 text-sm" id="tableSpecialCodeRemarks">
                        <thead class="bg-info">
                            <tr>
                                <th class="border px-2 py-1 w-12 text-center">No</th>
                                <th class="border px-2 py-1">Part Number</th>
                                <th class="border px-2 py-1">Part Remarks</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>

                <!-- Action buttons -->
                <div class="flex items-center justify-end gap-3">
                    <button id="closeAddNotesForSpecialCodeRemarks" type="button" class="btn bg-danger border-danger text-white hover:bg-danger/[0.85]">
                        Close
                    </button>
                    <button type="button"
                            id="saveAddNotesForSpecialCodeRemarks"
                            class="btn bg-purple border-purple text-white hover:bg-purple/[0.85]">
                        Save
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="modalTCCompanion"
     class="fixed inset-0 bg-black/60 z-[99999] hidden flex items-center justify-center">
    <div class="bg-white w-[420px] rounded-xl shadow-lg">
        <!-- Header -->
        <div class="flex items-center justify-between px-5 py-3 border-b">
            <h5 class="text-base font-semibold text-gray-800">
                TC Companion
            </h5>
        </div>

        <!-- Body -->
        <div class="px-5 py-4 space-y-3">
            <label class="text-sm font-medium text-gray-700">
                Select TC
            </label>
            <select id="TCCompanionDropdownModal"
                    class="form-input w-full h-[40px] text-sm rounded-md">
                <option value="">Not Required</option>
            </select>
        </div>

        <!-- Footer -->
        <div class="flex justify-end gap-3 px-5 py-3 border-t">
            <button id="closedTcCompanionModals" class="px-4 py-2 text-sm rounded-md bg-danger text-white">
                Cancel
            </button>
            <button id="saveTcCompanionModals" class="px-4 py-2 text-sm rounded-md bg-info text-white">
                Save
            </button>
        </div>
    </div>
</div>

<!-- End All Card -->
@section scripts{

    <script src="~/assets/js/main.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.28/jspdf.plugin.autotable.min.js"></script>

    <script>
        let partCounter = 0;
        let selectedTC = null;
        let allRemarks = [];
        let selectedPiaCode = null;
        let selectedPiaCodeString = null;
        let selectedCommit = false;
        let selectedFacilityInDropdown = null;
        let piaDocumentRules = [];
        let specialRemarksCache = {};
        let typeToTcMap = {}; // Global map to store Type -> TC relationship
        let isDetailFormAutoShown = false;
        const piaCodesWithNotes = ["MHK", "MII", "MOQ", "MQC"];
        const piaCodesWithTCCompanion = ["MHK", "MII", "MOQ", "MQC", "MAL", "DDS", "DDT", "ENC", "ENM", "ENP", "MH", "OMF", "QHE", "QPX", "QRS"];

        $(document).ready(function () {
            localStorage.removeItem("specialCodeRemarks");
            localStorage.removeItem("CompanionTc");
            localStorage.removeItem("CompanionTcValue");
            loadDocumentRules(2);

            loadPiaCodeRemarks();
            if (supervisorKpk) {
                prefillSupervisor(supervisorKpk, urlGetEmployee);
            }
            initSupervisorDropdown(
                "#supervisorInitiatorName",
                "#supervisorResults",
                "#supervisorInitiatorKpk",
                "#supervisorInitiatorName",
                urlGetEmployee
            );
            initSupervisorDropdown(
                "#previewSupervisorInitiatorName",
                "#previewSupervisorResults",
                "#previewSupervisorInitiatorKpk",
                "#previewSupervisorInitiatorName",
                urlGetEmployee
            );

            $("#previewTypeOfPiaDropdown").on("change", evaluateAutoShowDetailFormFromPreview);
            $("#previewFacilityDropdown").on("change", evaluateAutoShowDetailFormFromPreview);
            $("#previewSupervisorInitiatorName").on("input", evaluateAutoShowDetailFormFromPreview);
        });

        function arePreviewMandatoryFieldsCompleted() {
            const previewType = ($("#previewTypeOfPiaDropdown").val() || "").trim();
            const previewFacility = ($("#previewFacilityDropdown").val() || "").trim();
            const previewManagerKpk = ($("#previewSupervisorInitiatorKpk").val() || "").trim();
            return !!previewType && !!previewFacility && !!previewManagerKpk;
        }

        function syncPreviewHeaderToLegacyHiddenFields() {
            const previewType = ($("#previewTypeOfPiaDropdown").val() || "").trim();
            const previewFacility = ($("#previewFacilityDropdown").val() || "").trim();
            const previewManagerName = ($("#previewSupervisorInitiatorName").val() || "").trim();
            const previewManagerKpk = ($("#previewSupervisorInitiatorKpk").val() || "").trim();

            if (previewType) {
                $("#typeOfPiaDropdown").val(previewType).trigger("change");
            }

            if (previewFacility) {
                $("#facilityDropdown").val(previewFacility).trigger("change");
                $("#facilityInitiator").val(previewFacility);
            }

            $("#supervisorInitiatorName").val(previewManagerName);
            $("#supervisorInitiatorKpk").val(previewManagerKpk);
        }

        function showDetailFormAutomatically() {
            if (isDetailFormAutoShown) return;
            isDetailFormAutoShown = true;

            normalizeTcCompanionSelect(document.getElementById("previewTcCompanionDropdown"));
            normalizeTcCompanionSelect(document.getElementById("tcCompanionDropdown"));

            const $legacyContainer = $("#legacyPiaContainer");
            const $detailForm = $("#formContainerDetailsPartNumber");

            $legacyContainer.removeClass("hidden").css("display", "none").fadeIn(200);
            $("#legacyPiaHeaderTitle").addClass("hidden").css("display", "none");
            $("#legacyPiaHeaderFields").addClass("hidden").css("display", "none");
            $("#sectionContainer").addClass("hidden").css("display", "none");

            $detailForm.stop(true, true).hide().removeClass("hidden").slideDown(240);

            if (partCounter === 0) {
                const activeTc = document.getElementById("tcDropdown")?.value;
                if (activeTc) {
                    createPartCard(activeTc);
                }
            }
        }

        function evaluateAutoShowDetailFormFromPreview() {
            if (isDetailFormAutoShown) return;
            if (!arePreviewMandatoryFieldsCompleted()) return;

            syncPreviewHeaderToLegacyHiddenFields();
            showDetailFormAutomatically();
        }

        function showDropdownSpinner(wrapperId) {
            $("#" + wrapperId).append(
                '<div class="dropdown-spinner flex justify-center items-center p-2">' +
                '<div class="animate-spin inline-block size-6 border-[3px] border-l-transparent border-purple rounded-full"></div>' +
                '</div>'
            );
        }

        function showPreviewFieldLoading(wrapperId, message = "Loading...") {
            const $wrapper = $("#" + wrapperId);
            $wrapper.find(".preview-loading-state").remove();
            $wrapper.append(
                '<div class="preview-loading-state mt-2 flex items-center gap-2 text-xs text-muted">' +
                '<div class="animate-spin inline-block size-4 border-[2px] border-l-transparent border-purple rounded-full"></div>' +
                `<span>${message}</span>` +
                '</div>'
            );
        }

        function hidePreviewFieldLoading(wrapperId) {
            $("#" + wrapperId + " .preview-loading-state").remove();
        }

        function hideDropdownSpinner(wrapperId) {
            $("#" + wrapperId + " .dropdown-spinner").remove();
        }

        function restoreDropdown(dropdownId) {
            var dropdown = $("#" + dropdownId);
            var parent = dropdown.parent();
            var oldContent = dropdown.data("oldContent");

            if (oldContent) {
                parent.html(oldContent);
                dropdown = $("#" + dropdownId);
            }
            return dropdown;
        }

        function loadDocumentRules(application) {
            const typeWrapperId = $("#typeOfPiaDropdown").parent().attr("id");
            showDropdownSpinner(typeWrapperId);

            $.ajax({
                url: urlGetDocumentType,
                type: "GET",
                dataType: "json",
                data: { application: application },
                success: function (response) {
                    hideDropdownSpinner(typeWrapperId);
                    piaDocumentRules = Array.isArray(response) ? response : [];
                    initializePiaDocumentSelectors();
                    initializeNewLayoutPreviewSelectors();
                },
                error: function () {
                    hideDropdownSpinner(typeWrapperId);
                    handleAjaxError("Failed to load PIA document rules.");
                }
            });
        }

        function initializePiaDocumentSelectors() {
            const typeDropdown = $("#typeOfPiaDropdown");
            const facilityDropdown = document.getElementById("facilityDropdown");
            const tcDropdown = document.getElementById("tcDropdown");
            const facilityInput = document.getElementById("facilityInitiator");

            const typeOptions = [];
            const seenTypes = new Set();
            typeToTcMap = {}; // Reset and rebuild global map

            piaDocumentRules.forEach(function (item) {
                const typeName = (item.Type_Desc || "").trim();
                const tc = (item.TC || "").trim();
                const key = typeName.toLowerCase();
                if (!typeName || seenTypes.has(key)) return;
                seenTypes.add(key);

                // Store TC for this type
                if (tc) {
                    typeToTcMap[typeName] = tc;
                }

                // Display text with TC info
                const displayText = tc ? `${typeName} - TC${tc}` : typeName;
                typeOptions.push({ value: typeName, text: displayText, tc: tc });
            });

            typeDropdown.empty();
            typeDropdown.append('<option value="">-- Select Type --</option>');
            typeOptions.forEach(function (option) {
                typeDropdown.append(`<option value="${option.value}">${option.text}</option>`);
            });

            facilityDropdown.innerHTML = '<option value="">-- Select Facility --</option>';
            facilityDropdown.disabled = true;
            tcDropdown.innerHTML = '<option value="">-- Select TC --</option>';
            tcDropdown.disabled = true;
            facilityInput.value = "";
            selectedFacilityInDropdown = null;

            typeDropdown.off("change").on("change", function () {
                const selectedType = ($(this).val() || "").trim();
                resetPiaDownstreamSelectors();
                populateFacilityOptions(selectedType);

                // Auto-set TC based on Type
                const defaultTc = typeToTcMap[selectedType];
                if (defaultTc) {
                    tcDropdown.value = defaultTc;
                    // Trigger change event to load WC, PIA Code, and Remarks
                    $("#tcDropdown").trigger("change");
                }

                // Show/hide TC Companion form based on Type
                const isWip = selectedType.toLowerCase() === "wip";
                const tcCompanionCard = document.getElementById('tcCompanionCard');
                if (isWip) {
                    tcCompanionCard.classList.remove('hidden');
                    tcCompanionCard.style.display = '';
                } else {
                    tcCompanionCard.classList.add('hidden');
                    tcCompanionCard.style.display = 'none';
                    // Reset TC Companion dropdown when hiding
                    document.getElementById('tcCompanionDropdown').value = '';
                }

                // If Type is Subcont, WC is not required and should stay hidden.
                if (selectedType.toLowerCase() === "subcont") {
                    $('#piaCodeWCResultCard').addClass('hidden');
                    $('#wcDropdown').val('');
                    $('#wcDropdown').prop('disabled', true);
                } else {
                    // ensure WC can be shown later when TC selection allows it
                    $('#wcDropdown').prop('disabled', false);
                }
            });

            $("#facilityDropdown").off("change").on("change", function () {
                const selectedFacility = $(this).val();
                facilityInput.value = selectedFacility;
                selectedFacilityInDropdown = selectedFacility;
                populateTcOptions($("#typeOfPiaDropdown").val(), selectedFacility);
            });

            $("#tcDropdown").off("change").on("change", function () {
                const selectedTc = $(this).val();
                const selectedFacility = document.getElementById("facilityInitiator").value;

                if (!selectedTc) {
                    $('#piaCodeWCResultCard').addClass('hidden');
                    $('#piaCodeResultCard').addClass('hidden');
                    $('#piaCodeRemarksResultCard').addClass('hidden');
                    return;
                }

                if (!["20", "22"].includes(selectedTc)) {
                    loadWC(selectedFacility, "wcDropdown", "wcDropdown", "@Url.Action("GetWorkCenters", "DataForms")");
                    $('#piaCodeWCResultCard').removeClass('hidden');
                } else {
                    $('#piaCodeWCResultCard').addClass('hidden');
                }

                $('#piaCodeResultCard').removeClass('hidden');
                $('#piaCodeRemarksResultCard').removeClass('hidden');
                loadPiaCodeDropdown(
                    selectedFacility,
                    selectedTc,
                    "piaCodeDropdown",
                    "piaCodeDropdownWrapper",
                    "@Url.Action("GetPiaCodeByLocation", "DataForms")"
                );
            });

            if (typeOptions.length === 1) {
                typeDropdown.val(typeOptions[0].value).trigger("change");
            }
        }

