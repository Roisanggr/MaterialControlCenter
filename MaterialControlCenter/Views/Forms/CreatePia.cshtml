<!-- End All Card -->
@section scripts{

    <script src="~/assets/js/main.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.28/jspdf.plugin.autotable.min.js"></script>

    <script>
        let partCounter = 0;
        let selectedTC = null;
        let allRemarks = [];
        let selectedPiaCode = null;
        let selectedCommit = false;
        let selectedFacilities = plant;
        let selectedFacilityInDropdown = null;
        let specialRemarksCache = {};
        const piaCodesWithNotes = ["MHK", "MII", "MOQ", "MQC"];
        const piaCodesWithTCCompanion = ["MHK", "MII", "MOQ", "MQC", "MAL", "DDS", "DDT", "ENC", "ENM", "ENP", "MH", "OMF", "QHE", "QPX", "QRS"];

        $(document).ready(function () {
            localStorage.removeItem("specialCodeRemarks");
            localStorage.removeItem("CompanionTc");
            localStorage.removeItem("CompanionTcValue");
            loadTypeOfPiaDropdown();
            loadFacilityDropdown(
                selectedFacilities,
                "facilityDropdown",
                "facilityInitiator",
                "tcDropdown",
                TC_URL
            );

            loadPiaCodeRemarks();
            if (supervisorKpk) {
                prefillSupervisor(supervisorKpk, urlGetEmployee);
            }
            initSupervisorDropdown(
                "#supervisorInitiatorName",
                "#supervisorResults",
                "#supervisorInitiatorKpk",
                "#supervisorInitiatorName",
                urlGetEmployee
            );
        });

        function showDropdownSpinner(wrapperId) {
            $("#" + wrapperId).append(
                '<div class="dropdown-spinner flex justify-center items-center p-2">' +
                '<div class="animate-spin inline-block size-6 border-[3px] border-l-transparent border-purple rounded-full"></div>' +
                '</div>'
            );
        }

        function hideDropdownSpinner(wrapperId) {
            $("#" + wrapperId + " .dropdown-spinner").remove();
        }

        function restoreDropdown(dropdownId) {
            var dropdown = $("#" + dropdownId);
            var parent = dropdown.parent();
            var oldContent = dropdown.data("oldContent");

            if (oldContent) {
                parent.html(oldContent);
                dropdown = $("#" + dropdownId);
            }
            return dropdown;
        }

        function populateDropdown(dropdown, data, options = {}) {
            const {
                valueField = "id",
                placeholder = "-- Select Data --",
                formatFn = (item) => item.name
            } = options;

            dropdown.empty();
            dropdown.append(`<option value="">${placeholder}</option>`);

            $.each(data, function (i, item) {
                let displayText = formatFn(item);
                let value = item[valueField];
                dropdown.append(`<option value="${value}">${displayText}</option>`);
            });
        }

        function handleAjaxError(errorMsg) {
            showDynamicSwal({
                title: "Error",
                text: errorMsg,
                icon: "error",
                confirmText: "Close"
            });
        }

        function loadTypeOfPiaDropdown() {
            const dropdownId = "typeOfPiaDropdown";
            const wrapperId = $("#" + dropdownId).parent().attr("id");
            const dropdown = restoreDropdown(dropdownId);

            showDropdownSpinner(wrapperId);

            $.ajax({
                url: urlGetTypeScrap,
                type: 'GET',
                success: function (data) {
                    hideDropdownSpinner(wrapperId);


                    populateDropdown(dropdown, data, {
                        valueField: "Type_ID",
                        placeholder: "-- Select Type --",
                        formatFn: (item) => item.Type_Desc
                    });
                },
                error: function (xhr, status, error) {
                    hideDropdownSpinner(wrapperId);
                    handleAjaxError("Failed to load type PIA data.");
                }
            });
        }

        function loadFacilityDropdown(facilities, dropdownId, inputId, tcDropdownId, tcUrl) {
            const dropdown = document.getElementById(dropdownId);
            const input = document.getElementById(inputId);
            dropdown.innerHTML = "";

            if (typeof facilities === "string") {
                facilities = facilities.split(",").map(f => f.trim());
            }
            facilities = facilities.filter(Boolean);

            if (!facilities.length) {
                dropdown.innerHTML = `<option value="">-- Ask admin to assign facility --</option>`;
                dropdown.disabled = true;
                input.value = "";
                selectedFacilityInDropdown = null;
                return;
            }

            if (facilities.length === 1) {
                const fac = facilities[0];
                dropdown.innerHTML = `<option value="${fac}" selected>${fac}</option>`;
                dropdown.disabled = true;

                input.value = fac;
                selectedFacilityInDropdown = fac;
                console.log("Single facility auto-selected:", fac, "selectedFacilityInDropdown set to:", selectedFacilityInDropdown);
                const url = tcUrl + "?facility=" + encodeURIComponent(fac);
                console.log("Loading TC with URL:", url);
                loadTcDropdown(tcDropdownId, url);

                $('#piaCodeTcResultCard').removeClass('hidden');
                $('#piaCodeWCResultCard').addClass('hidden');
                $('#piaCodeResultCard').addClass('hidden');
                $('#piaCodeRemarksResultCard').addClass('hidden');
                return;
            }

            dropdown.append(new Option("-- Select Facility --", "", true, true));
            dropdown.options[0].disabled = true;
            facilities.forEach(fac => dropdown.append(new Option(fac, fac)));
            dropdown.disabled = false;

            dropdown.onchange = () => {
                const fac = dropdown.value;
                if (!fac) return;

                input.value = fac;
                selectedFacilityInDropdown = fac;
                console.log("Facility selected:", fac, "selectedFacilityInDropdown set to:", selectedFacilityInDropdown);

                const url = tcUrl + "?facility=" + encodeURIComponent(fac);
                console.log("Loading TC with URL:", url);
                loadTcDropdown(tcDropdownId, url);

                $('#piaCodeTcResultCard').removeClass('hidden');
                $('#piaCodeWCResultCard').addClass('hidden');
                $('#piaCodeResultCard').addClass('hidden');
                $('#piaCodeRemarksResultCard').addClass('hidden');
            };
        }

        function loadTcDropdown(dropdownId, url) {
            const wrapperId = dropdownId + "Wrapper";
            const dropdown = $("#" + dropdownId);
            dropdown.empty();
            dropdown.append('<option value="">Loading...</option>');
            dropdown.prop('disabled', true);
            showDropdownSpinner(wrapperId);

            $.ajax({
                url: url,
                type: 'GET',
                dataType: 'json',
                success: function(response) {
                    hideDropdownSpinner(wrapperId);
                    dropdown.empty();

                    if (response.success && response.data.length > 0) {
                         const selectedFacility = selectedFacilityInDropdown || document.getElementById("facilityInitiator")?.value;

                         console.log("DEBUG loadTcDropdown:", {
                             selectedFacility: selectedFacility,
                             selectedFacilityInDropdown: selectedFacilityInDropdown,
                             facilityInitiatorValue: document.getElementById("facilityInitiator")?.value,
                             allTCItems: response.data
                         });

                         // Filter: Type must be 'PIA', and either no Facility binding or matching facility
                         const filteredData = response.data.filter(item => {
                             const isTypeValid = item.Type === 'PIA';
                             const isFacilityMatch = !item.Facility || item.Facility === selectedFacility;
                             const willInclude = isTypeValid && isFacilityMatch;

                             if (item.Type === 'PIA') {
                                 console.log(`TC ${item.TC}: Type=${item.Type}, Facility=${item.Facility}, selectedFacility=${selectedFacility}, isFacilityMatch=${isFacilityMatch}, willInclude=${willInclude}`);
                             }

                             return willInclude;
                         });

                         console.log("Filtered TC data:", filteredData);

                         if (filteredData.length === 0) {
                             dropdown.append('<option value="">-- No TC Available --</option>');
                             dropdown.prop('disabled', true);
                             return;
                         }
                        dropdown.append('<option value="" disabled selected>-- Select TC --</option>');
                        dropdown.prop('disabled', false);
                        filteredData.sort((a, b) => parseInt(a.TC) - parseInt(b.TC));
                        filteredData.forEach(item => {
                            const optionText = `${item.TC} - ${item.Type} - ${item.TcDescription}`;
                            dropdown.append(
                                `<option value="${item.TC}" data-type="${item.Type}" data-desc="${item.TcDescription}">${optionText}</option>`
                            );
                        });
                        dropdown.off('change').on('change', function() {
                            selectedTC = $(this).val();
                            const selectedOption = $(this).find('option:selected');
                            const type = selectedOption.data('type');
                            const description = selectedOption.data('desc');
                            const facility = document.getElementById("facilityInitiator").value;

                            $('#piaCodeInput').val('');
                            $('#piaCodeHidden').val('');
                            $('#piaCodeResults').empty().hide();
                            $('#piaCodeResultCard').removeClass('hidden');
                            $('#piaCodeRemarksResultCard').removeClass('hidden');
                            $('#remarksDropdown').empty().append('<option value="">-- Select Remarks --</option>');
                            if (!["20", "22"].includes(selectedTC)) {
                               loadWC(facility, "wcDropdown", "wcDropdown", "@Url.Action("GetWorkCenters", "DataForms")");
                                $('#piaCodeWCResultCard').removeClass('hidden');
                            } else {
                                $('#piaCodeWCResultCard').addClass('hidden');
                            }
                            loadPiaCodeDropdown(
                                facility,
                                selectedTC,
                                "piaCodeDropdown",
                                "piaCodeDropdownWrapper",
                                "@Url.Action("GetPiaCodeByLocation", "DataForms")"
                            );

                        });

                    } else {
                        dropdown.append('<option value="">-- No TC Available --</option>');
                        dropdown.prop('disabled', true);

                        showDynamicSwal({
                            title: "No Data",
                            text: response.message || "Data Empty",
                            icon: "info",
                            confirmText: "OK"
                        });
                    }
                },
                error: function(xhr, status, error) {
                    hideDropdownSpinner(wrapperId);
                    dropdown.empty();
                    dropdown.append('<option value="">-- Error Loading TC --</option>');
                    dropdown.prop('disabled', true);

                    handleAjaxError("Something went wrong: " + error);
                }
            });
        }

        function loadWC(facility, dropdownId, wrapperId,url) {
            const $dropdown = restoreDropdown(dropdownId);
            showDropdownSpinner(wrapperId);

            $.ajax({
                url: url,
                type: 'GET',
                data: { facility: facility },
                success: function (response) {
                    hideDropdownSpinner(wrapperId);

                    if (response.success) {
                        populateDropdown($dropdown, response.data, {
                            valueField: 'WC',
                            placeholder: '-- Select WC --',
                            formatFn: (item) => `${item.WC} - ${item.Description || ''}`
                        });
                    } else {
                        handleAjaxError(response.message);
                    }
                },
                error: function (err) {
                    hideDropdownSpinner(wrapperId);
                    handleAjaxError("Gagal load WC");
                    console.error(err);
                }
            });
        }

        function loadPiaCodeDropdown(facility, selectedTC = null, dropdownId, wrapperId, url) {
            const $dropdown = restoreDropdown(dropdownId);
            showDropdownSpinner(wrapperId);

            $.ajax({
                url: url,
                type: 'GET',
                data: { location: facility, TC: selectedTC },
                dataType: 'json',
                success: function (response) {
                    hideDropdownSpinner(wrapperId);

                    if (response.success && response.data.length > 0) {
                        populateDropdown($dropdown, response.data, {
                            valueField: 'Code',
                            placeholder: '-- Select PIA Code --',
                            formatFn: (item) =>
                            (item.ShowScrapCode
                                ? `${item.ShowScrapCode} - ${item.Name}`
                                : `${item.Code} - ${item.Name}`)
                        });
