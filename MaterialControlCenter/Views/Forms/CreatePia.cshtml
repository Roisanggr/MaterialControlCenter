                    Are you sure?
                `;
                useHtml = true;
            }

            const result = await Swal.fire({
                title: "Submit PIA",
                ...(useHtml
                    ? {
                        html: confirmationText
                    }
                    : {
                        text: confirmationText
                    }),
                icon: "question",
                showCancelButton: true,
                confirmButtonText: "Yes, Save",
                cancelButtonText: "Cancel"
            });


