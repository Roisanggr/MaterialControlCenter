            $.ajax({
                url: '@Url.Action("GetRemarksByPiaCode", "DataForms")' + '?piaCode=' + encodeURIComponent(piaCode),
                type: 'GET',
                dataType: 'json',
                success: function(response) {
                    $dropdown.empty().append('<option value="">-- Select Remarks --</option>');
                    $dropdown.prop('disabled', false);

                    if (response.success && response.data.length > 0) {
                        response.data.forEach(item => {
