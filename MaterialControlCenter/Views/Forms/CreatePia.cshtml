                  <td class="border border-muted"><input id="baseValue-${partCounter}"  placeholder="Base Value" type="text" class="form-input w-24" readonly></td>
                  <td class="border border-muted"><input id="physicalQuantity-${partCounter}"  placeholder="Qty" type="number" step="${stepQty}"  min="${minQty}" class="form-input w-24"></td>
