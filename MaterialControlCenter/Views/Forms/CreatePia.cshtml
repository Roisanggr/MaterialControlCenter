                type: 'GET',
                dataType: 'json',
                success: function(response) {
                    $dropdown.empty().append('<option value="">-- Select Remarks --</option>');
                    $dropdown.prop('disabled', false);

                    if (response.success && response.data.length > 0) {
                        response.data.forEach(item => {
                            $dropdown.append(`<option value="${item.Id}">${item.RemarksText}</option>`);
                        });
                    } else {
                        $dropdown.append('<option value="">-- No Remarks Available --</option>');
                    }
                },
                error: function() {
                    $dropdown.empty().append('<option value="">-- Error Loading Remarks --</option>');
                    $dropdown.prop('disabled', false);
                }
