        function validateRequiredFields(fields, lockFields = false) {
            const emptyFields = fields.filter(f => {
                const el = document.getElementById(f.id);
                if (!el) return true;
                el.classList.remove("border-danger");

                if (f.id === "wcDropdown") {
                    const tcValue = document.getElementById("tcDropdown").value;
                    if (["20", "22"].includes(tcValue)) return false;
                }
                if (el.tagName === "SELECT") {
                    return el.value === "";
                }
                return !el.value || el.value.trim() === "";
            });
            emptyFields.forEach(f => {
                const el = document.getElementById(f.id);
                if (el) el.classList.add("border-danger");
            });

            if (emptyFields.length > 0) {
                const missingLabels = emptyFields.map(f => f.label).join(", ");
                showDynamicSwal({
                    title: "Incomplete Form",
                    text: `Please fill in the following field(s) first: ${missingLabels}`,
                    icon: "warning",
                    confirmText: "OK"
                });
                return false;
            }
            if (lockFields) {
                fields.forEach(f => {
                    const el = document.getElementById(f.id);
                    if (!el) return;

                    if (el.tagName === "INPUT") {
                        el.readOnly = true;
                    }

                    if (el.tagName === "SELECT") {
                        el.setAttribute("data-locked", "true");
                        el.style.pointerEvents = "none";
                    }
                    el.style.backgroundColor = "#f0f0f0";
                });
            }

            return true;
        }

