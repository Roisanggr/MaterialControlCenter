        function initPartAutocomplete(partCounter, selectedTC) {
            const input = document.getElementById(`partNumber-${partCounter}`);
            const suggestBox = document.getElementById(`partSuggest-${partCounter}`);
            const descInput = document.getElementById(`description-${partCounter}`);
            const baseValueInput = document.getElementById(`baseValue-${partCounter}`);
            const unitMeasurementInput = document.getElementById(`unit-${partCounter}`);
            const planit = document.getElementById(`planit-${partCounter}`);
            const cmidit = document.getElementById(`cmidit-${partCounter}`);
            const commit = document.getElementById(`commit-${partCounter}`);
            const processPointInput = document.getElementById(`processPoint-${partCounter}`);
            const totalValueInput = document.getElementById(`totalValue-${partCounter}`);

            const rowTr = document.getElementById(`row-${partCounter}`);
            let isSelecting = false;
            input.addEventListener("input", () => {
                if (isSelecting) return;
                resetRowExcept(partCounter);
            });
            let cacheData = [];
            const apiCache = {};
            let debounceTimer = null;
            let duplicateLock = false;

            function renderSuggest(response) {
                if (duplicateLock) return;
                suggestBox.innerHTML = "";
                suggestBox.classList.add("hidden");

                if (response.success && response.data.length > 0) {
                    cacheData = response.data;
                    document.body.appendChild(suggestBox);
                    const rect = input.getBoundingClientRect();
                    suggestBox.style.position = "absolute";
                    suggestBox.style.left = rect.left + "px";
                    suggestBox.style.top = rect.bottom + window.scrollY + "px";
                    suggestBox.style.minWidth = rect.width + "px";
                    suggestBox.style.maxWidth = "600px";
                    suggestBox.style.zIndex = 99999;
                    response.data.slice(0, 20).forEach(item => {
                        const div = document.createElement("div");
                        div.className = "px-3 py-1 hover:bg-info cursor-pointer text-sm";
                        div.textContent = `${item.PartNum} - ${item.Description}`;
                        div.addEventListener("click", () => handleSelect(item, partCounter));
                        suggestBox.appendChild(div);
                    });

                    suggestBox.classList.remove("hidden");
                } else {
                    cacheData = [];
                }
            }

            input.addEventListener("input", function () {
                clearTimeout(debounceTimer);
                const query = this.value.trim();
                if (duplicateLock) duplicateLock = false;
                debounceTimer = setTimeout(() => {
                    if (query.length < 2) {
                        suggestBox.innerHTML = "";
                        cacheData = [];
                        if (rowTr) {
                            rowTr.dataset.commit = "";
                            updateSelectedCommit();
                        }
                        return;
                    }

                    if (apiCache[query]) {
                        renderSuggest(apiCache[query]);
                        return;
                    }

                    $.ajax({
                        url: "@Url.Action("GetPartMasterUpdated", "DataForms")",
                        type: "GET",
                        data: { data: query, tc: selectedTC, exact: false},
                        success: function (response) {
                            apiCache[query] = response;
                            renderSuggest(response);
                        },
                        error: function () {
                            suggestBox.innerHTML = "";
                            cacheData = [];
                        }
                    });
                }, 300);
            });

            function handleSelect(selected, localCounter) {
                if (!selected) return;
                isSelecting = true;
                const input = document.getElementById(`partNumber-${localCounter}`);
                const descInput = document.getElementById(`description-${localCounter}`);
                const baseValueInput = document.getElementById(`baseValue-${localCounter}`);
                const unitMeasurementInput = document.getElementById(`unit-${localCounter}`);
                const processPointInput = document.getElementById(`processPoint-${localCounter}`);
                const totalValueInput = document.getElementById(`totalValue-${localCounter}`);
                const ftypit = document.getElementById(`ftypit-${localCounter}`);
                const typeit = document.getElementById(`typeit-${localCounter}`);
                const planit = document.getElementById(`planit-${localCounter}`);
                const cmidit = document.getElementById(`cmidit-${localCounter}`);
                const commit = document.getElementById(`commit-${localCounter}`);
                const rowTr = document.getElementById(`row-${localCounter}`);

                if (!input || !descInput || !baseValueInput || !unitMeasurementInput || !processPointInput || !ftypit || !typeit) {
                    console.warn(`⚠️ Missing field(s) on row-${localCounter}`);
                    return;
                }
                const allPartNumbers = Array.from(document.querySelectorAll("[id^='partNumber-']"))
                    .filter(el => el.id !== input.id)
                    .map(el => el.value.trim())
                    .filter(v => v !== "");

                if (allPartNumbers.includes(selected.PartNum.trim())) {
                    duplicateLock = true;
                    suggestBox.innerHTML = "";
                    suggestBox.classList.add("hidden");

                    showDynamicSwal({
                        title: "Duplicate Part Number",
                        text: `Part Number ${selected.PartNum.trim()} already exists!`,
                        icon: "error",
                        confirmText: "OK"
                    }).then(() => resetRow(localCounter));
                    return;
                }
                input.value = selected.PartNum;
                descInput.value = selected?.Description ?? "";
                baseValueInput.value = formatRupiah(selected?.BasePrice ?? 0);
                unitMeasurementInput.value = selected?.Measurement ?? "";
                processPointInput.value = selected?.ProcessPoint?.trim() ? selected.ProcessPoint : "N";
                ftypit.value = selected?.ftypit ?? "";
                typeit.value = selected?.typeit ?? "";
                planit.value = selected?.planit ?? "";
                cmidit.value = selected?.cmidit ?? "";
                commit.value = selected?.commit ?? "";
                if (rowTr) rowTr.dataset.commit = selected?.commit?.toLowerCase() ?? "";
                calculateTotal(localCounter);
                updateSelectedCommit();
                suggestBox.classList.add("hidden");

                function resetRow() {
                    input.value = "";
                    descInput.value = "";
                    baseValueInput.value = "";
                    unitMeasurementInput.value = "";
                    processPointInput.value = "";
                    document.getElementById(`ftypit-${localCounter}`).value = "";
                    document.getElementById(`typeit-${localCounter}`).value = "";
                    document.getElementById(`planit-${localCounter}`).value = "";
                    document.getElementById(`cmidit-${localCounter}`).value = "";
                    document.getElementById(`commit-${localCounter}`).value = "";
                    totalValueInput.value = "";
                    if (rowTr) rowTr.dataset.commit = "";
                    updateSelectedCommit();
                }
                setTimeout(() => {
                    isSelecting = false;
                }, 0);
            }
        }

        function updateSelectedCommit() {
            const allRows = document.querySelectorAll("[id^='row-']");
            let hasCommitX = false;
            allRows.forEach(row => {
                const commit = (row.dataset.commit || "").toLowerCase();
                row.classList.toggle("bg-warning/20", commit === "x");
                if (commit === "x") hasCommitX = true;
            });

            selectedCommit = hasCommitX;
        }

        function calculateTotal(counter) {
            const baseValueInput = document.getElementById(`baseValue-${counter}`);
            const varianceQtyInput = document.getElementById(`varianceQuantity-${counter}`);
            const totalValueInput = document.getElementById(`totalValue-${counter}`);

            if (!baseValueInput || !varianceQtyInput || !totalValueInput) return;

            let rawBase = baseValueInput.value || "0";
            rawBase = rawBase.replace(/[^\d,.-]/g, "");
            rawBase = rawBase.replace(/\./g, "");
            rawBase = rawBase.replace(",", ".");

            const baseValue = parseFloat(rawBase) || 0;
            const qty = parseFloat(varianceQtyInput.value) || 0;
            const total = baseValue * qty;

            totalValueInput.value = formatRupiah(total);
            updateGrandTotal();
        }

        function updateGrandTotal() {
            const rows = document.querySelectorAll("#listOfPartnumber tr");
            let totalQty = 0;
            let totalRupiah = 0;
            const partsData = [];

            rows.forEach(row => {
                const qtyInput = row.querySelector("input[id^='varianceQuantity-']");
                const totalInput = row.querySelector("input[id^='totalValue-']");

                // PIA tidak punya ftypit/typeit/commit per-part → kirim null
                let total = totalInput?.value?.replace(/[^\d,.-]/g, "") || "0";
                total = parseFloat(total.replace(/\./g, "").replace(",", ".")) || 0;

                totalQty += parseFloat(qtyInput?.value) || 0;
                totalRupiah += total;

                partsData.push({
                    value: total,
                    code: null,   // PIA tidak filter by code
                    tcType: null,   // PIA tidak filter by tcType
                    commit: false
                });
            });

            document.getElementById("totalQty").textContent = totalQty.toFixed(2);
            document.getElementById("totalRupiah").textContent = formatRupiah(totalRupiah);

            // ✅ Ganti checkPiaApprovalChain dengan fungsi generik
         checkApprovalChain("PIA", partsData, {
                documentCode: document.getElementById("piaCodeDropdown")?.value || ""
            });
        }

        document.getElementById("importExcel").addEventListener("click", function () {
            document.getElementById("excelFile").click();
        });

        document.getElementById("excelFile").addEventListener("change", function (e) {

            const file = e.target.files[0];
            if (!file) return;

            const reader = new FileReader();

            reader.onload = function (evt) {

                const data = new Uint8Array(evt.target.result);
                const workbook = XLSX.read(data, { type: "array" });

                const sheetName = workbook.SheetNames[0];
                const worksheet = workbook.Sheets[sheetName];
                const jsonData = XLSX.utils.sheet_to_json(worksheet, { header: 1 });
                const filteredData = jsonData.filter(row =>
                    row.some(cell => cell !== null && cell !== undefined && cell.toString().trim() !== "")
                );
                if (filteredData.length <= 1) {

                    Swal.fire({
                        icon: 'warning',
                        title: 'Empty Excel File',
                        text: 'The Excel file has no data to import.'
                    });

                    e.target.value = "";
                    return;
                }
                const invalidList = [];
                const invalidProcessPointParts = [];

                for (let r = 1; r < filteredData.length; r++) {

                    const partNum = filteredData[r][0]?.toString().trim();
                    if (!partNum) continue;

                    if (!isValidToyPart(partNum)) {
                        invalidList.push({
                            row: r,
                            value: partNum
                        });
                    }
                }

                if (invalidList.length > 0) {

                    Swal.fire({
                        icon: "error",
                        title: "Invalid Part Number Format",
                        html: `
                            <p>Please correct the following rows:</p>
                            <div style="text-align:left;margin-top:6px">
                                ${invalidList.map(x =>
                                    `Row ${x.row}: <b>${x.value}</b>`
                                ).join("<br>")}
                            </div>

                            <br><b>Required format:</b><br>
                            <code>TOYNIT-PARTIT</code><br>
                            Example:<br>
                            <code>MM031-9007</code>
                        `,
                        confirmButtonText: "OK",
                        allowOutsideClick: false
                    });

                    e.target.value = "";
                    return;
                }

                Swal.fire({
                    title: "Matching Data",
                    text: "Please wait while the data is being matched with the master list...",
                    allowOutsideClick: false,
                    didOpen: () => Swal.showLoading()
                });

                const totalAvailable = filteredData.length - 1;

                let uniqueCount = 0;
                let totalProcessedRows = 0;
                let processedAjax = 0;
                let totalAjaxRequest = 0;
                const duplicateParts = [];

                const existingParts = Array.from(
                    document.querySelectorAll("[id^='partNumber-']")
                )
                    .map(el => el.value.trim())
                    .filter(v => v !== "");

                for (let i = 1; i < filteredData.length; i++) {

                    if (uniqueCount >= 30) break;

                    const row = filteredData[i];
                    if (!row || row.length < 2) continue;

                    totalProcessedRows++;

                    const partNum = row[0]?.toString().trim();
                    const qty = row[1];
                    const leaderValue = row[2];

                    if (!partNum) continue;
                    if (existingParts.includes(partNum)) {
                        duplicateParts.push(partNum);
                        continue;
                    }
                    existingParts.push(partNum);
                    uniqueCount++;

                    if (partCounter >= 30) break;
                    let currentIndex;

                    if (uniqueCount === 1 && partCounter === 1) {
                        currentIndex = 1;
                    } else {
                        createPartCard(selectedTC);
                        currentIndex = partCounter;
                    }
                    const remarksInput = document.getElementById(`remarks-${currentIndex}`);
                    const remarksHidden = document.getElementById(`remarksId-${currentIndex}`);

                    filterRemarksByPiaCode(currentIndex, selectedPiaCode);

                    const remarksValue = row[3]?.toString();

                    if (remarksValue) {

                        const normalizedExcelRemarks = normalizeText(remarksValue);
                        const matchedRemark = allRemarks
                            .filter(r => r.ScrapCode === selectedPiaCode)
                            .find(r => normalizeText(r.Remarks) === normalizedExcelRemarks);

                        if (matchedRemark) {
                            remarksInput.value = matchedRemark.IdRemarks;
                            remarksHidden.value = matchedRemark.IdRemarks;
                        } else {
                            missingRemarks.push(remarksValue);
                        }
                    }
                    const specialRemark = row[4]?.toString().trim();
                    if (specialRemark) {
                        specialRemarksCache[partNum] = {
                            excelRow: i + 1,
                            remark: specialRemark
                        };

                    }

                    const partInput = document.getElementById(`partNumber-${currentIndex}`);
                    const physicalQtyInput = document.getElementById(`physicalQuantity-${currentIndex}`);
                    const systemQtyInput = document.getElementById(`systemQuantity-${currentIndex}`);
                    const varianceQtyInput = document.getElementById(`varianceQuantity-${currentIndex}`);
                    const descInput = document.getElementById(`description-${currentIndex}`);
                    const baseValueInput = document.getElementById(`baseValue-${currentIndex}`);
                    const unitInput = document.getElementById(`unit-${currentIndex}`);
                    const processPointInput = document.getElementById(`processPoint-${currentIndex}`);
                    const leaderInput = document.getElementById(`leader-${currentIndex}`);
                    const leaderKpkInput = document.getElementById(`leaderKpk-${currentIndex}`);
                    const ftypitInput = document.getElementById(`ftypit-${currentIndex}`);
                    const typeitInput = document.getElementById(`typeit-${currentIndex}`);
                    const planitInput = document.getElementById(`planit-${currentIndex}`);
                    const commitInput = document.getElementById(`commit-${currentIndex}`);
                    const cmiditInput = document.getElementById(`cmidit-${currentIndex}`);

                    partInput.value = partNum;
                    physicalQtyInput.value = qty || 0;
                    validateQtyInput(physicalQtyInput, currentIndex);
                    if (leaderValue) {

                        const cleanLeader = leaderValue.toString().trim();

                        $.ajax({
                            url: "@Url.Action("GetEmployeeByNameOrKpk","DataForms")",
                            type: "GET",
                            data: { keyword: cleanLeader },
                            success: function (res) {

                                if (res.success && res.data) {

                                    if (Array.isArray(res.data) && res.data.length) {
                                        leaderInput.value = res.data[0].name;
                                        leaderKpkInput.value = res.data[0].kpk;
                                    }
                                    else if (res.data.name && res.data.kpk) {
                                        leaderInput.value = res.data.name;
                                        leaderKpkInput.value = res.data.kpk;
                                    }
                                }
                                else {
                                    leaderInput.value = cleanLeader;
                                }
                            }
                        });
                    }
                    totalAjaxRequest++;
                    $.ajax({
                        url: "@Url.Action("GetPartMasterUpdated","DataForms")",
                        type: "GET",
                        data: { data: partNum, tc: selectedTC, exact: true },
                        success: function (response) {

                            if (response.success && response.data.length > 0) {
                                const selected = response.data[0];
                                descInput.value = selected.Description || "";
                                baseValueInput.value = formatRupiah(selected.BasePrice);
                                unitInput.value = selected.Measurement || "";
                                ftypitInput.value = selected.ftypit || "";
                                typeitInput.value = selected.typeit || "";
                                planitInput.value = selected.planit || "";
                                cmiditInput.value = selected.cmidit || "";
                                commitInput.value = selected.commit || "";
                                processPointInput.value = selected.ProcessPoint?.trim() || "N";

                                const isCommitX = selected?.commit?.toLowerCase() === 'x';
                                const rowDiv = document.getElementById(`row-${currentIndex}`);

                                if (rowDiv) rowDiv.classList.toggle('bg-warning/20', isCommitX);
                                if (isCommitX) selectedCommit = true;
                                if (!response.success || response.data.length === 0) {

                                    const expectedPP = selectedTC === "23" ? "N" : "Y";

                                    invalidProcessPointParts.push({
                                        partNumber: partNum,
                                        tc: selectedTC,
                                        expected: expectedPP,
                                        actual: expectedPP === "N" ? "Y" : "N",
                                        reason: `Invalid Process Point for TC ${selectedTC}`
                                    });

                                    removeRowByElement(rowDiv);
                                    return;
                                }
                                calculateTotal(currentIndex);
                            }
                        },
                        complete: function () {
                            processedAjax++;
                            if (processedAjax >= totalAjaxRequest) {

                                Swal.close();

                                for (let i = 1; i <= partCounter; i++) {
                                    validatePartCard(i, selectedTC == "22");
                                }

                                let htmlMessage = `<p>Imported <b>${uniqueCount}</b> unique parts from ${totalProcessedRows} rows.</p>`;
                                let icon = "success";

                                if (duplicateParts.length > 0 || missingRemarks.length > 0) {

                                    icon = "warning";
                                    htmlMessage += "<br>";

                                    if (duplicateParts.length)
                                        htmlMessage += `<p><b>Duplicate parts skipped:</b><br>${duplicateParts.join(", ")}</p>`;

                                    if (missingRemarks.length)
                                        htmlMessage += `<p><b>Remarks not found:</b><br>${missingRemarks.join(", ")}</p>`;

                                    if (invalidProcessPointParts.length)
                                        htmlMessage += `
                                        <hr><b>Skipped (Invalid TC):</b>
                                        <ul>${invalidProcessPointParts.map(p =>
                                            `<li>${p.partNumber} (TC ${p.tc})</li>`
                                        ).join("")}</ul>`;

                                }

                                Swal.fire({
                                    icon: icon,
                                    title: icon === "success"
                                        ? "Import Completed"
                                        : "Import Completed (Check Details)",
                                    html: htmlMessage
                                });

                                document.getElementById("excelFile").value = "";
                            }
                        }
                    });
                }
            };

            reader.readAsArrayBuffer(file);
        });

        function removeRowByElement(rowElement) {
            if (!rowElement) return;

            rowElement.remove();
            reindexRows();

            document.querySelectorAll("#listOfPartnumber tr").forEach(r => {
                const commitInput = r.querySelector("input[id^='commit-']");
                r.dataset.commit = commitInput?.value || "";
            });

            updateGrandTotal();
            updateSelectedCommit();
        }

        function initLeaderAutocomplete(counter, urlGetEmployee) {
            const leaderInput = document.getElementById(`leader-${counter}`);
            const leaderList = document.getElementById(`leaderList-${counter}`);
            const leaderKpkInput = document.getElementById(`leaderKpk-${counter}`);
            const facility = document.querySelector("#facilityInitiator")?.value.trim();
            if (facility === "P1" && kpk) {
                leaderKpkInput.value = kpk;
                fetchData(urlGetEmployee, { keyword: kpk }, function (res) {
                    if (res.success && res.data?.length > 0) { 
                        leaderInput.value = res.data[0].name;
                    } else {
                        leaderInput.value = kpk;
                    }
                });
                leaderInput.readOnly = true;
                return;
            }
            leaderInput.addEventListener("input", function () {
                const search = this.value.trim();
                leaderList.innerHTML = "";
                leaderList.classList.add("hidden");

                if (search.length < 3) return;

                fetchData(urlGetEmployee, { keyword: search }, function (res) {
                    leaderList.innerHTML = "";
                    if (res.success && Array.isArray(res.data)) {
                        res.data.forEach(emp => {
                            const item = document.createElement("div");
                            item.className = "px-3 py-1 hover:bg-info cursor-pointer text-sm";
                            item.textContent = `${emp.name} (${emp.kpk})`;
                            item.dataset.kpk = emp.kpk;
                            item.dataset.name = emp.name;
                            item.addEventListener("click", () => {
                                leaderInput.value = emp.name;
                                leaderKpkInput.value = emp.kpk;
                                leaderList.classList.add("hidden");
                            });

                            leaderList.appendChild(item);
                        });
                        leaderList.classList.remove("hidden");
                    }
                });
            });
            document.addEventListener("click", (e) => {
                if (!leaderInput.contains(e.target) && !leaderList.contains(e.target)) {
                    leaderList.classList.add("hidden");
                }
            });
        }

        function prefillSupervisor(kpk, apiUrl) {
            if (!kpk) return;

            fetchData(apiUrl, { keyword: kpk }, function (res) {
                if (res.success && Array.isArray(res.data) && res.data.length > 0) {
                    const emp = res.data[0];
                    $("#supervisorInitiatorKpk").val(emp.kpk);
                    $("#supervisorInitiatorName").val(emp.name);
                } else {
                    $("#supervisorInitiatorKpk").val(kpk);
                    $("#supervisorInitiatorName").val("");
                }
            });
        }

        function capitalizeWords(str) {
            return str
                .toLowerCase()
                .replace(/\b\w/g, c => c.toUpperCase());
        }

        function initSupervisorDropdown(inputSelector, resultsSelector, kpkSelector, nameSelector, apiUrl) {
            const $input = $(inputSelector);
            const $results = $(resultsSelector);

            $input.on("input", function () {
                const query = $(this).val().trim();

                if (query.length < 3) {
                    $results.empty().hide();
                    return;
                }

                fetchData(apiUrl, { keyword: query }, function (res) {
                    $results.empty();

                    if (res.success && Array.isArray(res.data)) {
                        res.data.forEach(item => {
                            const option = $("<div>")
                                .addClass("dropdown-item hover:bg-success/[0.85] cursor-pointer p-2 rounded")
                                .text(capitalizeWords(item.name) + " (" + item.kpk + ")")
                                .on("click", function () {
                                    $(kpkSelector).val(item.kpk);
                                    $(nameSelector).val(capitalizeWords(item.name));
                                    $results.empty().hide();
                                });


                            $results.append(option);
                        });

                        $results.show();
                    } else {
                        $results.hide();
                    }
                });
            });
        }

