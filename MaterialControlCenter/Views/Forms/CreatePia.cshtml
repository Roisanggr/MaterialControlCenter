        function buildPiaPayload() {
            const masterData = {
                Facility: document.getElementById("facilityInitiator")?.value || null,
                TC: document.getElementById("tcDropdown")?.value || null,
                PiaCode: document.getElementById("piaCodeDropdown")?.value || null,
                WC: document.getElementById("wcDropdown")?.value || null,
                InitiatorKpk: typeof kpk !== "undefined" ? kpk : null,
                Type_ID: document.getElementById("typeOfPiaDropdown")?.value || null,
                SpecialCodeRemarks: localStorage.getItem("specialCodeRemarks") || null,
                SpecialCodeTcCompanion: localStorage.getItem("CompanionTc") || null,
            };
            const rows = document.querySelectorAll("#listOfPartnumber tr");
            const partDataList = [];
            rows.forEach((row) => {

                const partNum = row
                    .querySelector('input[id^="partNumber-"]')
                    ?.value
                    ?.trim() || null;
                if (!partNum) return;
                const specialRemarksParts =
                    specialRemarksCache[partNum]?.remark || "";

                let rawBase =
                    row.querySelector('input[id^="baseValue-"]')?.value || "0";

                rawBase = rawBase.replace(/[^\d,.-]/g, "");
                rawBase = rawBase.replace(/\./g, "");
                rawBase = rawBase.replace(",", ".");
                const baseValue = parseFloat(rawBase) || 0;

                const physicalQty = Number(row.querySelector('input[id^="physicalQuantity-"]')?.value || "0");
                const systemQty = Number(row.querySelector('input[id^="systemQuantity-"]')?.value || "0");
                const varianceQty = Number(row.querySelector('input[id^="varianceQuantity-"]')?.value || "0");

                let rawTotalValue = row.querySelector('input[id^="totalValue-"]')?.value || "0";
                rawTotalValue = rawTotalValue.replace(/[^\d,.-]/g, "");
                rawTotalValue = rawTotalValue.replace(/\./g, "");
                rawTotalValue = rawTotalValue.replace(",", ".");
                const totalValue = parseFloat(rawTotalValue) || 0;

                const part = {
                    PartNum: partNum,
                    Description: row.querySelector('input[id^="description-"]')?.value || null,
                    PhysicalQty: physicalQty,
                    SystemQty: systemQty,
                    VarianceQty: varianceQty,
                    Qty: varianceQty,
                    Value: totalValue,
                    Remarks: row.querySelector('select[id^="remarks-"]')?.value || null,
                    RemarksText:
                        row.querySelector('select[id^="remarks-"] option:checked')?.textContent || null,
                    SpecialcodeRemarksParts: specialRemarksParts,

                    ProcessPoint: row.querySelector('input[id^="processPoint-"]')?.value || null,
                    Ftypit: row.querySelector('input[id^="ftypit-"]')?.value || null,
                    Typeit: row.querySelector('input[id^="typeit-"]')?.value || null,
                    LeaderKPK: row.querySelector('input[id^="leaderKpk-"]')?.value || null,
                    RnNumber: row.querySelector('input[id^="rn-"]')?.value || null,
                    Measit: row.querySelector('input[id^="unit-"]')?.value || null,
                    Planit: row.querySelector('input[id^="planit-"]')?.value || null,
                    Cmidit: row.querySelector('input[id^="cmidit-"]')?.value || null,
                    Commit: row.querySelector('input[id^="commit-"]')?.value || null,
                    BasePrice: baseValue,
                    RespCode: row.querySelector('input[id^="respCode-"]')?.value || null
                };

                partDataList.push(part);
            });

            return {
                Master: masterData,
                Parts: partDataList,
                detectedKPKGlobal:
                    typeof detectedKPKGlobal !== "undefined"
                        ? detectedKPKGlobal
                        : []
            };
        }

        async function generatePiaPDFBase64() {
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF({
                unit: "mm",
                format: "a4",
                compress: true
            });

            const payload = buildPiaPayload();
            const master = payload.Master;
            const parts = payload.Parts;
            const totalQty = parts.reduce((sum, p) => sum + (parseFloat(p.Qty) || 0), 0);
            const totalValue = parts.reduce((sum, p) => sum + (parseFloat(p.Value) || 0), 0);
            const logoUrl = '@Url.Content("~/assets/images/mattel-logo.png")';
            const logoImg = new Image();
            logoImg.src = logoUrl;
            await new Promise(resolve => (logoImg.onload = resolve));
            const typeLabel =
                parseInt(master.Type_ID) === 1 ? "REGULAR" :
                    parseInt(master.Type_ID) === 2 ? "RAP" :
                        master.Type_ID || "-";

            const rnValue = (parts || []).map(p => p.RnNumber).filter(Boolean)[0] || "N/A";

            const masterEntries = [
                ["Facility", master.Facility || "-"],
                ["TC", master.TC || "-"],
                ["TC Companion", master.SpecialCodeTcCompanion || "N/A"],
                ["PIA Code", master.PiaCode || "-"],
                ["WC", master.WC || "-"],
                ["RN", rnValue],
                ["Initiator KPK", master.InitiatorKpk || "-"],
                ["Type", typeLabel]
            ];

            const header = (doc, pageNumber, totalPages) => {
                const pageWidth = doc.internal.pageSize.getWidth();
                const logoMaxWidth = 8;
                const logoAspect = logoImg.width / logoImg.height;
                const logoWidth = logoMaxWidth;
                const logoHeight = logoWidth / logoAspect;
                const logoX = 14;
                const logoY = 8;
                doc.addImage(logoImg, "JPEG", logoX, logoY, logoWidth, logoHeight, '', 'FAST');

                doc.setFontSize(14);
                doc.setFont("helvetica", "bold");
                doc.setTextColor(0, 51, 102);
                const title = "PIA NOTICE";
                const textWidth = doc.getTextWidth(title);
                const textY = logoY + logoHeight / 2 + 3;
                doc.text(title, (pageWidth - textWidth) / 2, textY);
                const lineY = logoY + logoHeight + 4;
                doc.setDrawColor(0, 51, 102);
                doc.setLineWidth(0.3);
                doc.line(14, lineY, 196, lineY);

                doc.setFontSize(9);
                doc.setFont("helvetica", "normal");
                doc.setTextColor(0, 0, 0);

                let leftY = lineY + 7;
                let rightY = lineY + 7;
                const leftX = 14;
                const rightX = 110;

                for (let i = 0; i < 4; i++) {
                    const [key, value] = masterEntries[i];
                    doc.text(`${key}:`, leftX, leftY);
                    doc.text(value, leftX + 28, leftY);
                    leftY += 5;
                }

                for (let i = 4; i < masterEntries.length; i++) {
                    const [key, value] = masterEntries[i];
                    doc.text(`${key}:`, rightX, rightY);
                    doc.text(value, rightX + 28, rightY);
                    rightY += 5;
                }

                leftY += 3;
                doc.setFont("helvetica", "bold");
                doc.text("Total Qty:", leftX, leftY);
                doc.setFont("helvetica", "normal");
                doc.text(totalQty.toLocaleString(), leftX + 28, leftY);

                rightY += 3;
                doc.setFont("helvetica", "bold");
                doc.text("Total Value:", rightX, rightY);
                doc.setFont("helvetica", "normal");
                doc.text(formatRupiah(totalValue), rightX + 28, rightY);

                const pageHeight = doc.internal.pageSize.height;
                doc.setFontSize(8);
                doc.setTextColor(100);
                doc.text(`Page ${pageNumber} of ${totalPages}`, pageWidth - 30, pageHeight - 8);
            };

            const MAX_ROWS = 200;
            const tableData = (parts || [])
                .slice(0, MAX_ROWS)
                .map(p => [
                    p.PartNum || "-",
                    p.Description || "-",
                    (p.PhysicalQty !== undefined ? p.PhysicalQty : p.Qty) || 0,
                    (p.SystemQty !== undefined ? p.SystemQty : "-") || "-",
                    (p.VarianceQty !== undefined ? p.VarianceQty : p.Qty) || 0,
                    (p.Value || 0).toFixed(2),
                    p.ProcessPoint || "-",
                    p.LeaderKPK || "-",
                    p.RemarksText || "-",
                    p.SpecialcodeRemarksParts || "N/A"
                ]);

            doc.autoTable({
                startY: 65,
                margin: { top: 65 },
                head: [["Part Number", "Description", "Physical Qty", "System Qty", "Variance Qty", "Value", "Process Point", "Leader KPK", "Remarks", "Special Remarks"]],
                body: tableData,
                theme: "grid",
                styles: { fontSize: 8, cellPadding: 1, lineWidth: 0.1 },
                headStyles: {
                    fillColor: [0, 51, 102],
                    textColor: 255,
                    fontStyle: "bold"
                },
                didDrawPage: (data) => {
                    const pageCount = doc.internal.getNumberOfPages();
                    header(doc, data.pageNumber, pageCount);
                }
            });
            const pdfBase64 = doc.output("datauristring", { compress: true });
            return pdfBase64;
        }

        function insertPia(payload) {
            return fetch('@Url.Action("InsertPiaAsync", "DataForms")', {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify(payload)
            })
            .then(async res => {
                const data = await res.json();
                if (!res.ok) {
                    const serverMsg = data.Error || ("Server error: HTTP " + res.status);
                    const err = new Error(serverMsg);
                    err.isServerError = true;
                    throw err;
                }
                return data;
            });
        }

        $("#openModalsForAnalyzedCaseMaterial").on("click", function (e) {
            e.preventDefault();

            const tbody = $("#tableSpecialCodeRemarks tbody");
            tbody.empty();

            let no = 1;

            $("#listOfPartnumber tr").each(function () {
                const partNumber = $(this)
                    .find('input[id^="partNumber-"]')
                    .val()
                    ?.trim();

                if (!partNumber) return;

                const cachedRemark = specialRemarksCache[partNumber]?.remark || "";

                const row = `
            <tr>
                <td class="border px-2 py-1 text-center">${no}</td>
                <td class="border px-2 py-1">${partNumber}</td>
                <td class="border px-2 py-1">
                    <input
                        type="text"
                        class="form-input w-full special-remark-input"
                        data-part="${partNumber}"
                        value="${cachedRemark}"
                        placeholder="Type your remarks for this part number"
                    />
                </td>
            </tr>
        `;

                tbody.append(row);
                no++;
            });

            $("#addNotesForSpecialCodeRemarks").removeClass("hidden");
        });


        $("#closeAddNotesForSpecialCodeRemarks").on("click", function () {
            resetModalsForAnalyzedCaseMaterial();
        });
        $("#saveAddNotesForSpecialCodeRemarks").on("click", function () {

            let hasValue = false;
            const docRemark = $("#inputAddNotesForSpecialCodeRemarks").val().trim();
            if (docRemark !== "") {
                localStorage.setItem("specialCodeRemarks", docRemark);
            }

            $("#tableSpecialCodeRemarks tbody .special-remark-input").each(function () {
                const partNumber = $(this).data("part");
                const value = $(this).val().trim();

                if (!partNumber) return;

                if (value !== "") hasValue = true;

                if (!specialRemarksCache[partNumber]) {
                    specialRemarksCache[partNumber] = {
                        excelRow: null,
                        remark: ""
                    };
                }
                specialRemarksCache[partNumber].remark = value;

                const partIndex = $(`#listOfPartnumber input[value="${partNumber}"]`)
                    .attr("id")
                    ?.split("-")[1];

                if (partIndex) {
                    const partRemarkInput = $(`#specialRemark-${partIndex}`);
                    if (partRemarkInput.length) {
                        partRemarkInput.val(value);
                    }
                }
            });

            if (!hasValue) {
                showSpecialCodeToast("At least one remark must be filled", "error");
                return;
            }

            showSpecialCodeToast("Remarks saved", "success");

            setTimeout(() => {
                $("#addNotesForSpecialCodeRemarks").addClass("hidden");
            }, 500);
        });

        function resetModalsForAnalyzedCaseMaterial() {
            $("#addNotesForSpecialCodeRemarks").addClass("hidden");

        }

        function showSpecialCodeToast(message, type = "error") {
            const toastHtml = `
                <div class="px-4 py-2 rounded text-sm font-medium
                    ${type === "error" ? "bg-danger border success" : ""}
                    ${type === "success" ? "bg-success border-success" : ""}
                ">
                    ${message}
                </div>
            `;

            $("#toastContainerrSpecialCodeRemarks")
                .html(toastHtml)
                .fadeIn(200);

            setTimeout(() => {
                $("#toastContainerrSpecialCodeRemarks").fadeOut(300, function () {
                    $(this).empty();
                });
            }, 3000);
        }

        function validateSpecialCodeRemarks() {

            if (!piaCodesWithNotes.includes(selectedPiaCode)) {
                return { valid: true };
            }

            const remarks = localStorage.getItem("specialCodeRemarks");

            if (!remarks || remarks.trim() === "") {
                return {
                    valid: false,
                    message: "Special Remarks Notes must be filled in for the selected PIA code."

                };
            }

            return { valid: true };
        }

    </script>
}
