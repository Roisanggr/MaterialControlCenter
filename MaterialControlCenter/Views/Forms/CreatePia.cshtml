        function populateFacilityOptions(selectedType) {
            const facilityDropdown = document.getElementById("facilityDropdown");
            const facilityInput = document.getElementById("facilityInitiator");
            const filteredFacilities = piaDocumentRules
                .filter(function (item) {
                    return (item.Type_Desc || "").trim() === selectedType && (item.Facility || "").trim() !== "";
                })
                .map(function (item) { return (item.Facility || "").trim(); })
                .filter(function (value, index, array) { return array.indexOf(value) === index; });

            facilityDropdown.innerHTML = '<option value="">-- Select Facility --</option>';

            if (filteredFacilities.length === 0) {
                facilityDropdown.disabled = true;
                facilityInput.value = "";
                return;
            }

            filteredFacilities.forEach(function (facility) {
                facilityDropdown.append(new Option(facility, facility));
            });

            facilityDropdown.disabled = false;
            if (filteredFacilities.length === 1) {
                facilityDropdown.value = filteredFacilities[0];
                facilityInput.value = filteredFacilities[0];
                selectedFacilityInDropdown = filteredFacilities[0];
                populateTcOptions(selectedType, filteredFacilities[0]);
            }
