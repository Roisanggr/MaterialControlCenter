        function isEmpty(value) {
            return value.trim() === "";
        }

        function isInvalidQuantity(value) {
            const num = parseFloat(value);
            return isNaN(num) || num <= 0;
        }

        function isInvalidField(id, value) {
            if (id.startsWith("quantity-")) {
                return isInvalidQuantity(value);
            }
            return isEmpty(value);
        }

        function validatePartCard(partCounter, showSpecialFields) {
            const rowTr = document.getElementById(`row-${partCounter}`);
            let isValid = true;

            const fields = [
                `partNumber-${partCounter}`,
                `description-${partCounter}`,
                `unit-${partCounter}`,
                `processPoint-${partCounter}`,
                `baseValue-${partCounter}`,
                `physicalQuantity-${partCounter}`,
                `systemQuantity-${partCounter}`,
                `varianceQuantity-${partCounter}`,
                `totalValue-${partCounter}`,
                `leaderKpk-${partCounter}`,
            ];

            if (showSpecialFields) {
                fields.push(`rn-${partCounter}`, `respCode-${partCounter}`);
            }
            fields.forEach(id => {
                const input = document.getElementById(id);
                if (!input) return;

                const invalid = isInvalidField(id, input.value);

                if (invalid) {
                    isValid = false;
                    input.classList.add("bg-danger/20", "dark:bg-danger/20");
                } else {
                    input.classList.remove("bg-danger/20", "dark:bg-danger/20");
                }
            });

            if (rowTr) {
                if (!isValid) {
                    rowTr.classList.add("bg-danger/20", "dark:bg-danger/20");
                } else {
                    rowTr.classList.remove("bg-danger/20", "dark:bg-danger/20");
                }
            }

            return isValid;
        }

