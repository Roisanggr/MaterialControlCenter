                    qtyInput.value = value.replace(/[.,]/g, "");
                    qtyInput.classList.add("border-danger");
                    showQtyWarning(rowIndex, "Quantity for this PIA Code must be a whole number (no decimals)");
                } else {
                    qtyInput.classList.remove("border-danger");
                    removeQtyWarning(rowIndex);
                }
            }
            else {
                qtyInput.classList.remove("border-danger");
                removeQtyWarning(rowIndex);
            }
        }

