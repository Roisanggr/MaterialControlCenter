        function initLeaderAutocomplete(counter) {
            var leaderInput    = document.getElementById("leader-" + counter);
            var leaderList     = document.getElementById("leaderList-" + counter);
            var leaderKpkInput = document.getElementById("leaderKpk-" + counter);

            if (!leaderInput || !leaderList || !leaderKpkInput) {
                console.error("[Leader] Element not found for counter:", counter);
                return;
            }

            // Auto-prefill dari KPK user yang sedang login
            if (typeof kpk !== "undefined" && kpk) {
                leaderKpkInput.value = kpk;
                $.ajax({
                    url: "@Url.Action("GetEmployeeByNameOrKpk","DataForms")",
                    type: "GET",
                    data: { keyword: String(kpk) },
                    success: function (res) {
                        if (res.success && Array.isArray(res.data) && res.data.length > 0) {
                            leaderInput.value = res.data[0].name;
                            leaderKpkInput.value = res.data[0].kpk;
                        } else {
                            leaderInput.value = String(kpk);
                        }
                        leaderInput.readOnly = true;
                        leaderInput.style.backgroundColor = "#f0f0f0";
                        leaderInput.style.cursor = "not-allowed";
                    },
                    error: function () {
                        leaderInput.value = String(kpk);
                        leaderInput.readOnly = true;
                        leaderInput.style.backgroundColor = "#f0f0f0";
                        leaderInput.style.cursor = "not-allowed";
                    }
                });
                return;
            }

            // Tetap bisa dicari manual jika perlu ganti
            var leaderDebounce = null;

            leaderInput.addEventListener("input", function () {
                var search = this.value.trim();
                leaderList.innerHTML = "";
                leaderList.classList.add("hidden");
                leaderKpkInput.value = "";

                if (search.length < 2) return;

                clearTimeout(leaderDebounce);
                leaderDebounce = setTimeout(function () {
                    $.ajax({
                        url: "@Url.Action("GetEmployeeByNameOrKpk","DataForms")",
                        type: "GET",
                        data: { keyword: search },
                        success: function (res) {
                            leaderList.innerHTML = "";
                            if (res.success && Array.isArray(res.data) && res.data.length > 0) {
                                res.data.forEach(function (emp) {
                                    var item = document.createElement("div");
                                    item.className = "px-3 py-1 hover:bg-info cursor-pointer text-sm";
                                    item.textContent = emp.name + " (" + emp.kpk + ")";
                                    item.addEventListener("mousedown", function (e) {
                                        e.preventDefault();
                                        leaderInput.value = emp.name;
                                        leaderKpkInput.value = emp.kpk;
                                        leaderList.innerHTML = "";
                                        leaderList.classList.add("hidden");
                                    });
                                    leaderList.appendChild(item);
                                });
                                leaderList.classList.remove("hidden");
                            }
                        },
                        error: function (xhr, status, err) {
                            console.error("[Leader] AJAX error:", status, err);
                        }
                    });
                }, 300);
            });

            leaderInput.addEventListener("blur", function () {
                setTimeout(function () {
                    leaderList.classList.add("hidden");
                }, 200);
            });
        }

