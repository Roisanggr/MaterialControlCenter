                `remarks-${partCounter}`,
                // `leaderKpk-${partCounter}`,
            ];

            if (showSpecialFields) {
                fields.push(`rn-${partCounter}`, `respCode-${partCounter}`);
            }
            fields.forEach(id => {
                const input = document.getElementById(id);
                if (!input) return;

                const invalid = isInvalidField(id, input.value);

                if (invalid) {
                    isValid = false;
                    input.classList.add("bg-danger/20", "dark:bg-danger/20");
                } else {
                    input.classList.remove("bg-danger/20", "dark:bg-danger/20");
                }
            });

            if (rowTr) {
                if (!isValid) {
                    rowTr.classList.add("bg-danger/20", "dark:bg-danger/20");
                } else {
                    rowTr.classList.remove("bg-danger/20", "dark:bg-danger/20");
                }
            }

            return isValid;
        }

