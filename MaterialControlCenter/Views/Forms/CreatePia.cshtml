<div id="modalTCCompanion"
     class="fixed inset-0 bg-black/60 z-[99999] hidden flex items-center justify-center">
    <div class="bg-white w-[420px] rounded-xl shadow-lg">
        <!-- Header -->
        <div class="flex items-center justify-between px-5 py-3 border-b">
            <h5 class="text-base font-semibold text-gray-800">
                TC Companion
            </h5>
