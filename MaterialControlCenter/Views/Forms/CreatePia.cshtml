                        html: `PIA ID: <b>${data.IdPia}</b><br>Parts Count: <b>${data.PartsCount || 0}</b>`,
                        icon: "success"
                    }).then(() => {
                        window.location.reload();
                    });
                }
            } catch (err) {
                Swal.close();
                submitBtn.disabled = false;
                submitBtn.style.opacity = "";
                console.error("Error submitting PIA:", err);
                if (err.isServerError) {
                    Swal.fire({
