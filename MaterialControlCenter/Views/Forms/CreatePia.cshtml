            // Add event listeners for automatic variance quantity calculation
            const calculateVarianceQuantity = () => {
                const physical = parseFloat(physicalQtyInput.value) || 0;
                const system = parseFloat(systemQtyInput.value) || 0;
                const variance = physical - system;
                varianceQtyInput.value = variance;
                calculateTotal(partCounter);
