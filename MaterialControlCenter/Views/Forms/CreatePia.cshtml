        function initPartAutocomplete(partCounter, selectedTC) {
            const input = document.getElementById(`partNumber-${partCounter}`);
            const suggestBox = document.getElementById(`partSuggest-${partCounter}`);
            const descInput = document.getElementById(`description-${partCounter}`);
            const baseValueInput = document.getElementById(`baseValue-${partCounter}`);
            const unitMeasurementInput = document.getElementById(`unit-${partCounter}`);
            const planit = document.getElementById(`planit-${partCounter}`);
            const cmidit = document.getElementById(`cmidit-${partCounter}`);
            const commit = document.getElementById(`commit-${partCounter}`);
            const processPointInput = document.getElementById(`processPoint-${partCounter}`);
            const totalValueInput = document.getElementById(`totalValue-${partCounter}`);

            const rowTr = document.getElementById(`row-${partCounter}`);
            let isSelecting = false;
            input.addEventListener("input", () => {
                if (isSelecting) return;
                resetRowExcept(partCounter);
            });
            let cacheData = [];
            const apiCache = {};
            let debounceTimer = null;
            let duplicateLock = false;

            function renderSuggest(response) {
                if (duplicateLock) return;
                suggestBox.innerHTML = "";
                suggestBox.classList.add("hidden");

                if (response.success && response.data.length > 0) {
                    cacheData = response.data;
                    document.body.appendChild(suggestBox);
                    const rect = input.getBoundingClientRect();
                    suggestBox.style.position = "absolute";
                    suggestBox.style.left = rect.left + "px";
                    suggestBox.style.top = rect.bottom + window.scrollY + "px";
                    suggestBox.style.minWidth = rect.width + "px";
                    suggestBox.style.maxWidth = "600px";
                    suggestBox.style.zIndex = 99999;
                    response.data.slice(0, 20).forEach(item => {
                        const div = document.createElement("div");
                        div.className = "px-3 py-1 hover:bg-info cursor-pointer text-sm";
                        div.textContent = `${item.PartNum} - ${item.Description}`;
                        div.addEventListener("click", () => handleSelect(item, partCounter));
                        suggestBox.appendChild(div);
                    });

                    suggestBox.classList.remove("hidden");
                } else {
                    cacheData = [];
                }
            }

            input.addEventListener("input", function () {
                clearTimeout(debounceTimer);
                const query = this.value.trim();
                if (duplicateLock) duplicateLock = false;
                debounceTimer = setTimeout(() => {
                    if (query.length < 2) {
                        suggestBox.innerHTML = "";
                        cacheData = [];
                        if (rowTr) {
                            rowTr.dataset.commit = "";
                            updateSelectedCommit();
                        }
                        return;
                    }

                    if (apiCache[query]) {
                        renderSuggest(apiCache[query]);
                        return;
                    }

                    $.ajax({
                        url: "@Url.Action("GetPartMasterUpdated", "DataForms")",
                        type: "GET",
                        data: { data: query, tc: selectedTC, exact: false},
                        success: function (response) {
                            apiCache[query] = response;
                            renderSuggest(response);
                        },
                        error: function () {
                            suggestBox.innerHTML = "";
                            cacheData = [];
                        }
                    });
                }, 300);
            });

            function handleSelect(selected, localCounter) {
                if (!selected) return;
                isSelecting = true;
                const input = document.getElementById(`partNumber-${localCounter}`);
                const descInput = document.getElementById(`description-${localCounter}`);
                const baseValueInput = document.getElementById(`baseValue-${localCounter}`);
                const unitMeasurementInput = document.getElementById(`unit-${localCounter}`);
                const processPointInput = document.getElementById(`processPoint-${localCounter}`);
                const totalValueInput = document.getElementById(`totalValue-${localCounter}`);
                const ftypit = document.getElementById(`ftypit-${localCounter}`);
                const typeit = document.getElementById(`typeit-${localCounter}`);
                const planit = document.getElementById(`planit-${localCounter}`);
                const cmidit = document.getElementById(`cmidit-${localCounter}`);
                const commit = document.getElementById(`commit-${localCounter}`);
                const rowTr = document.getElementById(`row-${localCounter}`);

                if (!input || !descInput || !baseValueInput || !unitMeasurementInput || !processPointInput || !ftypit || !typeit) {
                    console.warn(`⚠️ Missing field(s) on row-${localCounter}`);
                    return;
                }
                const allPartNumbers = Array.from(document.querySelectorAll("[id^='partNumber-']"))
                    .filter(el => el.id !== input.id)
                    .map(el => el.value.trim())
                    .filter(v => v !== "");

                if (allPartNumbers.includes(selected.PartNum.trim())) {
                    duplicateLock = true;
                    suggestBox.innerHTML = "";
                    suggestBox.classList.add("hidden");

                    showDynamicSwal({
                        title: "Duplicate Part Number",
                        text: `Part Number ${selected.PartNum.trim()} already exists!`,
                        icon: "error",
                        confirmText: "OK"
                    }).then(() => resetRow(localCounter));
                    return;
                }
                input.value = selected.PartNum;
                descInput.value = selected?.Description ?? "";
                baseValueInput.value = formatRupiah(selected?.BasePrice ?? 0);
                unitMeasurementInput.value = selected?.Measurement ?? "";
                processPointInput.value = selected?.ProcessPoint?.trim() ? selected.ProcessPoint : "N";
                ftypit.value = selected?.ftypit ?? "";
                typeit.value = selected?.typeit ?? "";
                planit.value = selected?.planit ?? "";
                cmidit.value = selected?.cmidit ?? "";
                commit.value = selected?.commit ?? "";
                if (rowTr) rowTr.dataset.commit = selected?.commit?.toLowerCase() ?? "";
                calculateTotal(localCounter);
                updateSelectedCommit();
                suggestBox.classList.add("hidden");

                function resetRow() {
                    input.value = "";
                    descInput.value = "";
                    baseValueInput.value = "";
                    unitMeasurementInput.value = "";
                    processPointInput.value = "";
                    document.getElementById(`ftypit-${localCounter}`).value = "";
                    document.getElementById(`typeit-${localCounter}`).value = "";
                    document.getElementById(`planit-${localCounter}`).value = "";
                    document.getElementById(`cmidit-${localCounter}`).value = "";
                    document.getElementById(`commit-${localCounter}`).value = "";
                    totalValueInput.value = "";
                    if (rowTr) rowTr.dataset.commit = "";
                    updateSelectedCommit();
                }
                setTimeout(() => {
                    isSelecting = false;
                }, 0);
            }
        }

        function updateSelectedCommit() {
            const allRows = document.querySelectorAll("[id^='row-']");
            let hasCommitX = false;
            allRows.forEach(row => {
                const commit = (row.dataset.commit || "").toLowerCase();
                row.classList.toggle("bg-warning/20", commit === "x");
                if (commit === "x") hasCommitX = true;
            });

            selectedCommit = hasCommitX;
        }

        function calculateTotal(counter) {
            const baseValueInput = document.getElementById(`baseValue-${counter}`);
            const varianceQtyInput = document.getElementById(`varianceQuantity-${counter}`);
            const totalValueInput = document.getElementById(`totalValue-${counter}`);

            if (!baseValueInput || !varianceQtyInput || !totalValueInput) return;

            let rawBase = baseValueInput.value || "0";
            rawBase = rawBase.replace(/[^\d,.-]/g, "");
            rawBase = rawBase.replace(/\./g, "");
            rawBase = rawBase.replace(",", ".");

            const baseValue = parseFloat(rawBase) || 0;
            const qty = parseFloat(varianceQtyInput.value) || 0;
            const total = baseValue * qty;

            totalValueInput.value = formatRupiah(total);
            updateGrandTotal();
        }

        function updateGrandTotal() {
            const rows = document.querySelectorAll("#listOfPartnumber tr");
            let totalQty = 0;
            let totalRupiah = 0;
            const partsData = [];

            rows.forEach(row => {
                const qtyInput = row.querySelector("input[id^='varianceQuantity-']");
                const totalInput = row.querySelector("input[id^='totalValue-']");

                // PIA tidak punya ftypit/typeit/commit per-part → kirim null
                let total = totalInput?.value?.replace(/[^\d,.-]/g, "") || "0";
                total = parseFloat(total.replace(/\./g, "").replace(",", ".")) || 0;

                totalQty += parseFloat(qtyInput?.value) || 0;
                totalRupiah += total;

                partsData.push({
                    value: total,
                    code: null,   // PIA tidak filter by code
                    tcType: null,   // PIA tidak filter by tcType
                    commit: false
                });
            });

            document.getElementById("totalQty").textContent = totalQty.toFixed(2);
            document.getElementById("totalRupiah").textContent = formatRupiah(totalRupiah);

            // ✅ Ganti checkPiaApprovalChain dengan fungsi generik
         checkApprovalChain("PIA", partsData, {
                documentCode: document.getElementById("piaCodeDropdown")?.value || ""
            });
        }

        function normalizeExcelText(value) {
            return (value === null || value === undefined ? "" : value.toString())
                .trim()
                .toLowerCase()
                .replace(/[^a-z0-9]+/g, "");
        }

        function getExcelCellValue(row, index) {
            if (!row || index === null || index === undefined || index < 0) return "";
            const value = row[index];
            return value === null || value === undefined ? "" : value.toString().trim();
        }

        function getExcelColumnMap(headers) {
            const normalizedHeaders = (headers || []).map(normalizeExcelText);
            const findIndex = (aliases, fallbackIndex) => {
                const foundIndex = normalizedHeaders.findIndex(header => aliases.includes(header));
                return foundIndex >= 0 ? foundIndex : fallbackIndex;
            };

            return {
                type: findIndex(["type", "piatype"], -1),
                facility: findIndex(["facility", "plant", "location"], -1),
                manager: findIndex(["manager", "supervisor", "initiator"], -1),
                tcc: findIndex(["tcc", "tccompanion", "tc", "companiontc"], -1),
                partNumber: findIndex(["pn", "partnumber", "partno", "part", "partnumberpn"], -1),
                physicalQty: findIndex(["physicalquantity", "physicalqty"], -1),
                systemQty: findIndex(["systemquantity", "systemqty"], -1),
                quantity: findIndex(["quantity", "qty"], -1),
                reasonCode: findIndex(["reasoncode", "pia code", "piacode", "scrapcode"], -1),
                wc: findIndex(["wc", "workcenter", "workcentre"], -1),
                remarks: findIndex(["remarks", "remark", "notes"], -1),
                kpk: findIndex(["kpk", "employeekpk", "managerkpk"], -1)
            };
        }

        function setSelectValue(selectElement, rawValue) {
            if (!selectElement) return false;

            const value = (rawValue === null || rawValue === undefined ? "" : rawValue.toString()).trim();
            if (!value) {
                selectElement.value = "";
                return true;
            }

            const normalizedValue = normalizeExcelText(value);
            const matchingOption = Array.from(selectElement.options || []).find(function (option) {
                return normalizeExcelText(option.value) === normalizedValue || normalizeExcelText(option.textContent) === normalizedValue;
            });

            if (matchingOption) {
                selectElement.value = matchingOption.value;
                return true;
            }

            selectElement.add(new Option(value, value));
            selectElement.value = value;
            return true;
        }

        /**
         * Menunggu dropdown selesai dimuat (options lebih dari 1) lalu set nilainya.
         * Berguna untuk dropdown yang diisi secara async (AJAX).
         */
        function setSelectValueWhenReady(selectElement, rawValue, timeoutMs = 8000) {
            return new Promise(function (resolve) {
                if (!selectElement || !rawValue || rawValue.toString().trim() === "") {
                    resolve(false);
                    return;
                }

                const deadline = Date.now() + timeoutMs;

                function trySet() {
                    // Dropdown siap jika sudah ada opsi lebih dari 1 (lebih dari placeholder)
                    // DAN tidak mengandung teks "Loading..."
                    const hasOptions = selectElement.options.length > 1;
                    const isLoading = Array.from(selectElement.options).some(o => /loading/i.test(o.textContent));

                    if (hasOptions && !isLoading) {
                        const result = setSelectValue(selectElement, rawValue);
                        resolve(result);
                        return;
                    }

                    if (Date.now() >= deadline) {
                        // Timeout: set anyway sebagai fallback
                        const result = setSelectValue(selectElement, rawValue);
                        resolve(result);
                        return;
                    }

                    setTimeout(trySet, 120);
                }

                trySet();
            });
        }

        /**
         * Populate dropdown async per-row (reasonCode / wc) dan tunggu sampai selesai.
         * Mengembalikan Promise yang resolve saat opsi berhasil di-set.
         */
        function populateDetailDropdownAndSet(populateFn, rowIndex, facility, tc, selectId, valueToSet, timeoutMs = 8000) {
            return new Promise(function (resolve) {
                // Panggil fungsi load AJAX-nya dulu
                populateFn(rowIndex, facility, tc);

                // Lalu tunggu dropdown terisi dan set nilainya
                const selectEl = document.getElementById(selectId);
                if (!selectEl) { resolve(false); return; }

                setSelectValueWhenReady(selectEl, valueToSet, timeoutMs).then(resolve);
            });
        }

        function setPreviewImportBusy(isBusy, message) {
            const dropZone = document.getElementById("previewExcelDropZone");
            const fileInput = document.getElementById("excelFile");

            if (dropZone) {
                dropZone.classList.toggle("opacity-60", isBusy);
                dropZone.classList.toggle("cursor-wait", isBusy);
                dropZone.style.pointerEvents = isBusy ? "none" : "auto";

                // Tampilkan loading spinner di dalam drop zone selama proses berlangsung
                const existingOverlay = dropZone.querySelector(".import-loading-overlay");
                if (isBusy) {
                    if (!existingOverlay) {
                        const overlay = document.createElement("div");
                        overlay.className = "import-loading-overlay flex flex-col items-center gap-2 text-info text-sm";
                        overlay.innerHTML =
                            '<div class="animate-spin inline-block size-7 border-[3px] border-l-transparent border-info rounded-full"></div>' +
                            '<span class="import-loading-msg font-medium">' + (message || "Membaca file Excel...") + '</span>';
                        dropZone.innerHTML = "";
                        dropZone.appendChild(overlay);
                    } else if (message) {
                        const msgEl = existingOverlay.querySelector(".import-loading-msg");
                        if (msgEl) msgEl.textContent = message;
                    }
                } else {
                    // Kembalikan isi drop zone ke tampilan semula
                    dropZone.innerHTML =
                        '<div>' +
                        '<p class="text-sm font-medium text-black dark:text-white/80">Drop or click file here to fill the table</p>' +
                        '<p class="text-xs text-muted">Supports: .xlsx, .xls</p>' +
                        '</div>';
                }
            }

            if (fileInput) {
                fileInput.disabled = isBusy;
            }
        }

        function clearImportedDetailRows() {
            const partList = document.getElementById("listOfPartnumber");
            if (partList) {
                partList.innerHTML = "";
            }

            partCounter = 0;
            selectedCommit = false;
            specialRemarksCache = {};

            const totalQtyEl = document.getElementById("totalQty");
            const totalRupiahEl = document.getElementById("totalRupiah");

            if (totalQtyEl) totalQtyEl.textContent = "0.00";
            if (totalRupiahEl) totalRupiahEl.textContent = formatRupiah(0);

            updateGrandTotal();
            updateSelectedCommit();
        }

        function getEmployeeByKeyword(keyword) {
            return new Promise(function (resolve) {
                $.ajax({
                    url: "@Url.Action("GetEmployeeByNameOrKpk","DataForms")",
                    type: "GET",
                    data: { keyword: keyword },
                    success: function (response) {
                        if (response && response.success && response.data) {
                            if (Array.isArray(response.data) && response.data.length > 0) {
                                resolve(response.data[0]);
                                return;
                            }

                            if (response.data.name && response.data.kpk) {
                                resolve(response.data);
                                return;
                            }
                        }

                        resolve(null);
                    },
                    error: function () {
                        resolve(null);
                    }
                });
            });
        }

        function getPartMasterByNumber(partNumber, tcValue) {
            return new Promise(function (resolve) {
                $.ajax({
                    url: "@Url.Action("GetPartMasterUpdated","DataForms")",
                    type: "GET",
                    data: { data: partNumber, tc: tcValue, exact: true },
                    success: function (response) {
                        resolve(response || null);
                    },
                    error: function () {
                        resolve(null);
                    }
                });
            });
        }

        function getFirstNonEmpty(values) {
            for (const value of values) {
                if ((value || "").toString().trim()) {
                    return value.toString().trim();
                }
            }
            return "";
        }

        function normalizeTcCompanionValue(value) {
            const normalized = (value === null || value === undefined ? "" : value.toString()).trim();
            if (!normalized) return "";
            if (normalized === "0") return "";
            if (normalized.toLowerCase() === "not required") return "";
            return normalized;
        }

        function normalizeTcCompanionSelect(selectElement) {
            if (!selectElement) return;

            Array.from(selectElement.options || []).forEach(function (option) {
                if ((option.value || "").trim() === "0") {
                    option.remove();
                }
            });

            selectElement.value = normalizeTcCompanionValue(selectElement.value);
        }

        function updateImportProgress(message) {
            setPreviewImportBusy(true, message);
        }

        async function handlePreviewExcelImport(file) {
            if (!file) return;

            setPreviewImportBusy(true, "Reading Excel File...");
            Swal.fire({
                title: "Filling the form...",
                html: "<span id='importProgressMsg'>Reading Excel File...</span>",
                allowOutsideClick: false,
                didOpen: function () {
                    Swal.showLoading();
                }
            });

            function updateSwalProgress(msg) {
                setPreviewImportBusy(true, msg);
                try {
                    const el = document.getElementById("importProgressMsg");
                    if (el) el.textContent = msg;
                } catch(e) { /* ignore */ }
            }

            try {
                updateSwalProgress("Reading Data From Excel File...");
                const workbook = XLSX.read(await file.arrayBuffer(), { type: "array" });
                const sheetName = workbook.SheetNames[0];
                if (!sheetName) {
                    throw new Error("The Excel file does not contain any sheet.");
                }

                const worksheet = workbook.Sheets[sheetName];
                const rows = XLSX.utils.sheet_to_json(worksheet, { header: 1, defval: "" });
                const dataRows = rows.filter(function (row) {
                    return Array.isArray(row) && row.some(function (cell) {
                        return cell !== null && cell !== undefined && cell.toString().trim() !== "";
                    });
                });

                if (dataRows.length < 2) {
                    throw new Error("The Excel template must contain a header row and at least one data row.");
                }

                const columnMap = getExcelColumnMap(dataRows[0]);
                const firstDataRow = dataRows[1];
                const previewTypeDropdown = document.getElementById("previewTypeOfPiaDropdown");
                const previewFacilityDropdown = document.getElementById("previewFacilityDropdown");
                const previewManagerNameInput = document.getElementById("previewSupervisorInitiatorName");
                const previewManagerKpkInput = document.getElementById("previewSupervisorInitiatorKpk");
                const previewTccDropdown = document.getElementById("previewTcCompanionDropdown");

                const existingPreviewType = (previewTypeDropdown?.value || "").trim();
                const existingPreviewFacility = (previewFacilityDropdown?.value || "").trim();
                const existingPreviewManagerName = (previewManagerNameInput?.value || "").trim();
                const existingPreviewManagerKpk = (previewManagerKpkInput?.value || "").trim();
                const existingPreviewTcc = (previewTccDropdown?.value || "").trim();

                const hasHeaderType = columnMap.type >= 0;
                const hasHeaderFacility = columnMap.facility >= 0;
                const hasHeaderManager = columnMap.manager >= 0 || columnMap.kpk >= 0;
                const hasLegacyQuantity = columnMap.quantity >= 0;

                const previewTypeValue = getFirstNonEmpty([
                    getExcelCellValue(firstDataRow, columnMap.type),
                    getExcelCellValue(dataRows[0], columnMap.type),
                    existingPreviewType
                ]);
                const previewFacilityValue = getFirstNonEmpty([
                    getExcelCellValue(firstDataRow, columnMap.facility),
                    getExcelCellValue(dataRows[0], columnMap.facility),
                    existingPreviewFacility
                ]);
                const previewManagerValue = getFirstNonEmpty([
                    getExcelCellValue(firstDataRow, columnMap.manager),
                    getExcelCellValue(firstDataRow, columnMap.kpk),
                    getExcelCellValue(dataRows[0], columnMap.manager),
                    getExcelCellValue(dataRows[0], columnMap.kpk),
                    existingPreviewManagerName,
                    existingPreviewManagerKpk
                ]);
                const previewTccValue = normalizeTcCompanionValue(getFirstNonEmpty([
                    getExcelCellValue(firstDataRow, columnMap.tcc),
                    getExcelCellValue(dataRows[0], columnMap.tcc),
                    existingPreviewTcc
                ]));

                if (!previewTypeValue && !existingPreviewType) {
                    throw new Error("Type is required in the Excel file or must already be selected on the page.");
                }

                if (!previewFacilityValue && !existingPreviewFacility) {
                    throw new Error("Facility is required in the Excel file or must already be selected on the page.");
                }

                clearImportedDetailRows();

                setSelectValue(previewTypeDropdown, previewTypeValue);
                if (previewTypeDropdown) {
                    $(previewTypeDropdown).trigger("change");
                }

                setSelectValue(previewFacilityDropdown, previewFacilityValue);
                if (previewFacilityDropdown) {
                    $(previewFacilityDropdown).trigger("change");
                }

                updateSwalProgress("Search manager initiator...");
                const resolvedManager = await getEmployeeByKeyword(previewManagerValue);
                if (resolvedManager) {
                    previewManagerNameInput.value = resolvedManager.name || previewManagerValue;
                    previewManagerKpkInput.value = resolvedManager.kpk || previewManagerValue;
                } else {
                    previewManagerNameInput.value = previewManagerValue;
                    previewManagerKpkInput.value = previewManagerValue;
                }

                normalizeTcCompanionSelect(previewTccDropdown);
                setSelectValue(previewTccDropdown, previewTccValue);

                evaluateAutoShowDetailFormFromPreview();

                const importedType = (previewTypeDropdown?.value || previewTypeValue || existingPreviewType).trim();
                const selectedTcFromPage = (document.getElementById("tcDropdown")?.value || "").trim();
                selectedTC = getFirstNonEmpty([
                    typeToTcMap[importedType],
                    selectedTcFromPage
                ]);

                if (!selectedTC) {
                    updateSwalProgress("Main TC tidak ditemukan dari Excel. Melanjutkan import tanpa TC utama...");
                    console.warn("[PIA Import] Main TC could not be resolved from imported Type; continuing with null TC.");
                    selectedTC = null;
                }

                const headerReasonCode = getFirstNonEmpty([
                    getExcelCellValue(firstDataRow, columnMap.reasonCode),
                    getExcelCellValue(dataRows[0], columnMap.reasonCode)
                ]);
                const headerWc = getFirstNonEmpty([
                    getExcelCellValue(firstDataRow, columnMap.wc),
                    getExcelCellValue(dataRows[0], columnMap.wc)
                ]);

                selectedPiaCode = headerReasonCode || selectedPiaCode;
                selectedPiaCodeString = headerReasonCode || selectedPiaCodeString;

                const legacyPiaCodeDropdown = document.getElementById("piaCodeDropdown");
                const legacyWcDropdown = document.getElementById("wcDropdown");

                if (legacyPiaCodeDropdown && headerReasonCode) {
                    setSelectValue(legacyPiaCodeDropdown, headerReasonCode);
                    $(legacyPiaCodeDropdown).trigger("change");
                }

                if (legacyWcDropdown && headerWc) {
                    setSelectValue(legacyWcDropdown, headerWc);
                }

                const existingParts = Array.from(document.querySelectorAll("[id^='partNumber-']"))
                    .map(function (element) { return (element.value || "").trim(); })
                    .filter(function (value) { return value !== ""; });

                const duplicateParts = [];
                const missingMasters = [];
                const missingRemarks = [];
                const importedRows = [];

                for (let rowIndex = 1; rowIndex < dataRows.length; rowIndex++) {
                    const row = dataRows[rowIndex];
                    if (!row || row.length === 0) continue;

                    const partNumber = getExcelCellValue(row, columnMap.partNumber >= 0 ? columnMap.partNumber : 0);
                    if (!partNumber) continue;

                    if (existingParts.includes(partNumber)) {
                        duplicateParts.push(partNumber);
                        continue;
                    }

                    existingParts.push(partNumber);
                    importedRows.push(row);
                }

                if (importedRows.length === 0) {
                    throw new Error("No valid part numbers were found in the imported Excel file.");
                }

                const managerForRows = resolvedManager || {
                    name: previewManagerValue,
                    kpk: previewManagerValue
                };

                const importMode = hasHeaderType || hasHeaderFacility || hasHeaderManager || hasLegacyQuantity ? "mixed" : "legacy";

                updateSwalProgress("Mengisi detail baris dari Excel...");
                for (let index = 0; index < importedRows.length; index++) {
                    const row = importedRows[index];
                    const targetRow = index + 1;

                    createPartCard._skipAutoPopulate = true;
                    while (partCounter < targetRow) {
                        createPartCard(selectedTC);
                    }
                    createPartCard._skipAutoPopulate = false;

                    updateSwalProgress("Fill row " + targetRow + " from " + importedRows.length + "...");

                    const partNumber = getExcelCellValue(row, columnMap.partNumber >= 0 ? columnMap.partNumber : 0);
                    const physicalQty = importMode === "legacy"
                        ? (getExcelCellValue(row, columnMap.quantity) || "0")
                        : (getExcelCellValue(row, columnMap.physicalQty) || "0");
                    const systemQty = importMode === "legacy"
                        ? (getExcelCellValue(row, columnMap.systemQty) || "0")
                        : (getExcelCellValue(row, columnMap.systemQty) || "0");
                    const reasonCode = getExcelCellValue(row, columnMap.reasonCode) || headerReasonCode || (document.getElementById("piaCodeDropdown")?.value || "");
                    const wcValue = getExcelCellValue(row, columnMap.wc) || headerWc || (document.getElementById("wcDropdown")?.value || "");
                    const remarksValue = getExcelCellValue(row, columnMap.remarks);
                    const rowManagerValue = getFirstNonEmpty([
                        getExcelCellValue(row, columnMap.manager),
                        getExcelCellValue(row, columnMap.kpk),
                        previewManagerValue
                    ]);

                    const partInput = document.getElementById(`partNumber-${targetRow}`);
                    const physicalQtyInput = document.getElementById(`physicalQuantity-${targetRow}`);
                    const systemQtyInput = document.getElementById(`systemQuantity-${targetRow}`);
                    const varianceQtyInput = document.getElementById(`varianceQuantity-${targetRow}`);
                    const descInput = document.getElementById(`description-${targetRow}`);
                    const baseValueInput = document.getElementById(`baseValue-${targetRow}`);
                    const unitInput = document.getElementById(`unit-${targetRow}`);
                    const processPointInput = document.getElementById(`processPoint-${targetRow}`);
                    const leaderInput = document.getElementById(`leader-${targetRow}`);
                    const leaderKpkInput = document.getElementById(`leaderKpk-${targetRow}`);
                    const ftypitInput = document.getElementById(`ftypit-${targetRow}`);
                    const typeitInput = document.getElementById(`typeit-${targetRow}`);
                    const planitInput = document.getElementById(`planit-${targetRow}`);
                    const commitInput = document.getElementById(`commit-${targetRow}`);
                    const cmiditInput = document.getElementById(`cmidit-${targetRow}`);
                    const reasonCodeSelect = document.getElementById(`reasonCode-${targetRow}`);
                    const wcSelect = document.getElementById(`wc-${targetRow}`);
                    const remarksInput = document.getElementById(`remarks-${targetRow}`);

                    if (partInput) partInput.value = partNumber;
                    if (physicalQtyInput) physicalQtyInput.value = physicalQty;
                    if (systemQtyInput) systemQtyInput.value = systemQty;
                    if (varianceQtyInput) varianceQtyInput.value = (parseFloat(physicalQty) || 0) - (parseFloat(systemQty) || 0);

                    const resolvedRowManager = rowManagerValue ? await getEmployeeByKeyword(rowManagerValue) : null;
                    if (leaderInput) leaderInput.value = (resolvedRowManager?.name || managerForRows.name || rowManagerValue || previewManagerValue);
                    if (leaderKpkInput) leaderKpkInput.value = (resolvedRowManager?.kpk || managerForRows.kpk || rowManagerValue || previewManagerValue);

                    // Populate reason code dropdown (AJAX) dan tunggu sampai nilai ter-set
                    const importFacility = previewFacilityValue || existingPreviewFacility;
                    if (reasonCode) {
                        if (!selectedTC) {
                            setSelectValue(reasonCodeSelect, reasonCode);
                        } else {
                        await populateDetailDropdownAndSet(
                            function (rowIdx, fac, tc) { populateDetailReasonCodeDropdown(rowIdx, fac, tc); },
                            targetRow, importFacility, selectedTC,
                            "reasonCode-" + targetRow, reasonCode
                        );
                        }
                    } else if (reasonCodeSelect) {
                        setSelectValue(reasonCodeSelect, reasonCode);
                    }

                    // Populate WC dropdown (AJAX) dan tunggu sampai nilai ter-set
                    if (wcValue) {
                        if (!selectedTC) {
                            setSelectValue(wcSelect, wcValue);
                        } else {
                        await populateDetailDropdownAndSet(
                            function (rowIdx, fac) { populateDetailWcDropdown(rowIdx, fac); },
                            targetRow, importFacility, null,
                            "wc-" + targetRow, wcValue
                        );
                        }
                    } else if (wcSelect) {
                        setSelectValue(wcSelect, wcValue);
                    }

                    filterRemarksByPiaCode(targetRow, reasonCode || selectedPiaCode);

                    if (remarksInput) {
                        remarksInput.value = remarksValue;
                    }

                    const masterResponse = await getPartMasterByNumber(partNumber, selectedTC);
                    if (masterResponse && masterResponse.success && Array.isArray(masterResponse.data) && masterResponse.data.length > 0) {
                        const selectedPart = masterResponse.data[0];

                        if (descInput) descInput.value = selectedPart.Description || "";
                        if (baseValueInput) baseValueInput.value = formatRupiah(selectedPart.BasePrice);
                        if (unitInput) unitInput.value = selectedPart.Measurement || "";
                        if (ftypitInput) ftypitInput.value = selectedPart.ftypit || "";
                        if (typeitInput) typeitInput.value = selectedPart.typeit || "";
                        if (planitInput) planitInput.value = selectedPart.planit || "";
                        if (cmiditInput) cmiditInput.value = selectedPart.cmidit || "";
                        if (commitInput) commitInput.value = selectedPart.commit || "";
                        if (processPointInput) processPointInput.value = selectedPart.ProcessPoint?.trim() || "N";

                        const isCommitX = (selectedPart?.commit || "").toString().toLowerCase() === "x";
                        const rowElement = document.getElementById(`row-${targetRow}`);
                        if (rowElement) {
                            rowElement.classList.toggle("bg-warning/20", isCommitX);
                        }
                        if (isCommitX) {
                            selectedCommit = true;
                        }

                        calculateTotal(targetRow);
                    } else {
                        missingMasters.push(partNumber);
                    }

                    validateQtyInput(physicalQtyInput, targetRow);
                    calculateTotal(targetRow);
                }

                for (let i = 1; i <= partCounter; i++) {
                    validatePartCard(i, selectedTC == "22");
                }

                updateGrandTotal();
                updateSelectedCommit();

                setPreviewImportBusy(false);

                let htmlMessage = `<p>Success fill <b>${importedRows.length}</b> row from Excel.</p>`;

                if (duplicateParts.length > 0) {
                    htmlMessage += `<p><b>skipping duplicate part:</b><br>${duplicateParts.join(", ")}</p>`;
                }

                if (missingMasters.length > 0) {
                    htmlMessage += `<p><b>Part master can't find:</b><br>${missingMasters.join(", ")}</p>`;
                }

                Swal.fire({
                    icon: duplicateParts.length > 0 || missingMasters.length > 0 ? "warning" : "success",
                    title: duplicateParts.length > 0 || missingMasters.length > 0 ? "Import Selesai (Periksa Detail)" : "Automatic fill form success",
                    html: htmlMessage
                });
            } catch (error) {
                setPreviewImportBusy(false);
                Swal.fire({
                    icon: "error",
                    title: "Import Gagal",
                    text: error?.message || "Cannot fill form from excel."
                });
            } finally {
                setPreviewImportBusy(false);
                document.getElementById("excelFile").value = "";
            }
        }

