        function reindexRows() {
            const rows = document.querySelectorAll("#listOfPartnumber tr");
            rows.forEach((row, index) => {
                const newIndex = index + 1;
                row.id = `row-${newIndex}`;
                const numberCell = row.querySelector("td .flex span");
                if (numberCell) numberCell.textContent = newIndex;
                const trash = row.querySelector("td .flex i");
                if (trash) trash.setAttribute("data-row", newIndex);
                const elements = row.querySelectorAll("input, select, datalist");
                elements.forEach(el => {
                    const oldId = el.id;
                    if (oldId) el.id = oldId.replace(/\d+$/, newIndex);

                    const oldName = el.name;
                    if (oldName) el.name = oldName.replace(/\d+$/, newIndex);
                });
            });

            partCounter = rows.length;
