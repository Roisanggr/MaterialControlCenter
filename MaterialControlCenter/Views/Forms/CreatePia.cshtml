        function showSpecialCodeToast(message, type = "error") {
            const toastHtml = `
                <div class="px-4 py-2 rounded text-sm font-medium
                    ${type === "error" ? "bg-danger border danger" : ""}
                    ${type === "success" ? "bg-success border-success" : ""}
                ">
                    ${message}
                </div>
            `;

            $("#toastContainerrSpecialCodeRemarks")
                .html(toastHtml)
                .fadeIn(200);

            setTimeout(() => {
                $("#toastContainerrSpecialCodeRemarks").fadeOut(300, function () {
                    $(this).empty();
                });
            }, 3000);
        }

        function validateSpecialCodeRemarks() {

            if (!piaCodesWithNotes.includes(selectedPiaCodeString)) {
                return { valid: true };
            }

            const remarks = localStorage.getItem("specialCodeRemarks");

            if (!remarks || remarks.trim() === "") {
                return {
                    valid: false,
                    message: "Special Remarks Notes must be filled in for the selected PIA code."

                };
            }

            return { valid: true };
        }

        function getPiaTypeValue(typeLabel) {
            const normalizedType = (typeLabel || "").trim().toLowerCase();

            if (normalizedType === "subcont") {
                return 2;
            }

            if (normalizedType === "wip" || normalizedType === "reguler") {
                return 1;
            }

            return 1;
        }

    </script>
}
