        function buildPiaPayload() {
            const createdByKpkValue = (typeof kpk !== "undefined" ? kpk : "") || "";
            const createdByNameValue = (typeof userName !== "undefined" ? userName : "") || "";
            const typeLabel = document.getElementById("typeOfPiaDropdown")?.options[document.getElementById("typeOfPiaDropdown")?.selectedIndex]?.text || "Reguler";
            const typeValue = getPiaTypeValue(typeLabel);

            // Header now only contains Type, Facility, TC, TcCompanion
            const headerData = {
                Type        : typeValue,
                TypeLabel   : typeLabel,
                Facility    : document.getElementById("facilityInitiator")?.value || null,
                TC          : document.getElementById("tcDropdown")?.value || null,
                TcCompanion : document.getElementById("tcCompanionDropdown")?.value || null,
                CreatedByKpk  : createdByKpkValue,
                CreatedByName : createdByNameValue || null
            };
            const rows = document.querySelectorAll("#listOfPartnumber tr");
            const detailList = [];
            let partIdSequence = 1;  // Sequential part_id counter

            rows.forEach((row) => {
                const partNum = row.querySelector('input[id^="partNumber-"]')?.value?.trim() || null;
                if (!partNum) return;

                let rawBase = row.querySelector('input[id^="baseValue-"]')?.value || "0";
                rawBase     = parseFloat(rawBase.replace(/[^\d,.-]/g, "").replace(/\./g, "").replace(",", ".")) || 0;

                let rawTotal = row.querySelector('input[id^="totalValue-"]')?.value || "0";
                rawTotal     = parseFloat(rawTotal.replace(/[^\d,.-]/g, "").replace(/\./g, "").replace(",", ".")) || 0;

                // Get pia_code_id from reasonCode dropdown value (should be the ID)
                const piaCodeIdValue = row.querySelector('select[id^="reasonCode-"]')?.value || null;
                const piaCodeId = piaCodeIdValue ? parseInt(piaCodeIdValue) : null;

                detailList.push({
                    header_id        : 0,
                    part_id          : partIdSequence++,  // Auto-increment: 1, 2, 3, ...
                    part_number      : partNum,
                    part_description : row.querySelector('input[id^="description-"]')?.value || null,
                    part_proccess    : row.querySelector('input[id^="processPoint-"]')?.value || null,
                    ftypit           : row.querySelector('input[id^="ftypit-"]')?.value || null,
                    typeit           : row.querySelector('input[id^="typeit-"]')?.value || null,
                    planit           : parseInt(row.querySelector('input[id^="planit-"]')?.value) || 0,
                    cmidit           : parseInt(row.querySelector('input[id^="cmidit-"]')?.value) || 0,
                    commit_qty       : parseInt(row.querySelector('input[id^="commit-"]')?.value) || 0,
                    measit           : parseInt(row.querySelector('input[id^="unit-"]')?.value) || 0,
                    baspit           : rawBase,
                    physical_qty     : parseFloat(row.querySelector('input[id^="physicalQuantity-"]')?.value) || 0,
                    system_qty       : parseFloat(row.querySelector('input[id^="systemQuantity-"]')?.value)   || 0,
                    variance_qty     : parseFloat(row.querySelector('input[id^="varianceQuantity-"]')?.value) || 0,
                    total_value      : rawTotal,
                    pia_code_id      : piaCodeId,        // Changed from pia_code (string) to pia_code_id (int)
                    wc               : row.querySelector('select[id^="wc-"]')?.value || null,
                    remarks          : row.querySelector('input[id^="remarks-"]')?.value?.trim() || null,
                    LeaderKPK        : row.querySelector('input[id^="leaderKpk-"]')?.value || null,
                    status           : "active"
                });
            });

            return {
                Header           : headerData,      // ← "Header" bukan "Master"
                Details          : detailList,      // ← "Details" bukan "Parts"
                detectedKPKGlobal: typeof detectedKPKGlobal !== "undefined" ? detectedKPKGlobal : []
            };
        }

        async function generatePiaPDFBase64() {
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF({
                unit: "mm",
                format: "a4",
                compress: true
            });

            const payload = buildPiaPayload();
            const header = payload.Header;
            const details = payload.Details;
            const totalQty = details.reduce((sum, d) => sum + (parseFloat(d.physical_qty) || 0), 0);
            const totalValue = details.reduce((sum, d) => sum + (parseFloat(d.total_value) || 0), 0);
            const logoUrl = '@Url.Content("~/assets/images/mattel-logo.png")';
            const logoImg = new Image();
            logoImg.src = logoUrl;
            await new Promise(resolve => (logoImg.onload = resolve));

            const masterEntries = [
                ["Facility", (header.Facility || "-").toString()],
                ["TC", (header.TC || "-").toString()],
                ["TC Companion", (header.TcCompanion || "N/A").toString()],
                ["Type", (header.TypeLabel || header.Type || "-").toString()]
            ];

            const headerFn = (doc, pageNumber, totalPages) => {
                const pageWidth = doc.internal.pageSize.getWidth();
                const logoMaxWidth = 8;
                const logoAspect = logoImg.width / logoImg.height;
                const logoWidth = logoMaxWidth;
                const logoHeight = logoWidth / logoAspect;
                const logoX = 14;
                const logoY = 8;
                doc.addImage(logoImg, "JPEG", logoX, logoY, logoWidth, logoHeight, '', 'FAST');

                doc.setFontSize(14);
                doc.setFont("helvetica", "bold");
                doc.setTextColor(0, 51, 102);
                const title = "PIA NOTICE";
                const textWidth = doc.getTextWidth(title);
                const textY = logoY + logoHeight / 2 + 3;
                doc.text(title, (pageWidth - textWidth) / 2, textY);
                const lineY = logoY + logoHeight + 4;
                doc.setDrawColor(0, 51, 102);
                doc.setLineWidth(0.3);
                doc.line(14, lineY, 196, lineY);

                doc.setFontSize(9);
                doc.setFont("helvetica", "normal");
                doc.setTextColor(0, 0, 0);

                let leftY = lineY + 7;
                let rightY = lineY + 7;
                const leftX = 14;
                const rightX = 110;

                for (let i = 0; i < 4; i++) {
                    const [key, value] = masterEntries[i];
                    doc.text(`${key}:`, leftX, leftY);
                    doc.text(value, leftX + 28, leftY);
                    leftY += 5;
                }

                for (let i = 4; i < masterEntries.length; i++) {
                    const [key, value] = masterEntries[i];
                    doc.text(`${key}:`, rightX, rightY);
                    doc.text(value, rightX + 28, rightY);
                    rightY += 5;
                }

                leftY += 3;
                doc.setFont("helvetica", "bold");
                doc.text("Total Qty:", leftX, leftY);
                doc.setFont("helvetica", "normal");
                doc.text((totalQty || 0).toLocaleString(), leftX + 28, leftY);

                rightY += 3;
                doc.setFont("helvetica", "bold");
                doc.text("Total Value:", rightX, rightY);
                doc.setFont("helvetica", "normal");
                doc.text(formatRupiah(totalValue), rightX + 28, rightY);

                const pageHeight = doc.internal.pageSize.height;
                doc.setFontSize(8);
                doc.setTextColor(100);
                doc.text(`Page ${pageNumber} of ${totalPages}`, pageWidth - 30, pageHeight - 8);
            };

            const MAX_ROWS = 200;
            const tableData = (details || [])
                .slice(0, MAX_ROWS)
                .map(d => [
                    (d.part_number || "-").toString(),
                    (d.part_description || "-").toString(),
                    (d.physical_qty || 0).toString(),
                    (d.system_qty || 0).toString(),
                    (d.variance_qty || 0).toString(),
                    ((d.total_value || 0).toFixed(2)).toString(),
                    (d.part_proccess || "-").toString(),
                    "N/A",
                    "-"
                ]);

            doc.autoTable({
                startY: 65,
                margin: { top: 65 },
                head: [["Part Number", "Description", "Physical Qty", "System Qty", "Variance Qty", "Value", "Process Point", "Leader KPK", "Remarks"]],
                body: tableData,
                theme: "grid",
                styles: { fontSize: 8, cellPadding: 1, lineWidth: 0.1 },
                headStyles: {
                    fillColor: [0, 51, 102],
                    textColor: 255,
                    fontStyle: "bold"
                },
                didDrawPage: (data) => {
                    const pageCount = doc.internal.getNumberOfPages();
                    headerFn(doc, data.pageNumber, pageCount);
                }
            });
            const pdfBase64 = doc.output("datauristring", { compress: true });
            return pdfBase64;
        }

        function insertPia(payload) {
            return fetch('@Url.Action("InsertPiaAsync", "DataForms")', {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify(payload)
            })
            .then(async res => {
                const data = await res.json();
                if (!res.ok) {
                    const serverMsg = data.Error || ("Server error: HTTP " + res.status);
                    const err = new Error(serverMsg);
                    err.isServerError = true;
                    throw err;
                }
                return data;
            });
        }

