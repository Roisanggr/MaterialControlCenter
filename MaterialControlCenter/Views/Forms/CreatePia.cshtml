                });

                if (!result.isConfirmed) return;

                const submitBtn = document.getElementById("submitBtnCreatePia");
                submitBtn.disabled = true;
                submitBtn.style.opacity = "0.6";

                const payload = buildPiaPayload();

                // ── DEBUG: log payload ──
