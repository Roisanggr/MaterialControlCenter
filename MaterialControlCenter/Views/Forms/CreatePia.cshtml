        function validatePartCard(partCounter, showSpecialFields) {
            const rowTr = document.getElementById(`row-${partCounter}`);
            let isValid = true;

            const fields = [
                `partNumber-${partCounter}`,
                `description-${partCounter}`,
                `unit-${partCounter}`,
                `processPoint-${partCounter}`,
                `baseValue-${partCounter}`,
                `physicalQuantity-${partCounter}`,
                `systemQuantity-${partCounter}`,
