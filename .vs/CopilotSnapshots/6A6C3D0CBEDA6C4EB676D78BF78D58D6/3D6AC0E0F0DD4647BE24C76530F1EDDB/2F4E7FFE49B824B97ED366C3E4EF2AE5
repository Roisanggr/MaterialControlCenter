```

**After**:
```csharp
if (roleName.Contains("manager") && !roleName.Contains("material"))
{
    // ── CONDITIONAL LOGIC: Different for PIA vs SCRAP/TPR ──
    if (string.Equals(application, "PIA", StringComparison.OrdinalIgnoreCase))
    {
        // PIA: Manager adalah Supervisor dari Supervisor yang dipilih user
        // initiatorKpk sekarang adalah supervisor KPK yang dipilih user di header form
        // Cari supervisor dari supervisor ini
        var supervisorEmployee = supChain.ElementAtOrDefault(0);  // Index 0 = supervisor yang dipilih user
        if (supervisorEmployee != null && !string.IsNullOrEmpty(supervisorEmployee.Supervisor))
        {
            // Cari supervisor dari supervisor tersebut (= Manager)
            var managerEmployee = dbSSO.GetUserByKpkSSO(supervisorEmployee.Supervisor);
            if (managerEmployee != null)
            {
                resolvedKpks.Add(managerEmployee.Kpk);
                resolvedNames.Add(managerEmployee.Name ?? managerEmployee.Kpk);
                Debug.Print($"[GetApprovalChain] PIA Step 1 Manager (Supervisor's Supervisor): " +
                    $"SupervisorKpk={supervisorEmployee.Kpk}, ManagerKpk={managerEmployee.Kpk}");
            }
        }
    }
    else
    {
        // SCRAP/TPR: Manager adalah supervisor chain dari user yang login (initiator)
        // initiatorKpk adalah user KPK yang login, bukan supervisor yang dipilih
        var mgr = supChain.ElementAtOrDefault(1);
        if (mgr != null)
        {
            resolvedKpks.Add(mgr.Kpk);
            resolvedNames.Add(mgr.Name ?? mgr.Kpk);
            Debug.Print($"[GetApprovalChain] {application} Step 1 Manager: ManagerKpk={mgr.Kpk}");
        }
    }
}
```

**Key Changes**:
- Conditional check: `if (application == "PIA")`
- **PIA path**: Receives `initiatorKpk` as Supervisor KPK, looks up supervisor field
- **SCRAP/TPR path**: Uses original logic (supChain[1] = manager from initiator)
- Detailed debug logging for both paths

