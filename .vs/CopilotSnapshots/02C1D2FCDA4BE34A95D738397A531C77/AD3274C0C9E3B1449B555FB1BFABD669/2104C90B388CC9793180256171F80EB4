                            }
                        });

                        render();
                    })();
                </script>
                <!-- date range test -->
                <div class="card flex-1 basis-1/4 min-w-[200px] p-3">
                    <h2 id="codeFilterLabel" class="mb-2 text-sm font-semibold text-black capitalize dark:text-white/80">Code</h2>
