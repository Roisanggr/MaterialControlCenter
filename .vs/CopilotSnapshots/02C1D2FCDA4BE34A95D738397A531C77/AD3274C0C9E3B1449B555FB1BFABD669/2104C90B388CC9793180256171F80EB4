@section scripts{
    <script src="~/assets/js/main.js"></script>
    <script>
        (function () {

            // ── Konstanta & state ─────────────────────────────────────────────
            const _pageSize = 10;
            let _currentPage = 1;

            // URL endpoint baru (ditambahkan di Vendor_Scripts)
            const _urlGetAllRecords = urlGetAllRecords;

            // ── Init ──────────────────────────────────────────────────────────
            $(document).ready(function () {

                // Muat data pertama kali tanpa filter (menggunakan skeleton shimmer)
                loadAllScrapData(1, _pageSize, {});
                loadAllScrapTotals();
                initInitiatorAutocompleteForAllScrap();

                // Toggle panel filter
                document.getElementById("filtersScrapNotice").addEventListener("click", function (e) {
                    e.preventDefault();
                    document.getElementById("filterList").classList.toggle("hidden");
                });

                // Apply filter
                document.getElementById("applyFiltersScrapListButton").addEventListener("click", function () {
                    const appType = document.getElementById("applicationTypeFilter").value || "";

                    currentFilters = {
                        appType:          appType,
                        initiatorKpk:     document.getElementById("scrapInitiatorKpkFilter").value || "",
                        facility:         document.getElementById("scrapFacilityFilter").value || "",
                        createdDateFrom:  document.getElementById("scrapDateStart").value || "",
                        createdDateTo:    document.getElementById("scrapDateEnd").value || "",
                        // scrapCode hanya dikirim kalau appType bukan PIA
                        scrapCode:        (appType.toUpperCase() !== "PIA")
                                            ? (document.getElementById("scrapCodeFilter").value || "") : "",
                        // piaCode hanya dikirim kalau appType bukan SCRAP
                        piaCode:          (appType.toUpperCase() !== "SCRAP")
                                            ? (document.getElementById("scrapCodeFilter").value || "") : "",
                        tc:               document.getElementById("scrapTcCodeFilter").value || "",
                    };
                    _currentPage = 1;
                    loadAllScrapData(1, _pageSize, currentFilters);
                });

                // Reset filter
                document.getElementById("resetFiltersScrapListButton").addEventListener("click", function () {
                    document.getElementById("scrapInitiatorNameFilter").value = "";
                    document.getElementById("scrapInitiatorKpkFilter").value  = "";
                    document.getElementById("scrapFacilityFilter").value      = "";
                    document.getElementById("applicationTypeFilter").value    = "";
                    document.getElementById("scrapDateStart").value           = "";
                    document.getElementById("scrapDateEnd").value             = "";
                    document.getElementById("inputStart").value               = "";
                    document.getElementById("inputEnd").value                 = "";
                    document.getElementById("scrapCodeFilter").value          = "";
                    document.getElementById("scrapTcCodeFilter").value        = "";
                    currentFilters = {};
                    _currentPage = 1;
                    loadAllScrapData(1, _pageSize, {});
                });

                // ── Placeholder label "Code" berubah tergantung appType ──
                document.getElementById("applicationTypeFilter").addEventListener("change", function () {
                    const appType = this.value.toUpperCase();
                    const label   = document.getElementById("codeFilterLabel");
                    const input   = document.getElementById("scrapCodeFilter");
                    if (appType === "PIA") {
                        label.textContent = "PIA Code";
                        input.placeholder = "Input PIA Code";
                        input.disabled = false;
                    } else if (appType === "SCRAP") {
                        label.textContent = "Scrap Code";
                        input.placeholder = "Input Scrap Code";
                        input.disabled = false;
                    } else if (appType === "TPR") {
                        label.textContent = "TPR Code";
                        input.placeholder = "Input TPR Code";
                        input.disabled = false;
                    } else {
                        label.textContent = "Code";
                        input.placeholder = "Input Code";
                        input.disabled = true; // Selain kondisi di atas, input dimatikan
                    }

                });
            });


            // ── Load data via GetAllRecords ───────────────────────────────────
            function loadAllScrapData(pageNumber, size, filters) {
                filters = filters || currentFilters || {};

                // Bangun object data; hanya kirim scrapCode ATAU piaCode sesuai appType
                const appType = (filters.appType || "").toUpperCase();
                const requestData = {
                    pageNumber:      pageNumber,
                    pageSize:        size,
                    // Status: Waiting(1), Approved(4), Rejected(5), Finish(9), Draft(16)
                    "statusList[0]": 1,
                    "statusList[1]": 4,
                    "statusList[2]": 5,
                    "statusList[3]": 9,
                    "statusList[4]": 16,
                    appType:         filters.appType     || "",
                    initiatorKpk:    filters.initiatorKpk || "",
                    facility:        filters.facility     || "",
                    createdDateFrom: filters.createdDateFrom || "",
                    createdDateTo:   filters.createdDateTo   || "",
                    tc:              filters.tc            || "",
                };

                // Kirim scrapCode jika bukan pure-PIA, piaCode jika bukan pure-SCRAP
                if (appType !== "PIA")   requestData.scrapCode = filters.scrapCode || "";
                if (appType !== "SCRAP") requestData.piaCode   = filters.piaCode   || "";

                return $.ajax({
                    url:      _urlGetAllRecords,
                    type:     "GET",
                    data:     requestData,
                    dataType: "json"
                }).done(function (res) {
                    renderAllScrapTable(res.Data || []);
                    renderAllScrapPagination(res.TotalCount, res.PageNumber, res.PageSize);
                    if (typeof setApplyFilterLoading === "function") setApplyFilterLoading(false);
                }).fail(function (xhr, status, error) {
                    console.error("[AllScrap] loadAllScrapData error:", error);
                    document.getElementById("listOfScrap").innerHTML =
                        '<tr><td colspan="12" class="text-center py-6 text-muted">Failed to load data.</td></tr>';
                    if (typeof setApplyFilterLoading === "function") setApplyFilterLoading(false);
                });
            }


            // ── Render table ──────────────────────────────────────────────────
            function renderAllScrapTable(data) {
                const tbody = document.getElementById("listOfScrap");
                tbody.innerHTML = "";

                if (!data || data.length === 0) {
                    tbody.innerHTML =
                        '<tr><td colspan="12" class="text-center py-6 text-muted italic">No records found.</td></tr>';
                    return;
                }

                const appColors = {
                    "SCRAP": "bg-danger  text-white",
                    "PIA":   "bg-warning text-white",
                    "TPR":   "bg-info    text-white"
                };
                const statusMap = {
                    1:  { label: "Waiting",  cls: "bg-warning/10 text-warning" },
                    4:  { label: "Approved", cls: "bg-success/10 text-success" },
                    5:  { label: "Rejected", cls: "bg-danger/10  text-danger"  },
                    9:  { label: "Finish",   cls: "bg-info/10    text-info"    },
                    16: { label: "Draft",    cls: "bg-muted/20   text-muted"   }
                };

                let rows = "";
                data.forEach(function (item) {

                    // ── AppType badge ──────────────────────────────────────
                    // Response GetAllRecords menyertakan field AppType ("SCRAP" / "PIA")
                    const app      = (item.AppType || "SCRAP").toUpperCase();
                    const appColor = appColors[app] || "bg-muted text-white";
                    const appBadge = `<span class="text-xs px-2 py-0.5 rounded-full font-semibold ${appColor}">${app}</span>`;


                    // ── Document ID & detail URL ───────────────────────────
                    // GetAllRecords mengembalikan field "DocumentId" (unified)
                    const docId = item.DocumentId || item.Centralized_SourceData_ID || "";
                    const detailUrls = {
                        "SCRAP": `/DataForms/DetailScrap?id=${docId}`,
                        "PIA":   `/DataForms/DetailPia?id=${docId}`,
                        "TPR":   `/DataForms/DetailTpr?id=${docId}`
                    };
                    const detailUrl = detailUrls[app] || "#";

                    // ── Status badge ───────────────────────────────────────
                    const statusId   = item.Centralized_SourceData_Master_Status || 1;
                    const statusInfo = statusMap[statusId] || { label: "Unknown", cls: "bg-muted/20 text-muted" };
                    const statusBadge = `<span class="text-xs px-2 py-0.5 rounded-full ${statusInfo.cls}">${statusInfo.label}</span>`;


                    // ── Helper parse tanggal ASP.NET JSON format /Date(ticks)/ ──
                    function parseNetDate(val) {
                        if (!val) return null;
                        if (typeof val === "string") {
                            // Format: "/Date(1234567890000)/" atau "/Date(1234567890000+0700)/"
                            var m = /\/Date\((-?\d+)([+-]\d+)?\)\//.exec(val);
                            if (m) return new Date(parseInt(m[1], 10));
                        }
                        var d = new Date(val);
                        return isNaN(d.getTime()) ? null : d;
                    }

                    // ── Tanggal ────────────────────────────────────────────
                    var rawDate = item.CreatedDate || item.Centralized_SourceData_Master_CreatedDate;
                    var parsedDate = parseNetDate(rawDate);
                    const createdDate = parsedDate
                        ? parsedDate.toLocaleDateString("id-ID")
                        : "-";

                    // ── Approval step aktif ────────────────────────────────
                    const approval = item.CurrentApproval || "-";

                    // ── Code (ScrapCode atau PiaCode) ──────────────────────
                    // GetAllRecords menyatukan keduanya ke field "Code"
                    const mccCode = item.Code || "-";

                    rows += `
                        <tr>
                            <td>${appBadge}</td>
                            <td class="font-mono text-xs">${docId}</td>
                            <td>${item.Facility || "-"}</td>
                            <td>${item.InitiatorName || "-"}</td>
                            <td>${createdDate}</td>
                            <td>${mccCode}</td>
                            <td>${item.TC || "-"}</td>
                            <td>${item.TotalQty != null ? Number(item.TotalQty).toLocaleString("id-ID") : "-"}</td>
                            <td>${item.TotalValue != null ? formatRupiah(item.TotalValue) : "-"}</td>
                            <td class="text-xs">${approval}</td>
                            <td>${statusBadge}</td>
                            <td>
                                <a href="${detailUrl}"
                                   class="px-2 py-1 text-xs bg-info text-white rounded hover:bg-info/80">
                                    Detail
                                </a>
                            </td>
                        </tr>`;
                });

                tbody.innerHTML = rows;
            }


            // ── Pagination ────────────────────────────────────────────────────
            function renderAllScrapPagination(totalCount, pageNumber, size) {
                const ul         = document.getElementById("buttonPagination");
                const totalPages = Math.ceil(totalCount / size);
                ul.innerHTML     = "";

                if (totalPages <= 1) return;

                if (pageNumber > 1) {
                    const li = document.createElement("li");
                    li.innerHTML = `<button class="px-3 py-1 text-xs rounded border border-gray-300 hover:bg-gray-100"
                        onclick="loadAllScrapData(${pageNumber - 1}, ${size}, currentFilters)">‹</button>`;
                    ul.appendChild(li);
                }

                const start = Math.max(1, pageNumber - 2);
                const end   = Math.min(totalPages, pageNumber + 2);
                for (let p = start; p <= end; p++) {
                    const isActive = p === pageNumber;
                    const li = document.createElement("li");
                    li.innerHTML = `<button class="px-3 py-1 text-xs rounded border ${isActive
                        ? "bg-info text-white border-info"
                        : "border-gray-300 hover:bg-gray-100"}"
                        onclick="loadAllScrapData(${p}, ${size}, currentFilters)">${p}</button>`;
                    ul.appendChild(li);
                }

                if (pageNumber < totalPages) {
                    const li = document.createElement("li");
                    li.innerHTML = `<button class="px-3 py-1 text-xs rounded border border-gray-300 hover:bg-gray-100"
                        onclick="loadAllScrapData(${pageNumber + 1}, ${size}, currentFilters)">›</button>`;
                    ul.appendChild(li);
                }
            }


            // ── Initiator autocomplete ────────────────────────────────────────
            function initInitiatorAutocompleteForAllScrap() {
                const $input   = $("#scrapInitiatorNameFilter");
                const $results = $("#scrapInitiatorResults");
                const $kpk     = $("#scrapInitiatorKpkFilter");

                $input.on("input", function () {
                    const query = $(this).val().trim();
                    if (query.length < 3) {
                        $results.empty().addClass("hidden");
                        $kpk.val("");
                        return;
                    }
                    fetchData(urlGetEmployee, { keyword: query }, function (res) {
                        $results.empty();
                        if (res.success && Array.isArray(res.data)) {
                            res.data.slice(0, 5).forEach(function (emp) {
                                $("<div>")
                                    .addClass("dropdown-item hover:bg-success/[0.85] cursor-pointer p-2 rounded text-sm")
                                    .text(capitalizeWords(emp.name) + " (" + emp.kpk + ")")
                                    .on("click", function () {
                                        $kpk.val(emp.kpk);
                                        $input.val(capitalizeWords(emp.name));
                                        $results.empty().addClass("hidden");
                                    })
                                    .appendTo($results);
                            });
                            $results.removeClass("hidden");
                        } else {
                            $results.addClass("hidden");
                        }
                    });
                });

                $(document).on("click", function (e) {
                    if (!$(e.target).closest("#scrapInitiatorNameFilter, #scrapInitiatorResults").length)
                        $results.empty().addClass("hidden");
                });
            }


            // ── Summary cards ─────────────────────────────────────────────────
            async function loadAllScrapTotals() {
                try {
                    const data = {};
                    [1, 4, 9].forEach((s, i) => { data[`statusList[${i}]`] = s; });
                    const res = await $.ajax({
                        url:      urlGetScrapTotals,
                        type:     "GET",
                        data:     data,
                        dataType: "json"
                    });
                    $("#totalValueAll").empty().text(formatRupiahShort(res.TotalValueAll || 0));
                    $("[id='totalQtyAll']").eq(0).empty().text((res.TotalQtyAll || 0).toLocaleString("id-ID"));
                } catch (err) {
                    console.error("[AllScrap] loadAllScrapTotals error:", err);
                }
            }

            // Expose ke global scope untuk onclick pagination
            window.loadAllScrapData = loadAllScrapData;

        })();
    </script>
}
