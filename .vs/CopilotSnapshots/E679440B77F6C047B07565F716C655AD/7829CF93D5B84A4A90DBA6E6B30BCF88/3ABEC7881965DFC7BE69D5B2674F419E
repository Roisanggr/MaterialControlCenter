    @Html.Partial("~/Views/Shared/Vendor_Scripts.cshtml")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcode/1.5.1/qrcode.min.js"></script>
    <script src="~/assets/libs/apexcharts/apexcharts.min.js"></script>
    <script src="~/assets/js/main.js"></script>
    <script>
        const params = new URLSearchParams(window.location.search);
        const token = params.get("token");
        let docId = null;
        const urlGetPiaSummary = '@Url.Action("GetHeaderDocuments", "ListOfData")';
        const urlGetPiaDetails = '@Url.Action("GetDetailDocuments", "ListOfData")';

        if (token) {
            docId = atob(token);
        }

        $(document).ready(function () {
            if (docId) {
                document.getElementById("documentID").textContent = docId;
                loadSummaryData(docId);
                loadData(1, 10);
            } else {
                document.getElementById("detailsPia").innerHTML =
                    '<tr><td colspan="9" class="text-center py-6 text-muted">Invalid document ID. Please check the URL.</td></tr>';
            }

            // ── Filter button toggle ──────────────────────────────────────────
            document.getElementById('filtersPiaNotice').addEventListener('click', function (e) {
                e.preventDefault();
                document.getElementById('filterList').classList.toggle('hidden');
            });

            // ── Apply filters ─────────────────────────────────────────────────
            document.getElementById('applyFiltersPiaListButtonPiaDetail').addEventListener('click', function (e) {
                e.preventDefault();
                currentFilters = {
                    partNumber: $("#piaPartNumberFilter").val(),
                    process: $("#piaProcessFilter").val()
                };
                loadData(1, 10, currentFilters);
            });

            // ── Reset filters ─────────────────────────────────────────────────
            document.getElementById('resetFiltersPiaListButtonPiaDetail').addEventListener('click', function (e) {
                e.preventDefault();
                $('#piaPartNumberFilter, #piaProcessFilter').val('');
                currentFilters = {};
                loadData(1, 10, currentFilters);
            });
        });

        function loadData(page = 1, pageSize = 10, filters = {}) {
            if (!docId) {
                console.warn("[DetailPia] loadData called but docId is not set");
                return;
            }

            console.log("[DetailPia] loadData called with:", { page, pageSize, docId, filters });

            $.ajax({
                url: urlGetPiaDetails,
                type: "GET",
                data: {
                    documentType: 'PIA',
                    documentId: docId,
                    page: page,
                    pageSize: pageSize,
                    partNumber: filters.partNumber || "",
                    process: filters.process || ""
                },
                success: function (res) {
                    console.log("[DetailPia] loadData response:", res);
                    renderTablePiaDetail(res.Data);
                    renderPagination(res.TotalPartsAll, page, pageSize);
                },
                error: function (err) {
                    console.error("[DetailPia] loadData error:", err);
                    document.getElementById("detailsPia").innerHTML =
                        '<tr><td colspan="9" class="text-center py-6 text-muted">Failed to load data.</td></tr>';
                }
            });
        }

        function renderTablePiaDetail(data) {
            const tbody = document.getElementById("detailsPia");
            tbody.innerHTML = "";

            if (!data || data.length === 0) {
                const row = document.createElement("tr");
                row.innerHTML = `
                <td colspan="9" class="text-center text-muted py-3">
                    No data available
                </td>
            `;
                tbody.appendChild(row);
                return;
            }

            data.forEach(part => {
                const row = document.createElement("tr");
                row.innerHTML = `
                <td>${part.PartNumber || '-'}</td>
                <td>${part.PartDescription || '-'}</td>
                <td>${part.PartProcess || '-'}</td>
                <td>${part.PhysicalQty != null ? Number(part.PhysicalQty).toLocaleString("id-ID") : "-"}</td>
                <td>${part.SystemQty != null ? Number(part.SystemQty).toLocaleString("id-ID") : "-"}</td>
                <td>${part.VarianceQty != null ? Number(part.VarianceQty).toLocaleString("id-ID") : "-"}</td>
                <td>${part.Unit || '-'}</td>
                <td>${part.TotalValue != null ? formatRupiah(part.TotalValue) : "-"}</td>
                <td>${part.Status || '-'}</td>
            `;
                tbody.appendChild(row);
            });
        }

        function loadSummaryData(docId) {
            if (!docId) {
                console.warn("[DetailPia] loadSummaryData called but docId is not set");
                return;
            }

            console.log("[DetailPia] loadSummaryData called with docId:", docId);

            $.ajax({
                url: urlGetPiaSummary,
                type: "GET",
                data: { documentType: 'PIA', documentId: docId },
                success: function (res) {
                    console.log("[DetailPia] loadSummaryData response:", res);

                    if (!res || res.error) {
                        console.warn("[DetailPia] Response error or not found:", res);
                        document.getElementById("detailsPia").innerHTML =
                            '<tr><td colspan="9" class="text-center py-6 text-muted">No document found or invalid ID.</td></tr>';
                        return;
                    }

                    $('#overallTotal').empty().text(formatRupiahShort(res.TotalValue || 0));
                    $('#overallQuantity').empty().text(res.TotalVarianceQty || 0);

                    document.getElementById("facilityInfo").textContent = res.Facility || "-";
                    document.getElementById("tcInfo").textContent = res.TC || "-";
                    document.getElementById("piaCodeInfo").textContent = res.PiaCode || "-";
                    document.getElementById("typeInfo").textContent = res.Type || "-";

                    renderCurrentStatus(res.Status || 0);
                },
                error: function (err) {
                    console.error("[DetailPia] loadSummaryData error:", err);
                    document.getElementById("detailsPia").innerHTML =
                        '<tr><td colspan="9" class="text-center py-6 text-muted">Failed to load document summary.</td></tr>';
                }
            });
        }

        function renderCurrentStatus(statusId) {
            const statusMap = {
                0: { text: "Draft", icon: "ri-edit-line", class: "bg-muted/50" },
                1: { text: "Waiting", icon: "ri-time-line", class: "bg-warning/10" },
                4: { text: "Approved", icon: "ri-check-line", class: "bg-success/10" },
                5: { text: "Rejected", icon: "ri-close-line", class: "bg-danger/10" },
                9: { text: "Finish", icon: "ri-check-double-line", class: "bg-info/10" },
                16: { text: "Draft", icon: "ri-edit-line", class: "bg-muted/50" }
            };

            // Convert string status ID to number if needed
            const statusIdNum = typeof statusId === "string" ? parseInt(statusId, 10) : statusId;
            const statusInfo = statusMap[statusIdNum] || { text: "Unknown", icon: "ri-help-line", class: "bg-muted/10" };
            const statusDiv = document.getElementById("currentStatusDiv");
            const badgeDiv = document.getElementById("currentStatusBadge");

            statusDiv.className = `p-5 border-b mb-4 rounded ${statusInfo.class} dark:border-darkborder border-black/10 text-center`;
            badgeDiv.innerHTML = `
                <div class="inline-flex items-center justify-center gap-2 text-sm font-semibold">
                    <i class="${statusInfo.icon}"></i>
                    <span>${statusInfo.text}</span>
                </div>
            `;
        }

        function renderPagination(totalCount, pageNumber, size) {
            const ul = document.getElementById("buttonPagination");
            const totalPages = Math.ceil(totalCount / size);
            ul.innerHTML = "";

            if (totalPages <= 1) return;

            // Previous button
            if (pageNumber > 1) {
                const li = document.createElement("li");
                const btn = document.createElement("button");
                btn.className = "px-3 py-1 text-xs rounded border border-gray-300 hover:bg-gray-100";
                btn.textContent = "‹";
                btn.onclick = function() { 
                    loadData(pageNumber - 1, size, currentFilters);
                };
                li.appendChild(btn);
                ul.appendChild(li);
            }

            // Page numbers
            const start = Math.max(1, pageNumber - 2);
            const end = Math.min(totalPages, pageNumber + 2);
            for (let p = start; p <= end; p++) {
                const isActive = p === pageNumber;
                const li = document.createElement("li");
                const btn = document.createElement("button");
                btn.className = `px-3 py-1 text-xs rounded border ${isActive
                    ? "bg-info text-white border-info"
                    : "border-gray-300 hover:bg-gray-100"}`;
                btn.textContent = p;
                btn.onclick = function() { 
                    loadData(p, size, currentFilters);
                };
                li.appendChild(btn);
                ul.appendChild(li);
            }

            // Next button
            if (pageNumber < totalPages) {
                const li = document.createElement("li");
                const btn = document.createElement("button");
                btn.className = "px-3 py-1 text-xs rounded border border-gray-300 hover:bg-gray-100";
                btn.textContent = "›";
                btn.onclick = function() { 
                    loadData(pageNumber + 1, size, currentFilters);
                };
                li.appendChild(btn);
                ul.appendChild(li);
            }
        }

        window.loadData = loadData;

        // ────────────────────────────────────────────────────────────────────────────
        // APPROVAL & STATUS FUNCTIONS
        // ────────────────────────────────────────────────────────────────────────────

        const urlGetPiaApprovals = '@Url.Action("GetDetailsApprovals", "ListOfData")';
        const urlTriggerApproval = '@Url.Action("TriggerApproval", "AutomateFlow")';
        const urlTriggerApprovalManual = '@Url.Action("TriggerApprovalManual", "AutomateFlow")';
        const urlInsertDelegate = '@Url.Action("InsertDelegateApprovalRecord", "UpdateData")';
        const urlDeletePia = '@Url.Action("DeletePia", "UpdateData")';

        let currentApproval = null;
        let currentSourceDataID = null;
        let isLastApprovalStep = false;
        let originalApproverKpk = null;
        let isDelegateActive = false;

        async function loadApprovalData(piaId) {
            try {
                const result = await $.ajax({
                    url: urlGetPiaApprovals,
                    type: "GET",
                    data: { documentType: 'PIA', documentId: piaId }
                });

                if (result && result.Data && result.Data.length > 0) {
                    const approvalData = result.Data[0];
                    renderApprovalProgress(approvalData.Approvals || []);
                    await checkAndRenderApproveReject(piaId, approvalData);
                }
            } catch (err) {
                console.error("[DetailPia] loadApprovalData error:", err);
            }
        }

        function renderApprovalProgress(approvals) {
            const ul = document.getElementById("approvalProgress");
            ul.innerHTML = "";

            if (!Array.isArray(approvals) || approvals.length === 0) {
                ul.innerHTML = `<li class="text-muted text-sm p-4">No approvals configured.</li>`;
                return;
            }

            approvals.forEach(app => {
                const initials = (app.ApproverName || "?")
                    .split(" ")
                    .map(n => n[0])
                    .join("")
                    .toUpperCase();

                const { statusText, badgeClass } = getApprovalStatus(app.Centralized_StatusList_ID);

                const li = document.createElement("li");
                li.innerHTML = `
                    <div class="flex items-center gap-3">
                        <div class="relative rounded-full shrink-0">
                            <div class="rounded-full h-7 w-7 flex items-center justify-center text-xs font-semibold uppercase bg-purple/20 text-purple">
                                ${initials}
                            </div>
                        </div>
                        <div class="grow">
                            <h6 class="mb-1 text-black dark:text-white/80">${capitalizeWords(app.ApproverName || "Unknown")}</h6>
                            <p class="text-xs text-muted">${app.Centralized_ApprovalList_Date ? formatDate(app.Centralized_ApprovalList_Date) : 'Pending'}</p>
                        </div>
                        <div class="relative shrink-0">
                            <div class="inline-block px-3 py-1 ${badgeClass} text-white text-xs font-semibold rounded-full shadow-md">
                                ${statusText}
                            </div>
                        </div>
                    </div>`;
                ul.appendChild(li);
            });
        }

        async function checkAndRenderApproveReject(piaId, approvalData) {
            const approveRejectField = document.getElementById("approveRejectField");
            const buttonDelete = document.getElementById("deleteButtonForInitiator");

            approveRejectField.classList.add("hidden");
            buttonDelete.classList.add("hidden");

            if (!approvalData) return;

            const approvals = approvalData.Approvals || [];
            const currentStatus = approvalData.CurrentStatus;
            const initiatorKpk = approvalData.InitiatorKpk;

            // Render current status
            renderCurrentStatus(currentStatus);

            // Show delete button for initiator if document is pending or active
            if (initiatorKpk === kpk && (currentStatus === 1 || currentStatus === 4)) {
                buttonDelete.classList.remove("hidden");
                if (approvals.length > 0) {
                    setCurrentApproval(null, approvalData.Centralized_SourceData_ID);
                }
            }

            // If rejected or finished, don't show approve/reject buttons
            if (currentStatus === 5 || currentStatus === 9 || currentStatus === 16) {
                return;
            }

            // Check if user is next approver
            approvals.sort((a, b) => a.Centralized_ApprovalList_Step - b.Centralized_ApprovalList_Step);
            const nextStepPending = approvals.find(a => a.Centralized_StatusList_ID === 1);

            if (!nextStepPending) return;

            const maxStep = Math.max(...approvals.map(a => a.Centralized_ApprovalList_Step));
            isLastApprovalStep = nextStepPending.Centralized_ApprovalList_Step === maxStep;

            const originalKpk = nextStepPending.OriginalKpkApproval || nextStepPending.Kpk;
            const approverKpks = await getDelegateKpkIfAny(originalKpk);

            // Check if all previous steps are approved
            const stepIndex = approvals.indexOf(nextStepPending);
            if (stepIndex > 0) {
                const prevStep = approvals[stepIndex - 1];
                if (prevStep.Centralized_StatusList_ID !== 2) return;
            }

            // Show approve/reject buttons if user is next approver
            if (approverKpks.map(x => x.toString()).includes(kpk.toString())) {
                approveRejectField.classList.remove("hidden");
                setCurrentApproval(nextStepPending.Centralized_ApprovalList_ID, approvalData.Centralized_SourceData_ID);
            }
        }

        async function getDelegateKpkIfAny(originalKpk) {
            const currentDayType = getCurrentDayType();
            originalApproverKpk = originalKpk;

            try {
                const res = await $.getJSON(getDelegatesUrl, { searchUserKpk: originalKpk });
                if (!res.success) return [originalKpk];

                const matchedDelegates = res.data.filter(d =>
                    d.DelegateTime === currentDayType || d.DelegateTime === "Everyday"
                );

                if (matchedDelegates.length > 0) {
                    const delegateKpks = matchedDelegates.map(d => d.DelegateKpk);
                    isDelegateActive = true;
                    return [originalKpk, ...delegateKpks];
                } else {
                    return [originalKpk];
                }
            } catch (err) {
                console.error("Error fetching delegates:", err);
                return [originalKpk];
            }
        }

        function setCurrentApproval(approvalListId, sourceDataID) {
            currentApproval = approvalListId;
            currentSourceDataID = sourceDataID;
        }

        async function handleDecision(status) {
            if (!currentSourceDataID) return;

            const baseUrl = isLastApprovalStep
                ? urlTriggerApprovalManual
                : urlTriggerApproval;

            const urlTrigger = baseUrl
                + "?approvalListId=" + currentApproval
                + "&status=" + status
                + "&sourceDataID=" + currentSourceDataID;

            const result = await showDynamicSwal({
                title: "Are you sure?",
                text: status == 3 ? "Do you want to reject this?" : "Do you want to approve this?",
                icon: "warning",
                confirmText: "Yes, Continue",
                cancelText: "Cancel"
            });

            if (!result.isConfirmed) return;

            Swal.fire({
                title: "Processing...",
                text: "Please wait while processing your decision.",
                allowOutsideClick: false,
                didOpen: () => Swal.showLoading()
            });

            try {
                if (isDelegateActive && kpk !== originalApproverKpk) {
                    const insertRes = await $.post(urlInsertDelegate, {
                        approvalListId: currentApproval,
                        statusListId: status,
                        delegateKpk: kpk
                    });

                    if (!insertRes.success) {
                        Swal.close();
                        Swal.fire({
                            icon: "error",
                            title: "Delegate Insert Failed",
                            text: insertRes.message || "Failed to insert delegate record."
                        });
                        return;
                    }
                }

                const response = await $.get(urlTrigger);

                if (response.success) {
                    Swal.close();
                    await Swal.fire({
                        icon: "success",
                        title: "Success",
                        text: response.message || "Decision recorded successfully."
                    });

                    loadApprovalData(docId);
                    loadSummaryData(docId);
                } else {
                    Swal.close();
                    Swal.fire({
                        icon: "error",
                        title: "Error",
                        text: response.message || "Failed to process decision."
                    });
                }
            } catch (err) {
                Swal.close();
                Swal.fire({
                    icon: "error",
                    title: "Request Failed",
                    text: "Something went wrong while processing your decision."
                });
                console.error(err);
            }
        }

        async function UpdateStatusDelete() {
            if (!currentSourceDataID || !docId) {
                console.warn("⚠️ Centralized_SourceData_ID or Document ID not found");
                return;
            }

            const confirmResult = await showDynamicSwal({
                title: "Are you sure?",
                text: "This action will mark the PIA as deleted.",
                icon: "warning",
                confirmText: "Yes, delete it!",
                cancelText: "Cancel"
            });

            if (!confirmResult.isConfirmed) return;

            try {
                const response = await fetch(urlDeletePia, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({
                        piaHeaderId: docId,
                        sourceDataId: currentSourceDataID
                    })
                });

                const result = await response.json();

                if (result.success) {
                    await Swal.fire({
                        icon: "success",
                        title: "Deleted!",
                        text: result.message || "PIA document deleted successfully.",
                        confirmButtonText: "OK"
                    });
                    location.reload();
                } else {
                    Swal.fire({
                        icon: "error",
                        title: "Delete Failed",
                        text: result.message || "Could not delete the PIA.",
                        confirmButtonText: "Close"
                    });
                }
            } catch (err) {
                console.error("🔥 Error:", err);
                Swal.fire({
                    icon: "warning",
                    title: "Unexpected Error",
                    text: "An unexpected error occurred. Please try again later.",
                    confirmButtonText: "OK"
                });
            }
        }

        // ────────────────────────────────────────────────────────────────────────────
        // CHART & DOWNLOAD FUNCTIONS
        // ────────────────────────────────────────────────────────────────────────────

        async function downloadExcel() {
            if (!docId) return;

            try {
                const summaryRes = await $.get(urlGetPiaSummary, { documentType: 'PIA', documentId: docId });
                const detailRes = await $.get(urlGetPiaDetails, { documentType: 'PIA', documentId: docId, page: 1, pageSize: 99999 });

                const summarySheetData = [
                    ["Document ID", docId],
                    ["Facility", summaryRes.Facility ?? "N/A"],
                    ["TC", summaryRes.TC ?? "N/A"],
                    ["PIA Code", summaryRes.PiaCode ?? "N/A"],
                    ["Type", summaryRes.Type ?? "N/A"],
                    ["Total Value", formatRupiah(summaryRes.TotalValue || 0)],
                    ["Total Variance Qty", summaryRes.TotalVarianceQty ?? "N/A"],
                    []
                ];

                const detailHeader = [
                    "Part Number",
                    "Description",
                    "Process",
                    "Physical Qty",
                    "System Qty",
                    "Variance Qty",
                    "Unit",
                    "Total Value",
                    "Status"
                ];

                const detailRows = detailRes.Data.map(part => [
                    part.PartNumber,
                    part.PartDescription,
                    part.PartProcess,
                    part.PhysicalQty,
                    part.SystemQty,
                    part.VarianceQty,
                    part.Unit,
                    formatRupiah(part.TotalValue || 0),
                    part.Status
                ]);

                const ws = XLSX.utils.aoa_to_sheet([...summarySheetData, detailHeader, ...detailRows]);
                const headerRow = summarySheetData.length;

                const colWidths = [];
                for (let C = 0; C < detailHeader.length; C++) {
                    const maxLength = Math.max(...detailRows.map(r => (r[C] ? r[C].toString().length : 0)));
                    colWidths.push({ wch: maxLength + 5 });
                }
                ws['!cols'] = colWidths;

                const wb = XLSX.utils.book_new();
                XLSX.utils.book_append_sheet(wb, ws, "PIA Report");
                XLSX.writeFile(wb, `PiaDetails_${docId}.xlsx`);

            } catch (err) {
                console.error("Error exporting Excel:", err);
                Swal.fire("Error", "Failed to download Excel file.", "error");
            }
        }

        async function downloadPDF() {
            if (!docId) return;

            try {
                const summaryRes = await $.get(urlGetPiaSummary, { documentType: 'PIA', documentId: docId });
                const detailRes = await $.get(urlGetPiaDetails, {
                    documentType: 'PIA',
                    documentId: docId,
                    page: 1,
                    pageSize: 30
                });

                const { jsPDF } = window.jspdf;
                const doc = new jsPDF({ orientation: "portrait", unit: "mm", format: "a4" });

                const pageWidth = doc.internal.pageSize.getWidth();
                const pageHeight = doc.internal.pageSize.getHeight();
                const margin = 10;
                let yPosition = margin;

                // Title
                doc.setFontSize(16);
                doc.setFont("helvetica", "bold");
                doc.text(`PIA Notice - ${docId}`, margin, yPosition);
                yPosition += 10;

                // Summary info
                doc.setFontSize(10);
                doc.setFont("helvetica", "normal");
                const summaryInfo = [
                    [`Facility: ${summaryRes.Facility || "N/A"}`, `TC: ${summaryRes.TC || "N/A"}`],
                    [`PIA Code: ${summaryRes.PiaCode || "N/A"}`, `Type: ${summaryRes.Type || "N/A"}`],
                    [`Total Value: ${formatRupiah(summaryRes.TotalValue || 0)}`, `Variance Qty: ${summaryRes.TotalVarianceQty || "N/A"}`]
                ];

                summaryInfo.forEach(row => {
                    doc.text(row[0], margin, yPosition);
                    doc.text(row[1], pageWidth / 2, yPosition);
                    yPosition += 6;
                });

                yPosition += 4;

                // Table header
                doc.setFont("helvetica", "bold");
                doc.setFontSize(9);
                const columns = ["Part No", "Description", "Process", "Phys. Qty", "Sys. Qty", "Var. Qty", "Unit", "Total", "Status"];
                const colWidth = (pageWidth - 2 * margin) / columns.length;

                columns.forEach((col, index) => {
                    doc.text(col, margin + index * colWidth, yPosition, { maxWidth: colWidth - 1, align: "center" });
                });

                yPosition += 6;
                doc.setDrawColor(200, 200, 200);
                doc.line(margin, yPosition, pageWidth - margin, yPosition);
                yPosition += 2;

                // Table rows
                doc.setFont("helvetica", "normal");
                doc.setFontSize(8);

                detailRes.Data.slice(0, 30).forEach(part => {
                    if (yPosition > pageHeight - 10) {
                        doc.addPage();
                        yPosition = margin;
                    }

                    const data = [
                        part.PartNumber || "-",
                        part.PartDescription || "-",
                        part.PartProcess || "-",
                        part.PhysicalQty || "-",
                        part.SystemQty || "-",
                        part.VarianceQty || "-",
                        part.Unit || "-",
                        formatRupiah(part.TotalValue || 0),
                        part.Status || "-"
                    ];

                    data.forEach((cell, index) => {
                        doc.text(cell.toString(), margin + index * colWidth, yPosition, { maxWidth: colWidth - 1, align: "center" });
                    });

                    yPosition += 6;
                });

                doc.save(`Pia_${docId}.pdf`);

            } catch (err) {
                console.error("Error generating PDF:", err);
                Swal.fire("Error", "Failed to generate PDF.", "error");
            }
        }
    </script>
