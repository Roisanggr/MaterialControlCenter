            if (!result || !result.approvals) return;
            renderCurrentStatus(result.currentStatus);

            const approvals = result.approvals;
            logApprovalSummary(approvals);
            if (result.initiatorKpk === kpk && (result.currentStatus === 1 || result.currentStatus === 4)) {
                buttonDelete.classList.remove("hidden");
                if (approvals.length > 0) {
                    setCurrentApproval(null, approvals[0].Centralized_SourceData_ID);
