                                </div>
                                <ul id="approvalProgress" class="flex flex-col gap-3 mb-4">
                                    <li class="animate-pulse">
                                        <div class="flex items-center gap-3">
                                            <!-- Avatar skeleton -->
                                            <div class="relative rounded-full shrink-0">
                                                <div class="rounded-full bg-muted size-9"></div>
                                                <span class="inline-block size-2 bg-muted/50 rounded-full absolute ltr:right-0.5 rtl:left-0.5 bottom-[1px] border border-white"></span>
                                            </div>

                                            <!-- Text skeleton -->
                                            <div class="grow space-y-2">
                                                <div class="h-3 bg-muted/50 rounded w-32"></div>
                                                <div class="h-2 bg-muted/50 rounded w-24"></div>
                                            </div>

                                            <!-- Badge skeleton -->
                                            <div class="relative shrink-0">
                                                <div class="h-6 w-20 bg-muted/50 rounded-full"></div>
                                            </div>
                                        </div>
                                    </li>
                                    <li class="animate-pulse">
                                        <div class="flex items-center gap-3">
                                            <!-- Avatar skeleton -->
                                            <div class="relative rounded-full shrink-0">
                                                <div class="rounded-full bg-muted size-9"></div>
                                                <span class="inline-block size-2 bg-muted/50 rounded-full absolute ltr:right-0.5 rtl:left-0.5 bottom-[1px] border border-white"></span>
                                            </div>

                                            <!-- Text skeleton -->
                                            <div class="grow space-y-2">
                                                <div class="h-3 bg-muted/50 rounded w-32"></div>
                                                <div class="h-2 bg-muted/50 rounded w-24"></div>
                                            </div>

                                            <!-- Badge skeleton -->
                                            <div class="relative shrink-0">
                                                <div class="h-6 w-20 bg-muted/50 rounded-full"></div>
                                            </div>
                                        </div>
                                    </li>
                                    <li class="animate-pulse">
                                        <div class="flex items-center gap-3">
                                            <!-- Avatar skeleton -->
                                            <div class="relative rounded-full shrink-0">
                                                <div class="rounded-full bg-muted size-9"></div>
                                                <span class="inline-block size-2 bg-muted/50 rounded-full absolute ltr:right-0.5 rtl:left-0.5 bottom-[1px] border border-white"></span>
                                            </div>

                                            <!-- Text skeleton -->
                                            <div class="grow space-y-2">
                                                <div class="h-3 bg-muted/50 rounded w-32"></div>
                                                <div class="h-2 bg-muted/50 rounded w-24"></div>
                                            </div>

                                            <!-- Badge skeleton -->
                                            <div class="relative shrink-0">
                                                <div class="h-6 w-20 bg-muted/50 rounded-full"></div>
                                            </div>
                                        </div>
                                    </li>


                                </ul>
                                <div id="approveRejectField" class="flex gap-3 w-full hidden">
                                    <!-- Reject Button -->
                                    <button type="button"
                                            class="flex-1 btn bg-danger border-danger text-white hover:bg-danger/[0.85] hover:border-danger/[0.85]"
                                            onclick="handleDecision(3)">
                                        <i class="ri-close-line align-bottom ltr:mr-1 rtl:ml-1"></i> Reject
                                    </button>

                                    <!-- Approve Button -->
                                    <button type="button"
                                            class="flex-1 btn bg-success border-success text-white hover:bg-success/[0.85] hover:border-success/[0.85]"
                                            onclick="handleDecision(2)">
                                        <i class="ri-check-line align-bottom ltr:mr-1 rtl:ml-1"></i> Approve
                                    </button>


                                </div>

                                <div id="deleteButtonForInitiator" class="flex gap-3 w-full mt-4 hidden">
                                    <!-- Reject Button -->
                                    <button id="buttonDelete" type="button"
                                            class="flex-1 btn bg-danger border-danger text-white hover:bg-danger/[0.85] hover:border-danger/[0.85]"
                                            onclick="UpdateStatusDelete()">
                                        <i class="ri-delete-bin-line align-bottom ltr:mr-1 rtl:ml-1"></i> Delete
                                    </button>

                                </div>

                            </div>


                            <div class="bg-muted/50 p-5 border-b dark:border-darkborder border-black/10 flex justify-between items-center">
                                <h6 class="font-semibold text-black dark:text-white/80">Scrap Disposal</h6>
                                <button id="addDisposalButton" type="button"
                                        class="btn bg-success text-white hover:bg-success/[0.85] px-3 py-1 text-xs rounded flex items-center justify-center gap-1"
                                        onclick="openDisposalModal()">
                                    <i class="ri-add-line text-sm"></i> Add
                                </button>

                            </div>

                            <ul class="flex flex-col gap-3 mb-4 mt-4">
                                <li>
                                    <table class="w-full">
                                        <thead>
                                            <tr class="ltr:text-left rtl:text-right">

                                                <th>Item Code</th>
                                                <th>Description</th>
                                                <th>Qty</th>
                                                <th>Unit</th>

                                            </tr>
                                        </thead>
                                        <tbody id="disposalTable">
                                            <tr class="text-muted">
                                                <td colspan="4">Loading...</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </li>
                            </ul>
                            <div class="bg-muted/50 p-5 border-b dark:border-darkborder border-black/10">
                                <h6 class="font-semibold text-black dark:text-white/80">Download File</h6>
                            </div>
                            <ul class="flex flex-col gap-3 mb-4 mt-4">
                                <li>
                                    <div class="flex justify-center gap-4">
                                        <!-- Download PDF Button -->
                                        <button type="button"
                                                class="btn bg-danger text-white hover:bg-info px-6 py-3 text-sm rounded-lg flex items-center justify-center"
                                                onclick="downloadPDF()">
                                            <i class="ri-file-pdf-line ltr:mr-2 rtl:ml-2 text-lg"></i> PDF
                                        </button>

                                        <!-- Download Excel Button -->
                                        <button type="button"
                                                class="btn bg-success text-white hover:bg-muted px-6 py-3 text-sm rounded-lg flex items-center justify-center"
                                                onclick="downloadExcel()">
                                            <i class="ri-file-excel-line ltr:mr-2 rtl:ml-2 text-lg"></i> Excel
                                        </button>
                                    </div>
                                </li>
                            </ul>
                        </div>

                    </div>


                    @Html.Partial("~/Views/Shared/Footer.cshtml")

                </div>
                <!-- End Content -->
            </div>
            <!-- End Content Area -->
        </div>
    </div>

    <div id="modalsUpdateApproval"
         class="fixed inset-0 bg-black/80 z-[99998] hidden overflow-y-auto dark:bg-dark/90">
        <div class="flex items-start justify-center min-h-screen px-4"  onclick="event.stopPropagation()">
            <div class="relative w-full max-w-lg p-0 my-8 overflow-hidden bg-white border rounded-lg border-black/10 dark:bg-darklight dark:border-darkborder">
                <div class="flex items-center justify-between px-5 py-3 bg-white border-b border-black/10 dark:bg-darklight dark:border-darkborder">
                    <h5 class="text-lg font-semibold dark:text-white">Update Approval Flow</h5>
                    <button type="button" class="text-muted hover:bg-danger/[0.85] text-black dark:hover:text-white"
                            onclick="closeModal('modalsUpdateApproval')">
                        ✕
                    </button>
                </div>
                <div class="p-5 space-y-4">
                    <div id="approverList" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <!-- Card 1 -->
                        <div class="p-5 border rounded border-black/10 dark:border-darkborder">
                            <div class="flex gap-4 mb-4">
                                <div class="flex-1">
                                    <p class="mb-1 text-sm font-semibold dark:text-white">1. Kevin Immanuel Bujani</p>
                                    <p class="text-xs text-muted dark:text-darkmuted">Approved At: Nov 10, 2024</p>
                                </div>

                            </div>
                        </div>

                        <!-- Card 2 -->
                        <div class="p-5 border rounded border-black/10 dark:border-darkborder">
                            <div class="flex gap-4 mb-4">
                                <div class="flex-1">
                                    <p class="mb-1 text-sm font-semibold dark:text-white">2. John Doe</p>
                                    <p class="text-xs text-muted dark:text-darkmuted">Approved At: Nov 11, 2024</p>
                                </div>

                            </div>
                        </div>

                        <!-- Card 3 -->
                        <div class="p-5 border rounded border-black/10 dark:border-darkborder">
                            <div class="flex gap-4 mb-4">
                                <div class="flex-1">
                                    <p class="mb-1 text-sm font-semibold dark:text-white">3. Jane Smith</p>
                                    <p class="text-xs text-muted dark:text-darkmuted">Approved At: Nov 12, 2024</p>
                                </div>

                            </div>
                        </div>
                    </div>


                    <div class="flex items-center justify-end gap-4">
                        <button type="button"
                                class="btn bg-danger border-danger text-white hover:bg-danger/[0.85]"
