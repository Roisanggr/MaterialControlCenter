                            Discard
                        </button>

                        <button id="saveUpdateApproval" type="button" class="btn bg-purple border-purple text-white hover:bg-purple/[0.85]">Save</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="modalAddDisposal"
         class="fixed inset-0 bg-black/80 z-[99999] hidden overflow-y-auto dark:bg-dark/90">
        <div class="flex items-start justify-center min-h-screen px-4" onclick="closeModal('modalAddDisposal')">
            <div class="relative w-full max-w-lg p-0 my-8 overflow-hidden bg-white border rounded-lg border-black/10 dark:bg-darklight dark:border-darkborder" onclick="event.stopPropagation()">

                <!-- Header -->
                <div class="flex items-center justify-between px-5 py-3 bg-white border-b border-black/10 dark:bg-darklight dark:border-darkborder">
                    <h5 class="text-lg font-semibold dark:text-white">Add Disposal</h5>
                    <button type="button" class="text-muted hover:bg-danger/[0.85] text-black dark:hover:text-white"
                            onclick="closeModal('modalAddDisposal')">
                        ✕
                    </button>
                </div>

                <!-- Body -->
                <div class="p-5 space-y-4">
                    <!-- Disposal Form -->
                    <div class="space-y-4">

                        <!-- Select Disposal ID -->
                        <div>
                            <label class="text-sm font-medium dark:text-white">Disposal Item</label>
                            <select id="disposalSelect" class="w-full border rounded p-2 dark:bg-darkbg dark:text-white">
                                <!-- Options will be populated dynamically -->
                            </select>
                        </div>

                        <!-- Quantity -->
                        <div>
                            <label class="text-sm font-medium dark:text-white">Quantity</label>
                            <input type="number"
                                   min="0.01"
                                   step="0.01"
                                   id="disposalQty"
                                   class="w-full border rounded p-2 dark:bg-darkbg dark:text-white"
                                   placeholder="Enter quantity" />
                        </div>

                        <!-- Remarks -->
                        <div>
                            <label class="text-sm font-medium dark:text-white">Remarks</label>
                            <textarea id="disposalRemarks" class="w-full border rounded p-2 dark:bg-darkbg dark:text-white" placeholder="Enter remarks"></textarea>
                        </div>

                        <!-- Checkboxes -->
                        <div class="flex gap-4">
                            <label class="flex items-center gap-1">
                                <input type="checkbox" id="chkIn" /> In
                            </label>
                            <label class="flex items-center gap-1">
                                <input type="checkbox" id="chkOut" /> Out
                            </label>
                            <label class="flex items-center gap-1">
                                <input type="checkbox" id="chkB3" /> B3
                            </label>
                            <label class="flex items-center gap-1">
                                <input type="checkbox" id="chkNonB3" /> Non B3
                            </label>
                        </div>
                    </div>

                    <!-- Footer Buttons -->
                    <div class="flex items-center justify-end gap-4">
                        <button type="button"
                                class="btn bg-danger border-danger text-white hover:bg-danger/[0.85]"
                                onclick="closeModal('modalAddDisposal')">
                            Cancel
                        </button>
                        <button type="button"
                                class="btn bg-purple border-purple text-white hover:bg-purple/[0.85]"
                                onclick="saveDisposal()">
                            Save
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

