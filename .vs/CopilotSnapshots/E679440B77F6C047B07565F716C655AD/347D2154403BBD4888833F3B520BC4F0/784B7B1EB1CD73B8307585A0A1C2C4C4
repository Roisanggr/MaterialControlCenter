        function logApprovalSummary(approvals) {
            const totalApprovers = approvals.length;
            const totalStatus1 = approvals.filter(a => a.Centralized_StatusList_ID === 1).length; // Pending
            const totalStatus2 = approvals.filter(a => a.Centralized_StatusList_ID === 2).length; // Approved
            const totalStatus3 = approvals.filter(a => a.Centralized_StatusList_ID === 3).length; // Rejected
            let watermarkText = "AWAITING APPROVER";

            if (totalStatus3 > 0) {

                watermarkText = "REJECTED";
            }
            else if (totalStatus2 === totalApprovers && totalApprovers > 0) {

                watermarkText = "APPROVED";
            }
            else if (totalStatus2 === totalApprovers - 1 && totalStatus1 === 1) {
                watermarkText = "STORE APPROVAL";
            }
            else {

                watermarkText = "AWAITING APPROVER";
            }
            globalWatermarkText = watermarkText;

            return watermarkText;
        }


