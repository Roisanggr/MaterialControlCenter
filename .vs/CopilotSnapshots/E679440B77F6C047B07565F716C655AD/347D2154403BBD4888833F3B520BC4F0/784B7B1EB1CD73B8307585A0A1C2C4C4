        let docId = null;
        const urlGetSummary = '@Url.Action("GetScrapSummaryPerLeader", "ListOfData")';
        const urlGetScrapDetails = '@Url.Action("GetScrapPartsPaged", "ListOfData")';
        let currentApproval = null;
        let currentSourceDataID = null;
        let currentKpkList = [];
        let globalWatermarkText = "AWAITING APPROVER";
