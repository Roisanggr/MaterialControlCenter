                : '@Url.Action("TriggerApproval", "AutomateFlow")';

            const urlTrigger = baseUrl
                + "?approvalListId=" + currentApproval
                + "&status=" + status
                + "&sourceDataID=" + currentSourceDataID;

           const urlInsertDelegate = '@Url.Action("InsertDelegateApprovalRecord", "UpdateData")';

           const result = await showDynamicSwal({
               title: "Are you sure?",
               text: status == 3 ? "Do you want to reject this?" : "Do you want to approve this?",
               icon: "warning",
               confirmText: "Yes, Continue",
               cancelText: "Cancel"
           });

           if (!result.isConfirmed) return;

            Swal.fire({
                title: "Processing...",
                text: "Please wait. This process usually takes a few seconds, but may take up to 1 minute during gateway delays.",
                allowOutsideClick: false,
                didOpen: () => Swal.showLoading()
            });


           try {
               if (isDelegateActive && kpk !== originalApproverKpk) {
                   const insertRes = await $.post(urlInsertDelegate, {
                       approvalListId: currentApproval,
                       statusListId: status,
                       delegateKpk: kpk
                   });

                   if (!insertRes.success) {
                       Swal.close();
                       Swal.fire({
                           icon: "error",
                           title: "Delegate Insert Failed",
                           text: insertRes.message || "Failed to insert delegate record."
                       });
                       return;
                   }

               }
               const response = await $.get(urlTrigger);

               if (response.success) {

                   Swal.close();
                   if (response.flowStatus !== 200) {
                       await Swal.fire({
                           icon: "warning",
                           title: "Email Delivery Failed – Switched to Manual Approval",
                           text: "The system could not send the notification email to the next approver due to a gateway connection issue. The approval process is still continued using the manual approach.",
                       });

                   } else {
                       await Swal.fire({
                           icon: "success",
                           title: "Success",
                           text: response.message
                       });
                   }

                   await loadApprovalProgress(docId);
                   checkAndRenderApproveReject(docId);
               } else {
                   Swal.close();
                   Swal.fire({
                       icon: "error",
                       title: "Error",
                       text: response.message
                   });
               }
           } catch (err) {
               Swal.close();
               Swal.fire({
                   icon: "error",
                   title: "Request Failed",
                   text: "Something went wrong while sending the request."
               });
               console.error(err);
           }
        }

        async function downloadExcel() {
            if (!docId) return;

            try {
                const summaryRes = await $.get(urlGetSummary, { idScrap: docId });
                const detailRes = await $.get(urlGetScrapDetails, { idScrap: docId, page: 1, pageSize: 99999 });
                const summarySheetData = [
                    ["Document ID", docId],
                    ["Facility", summaryRes.Facility ?? "N/A"],
                    ["Created Date", formatDate(summaryRes.CreatedDate)],
                    ["Total", formatRupiah(summaryRes.TotalValueOverall)],
                    ["Quantity", summaryRes.TotalQtyOverall],
                    []
                ];
                const detailHeader = [
                    "Part Number",
                    "Description",
                    "Scrap Code",
                    "WC",
                    "TC",
                    "Special Code TcCompanion",
                    "RN",
                    "Leader",
                    "Quantity",
                    "Total",
                    "Remarks"
                ];

                const detailRows = detailRes.Data.map(part => [
                    part.PartNum,
                    part.Description,
                    summaryRes.AreaCode,
                    summaryRes.WC,
                    summaryRes.TC,
                    summaryRes.SpecialCodeTcCompanion || "N/A",
                    part.RnNumber || "N/A",
                    part.LeaderName,
                    part.Qty,
                    formatRupiah(part.Value),
                    part.Remarks
                ]);
                const ws = XLSX.utils.aoa_to_sheet([...summarySheetData, detailHeader, ...detailRows]);
                const headerRow = summarySheetData.length;
                const headerRange = XLSX.utils.decode_range(ws["!ref"]);

                for (let C = headerRange.s.c; C <= headerRange.e.c; ++C) {
                    const cellAddress = XLSX.utils.encode_cell({ r: headerRow, c: C });
                    if (ws[cellAddress]) {
                        ws[cellAddress].s = {
                            fill: { fgColor: { rgb: "1E90FF" } },
                            font: { bold: true, color: { rgb: "FFFFFF" } },
                            alignment: { horizontal: "center" }
                        };
                    }
                }
                const colWidths = [];
                const allRows = [...detailRows];
                allRows.unshift(detailHeader);
                for (let C = 0; C < detailHeader.length; C++) {
                    const maxLength = Math.max(...allRows.map(r => (r[C] ? r[C].toString().length : 0)));
                    colWidths.push({ wch: maxLength + 5 });
                }
                ws['!cols'] = colWidths;
                ws['!autofilter'] = {
                    ref: XLSX.utils.encode_range({
                        s: { r: headerRow, c: 0 },
                        e: { r: headerRow + detailRows.length, c: detailHeader.length - 1 }
                    })
                };
                const wb = XLSX.utils.book_new();
                XLSX.utils.book_append_sheet(wb, ws, "Scrap Report");
                XLSX.writeFile(wb, `ScrapDetails_${docId}.xlsx`);

            } catch (err) {
                console.error("Error exporting Excel:", err);
                Swal.fire("Error", "Failed to download Excel file.", "error");
            }
        }

        async function downloadPDF() {
            if (!docId) return;

            try {
                const summaryRes = await $.get(urlGetSummary, { idScrap: docId });
                const detailRes = await $.get(urlGetScrapDetails, {
                    idScrap: docId,
                    page: 1,
                    pageSize: 30
                });
                const { jsPDF } = window.jspdf;
                const doc = new jsPDF({ orientation: "landscape", unit: "mm", format: "a5" });
                const pageHeight = doc.internal.pageSize.getHeight();
                const pageWidth = doc.internal.pageSize.getWidth();
                const halfHeight = pageHeight / 2;
                const img = new Image();
                img.src = watermarkUrl;
                await new Promise(resolve => img.onload = resolve);
                doc.setGState(new doc.GState({ opacity: 0.1 }));
                doc.addImage(img, 'PNG', 0, 0, pageWidth, pageHeight);
                doc.setGState(new doc.GState({ opacity: 1 }));
                const drawScrapNotice = async (offsetY) => {
                    let y = offsetY;
                    doc.setFillColor(0, 51, 102);
                    const headerHeight = 10;
                    doc.rect(0, y, pageWidth, headerHeight, 'F');
                    const logoUrl = '@Url.Content("~/assets/images/mattel-logo.png")';
                    const logoImg = new Image();
                    logoImg.src = logoUrl;
                    await new Promise(resolve => logoImg.onload = resolve);
                    const logoMaxWidth = 12;
                    const logoAspect = logoImg.width / logoImg.height;
                    const logoWidth = logoMaxWidth;
                    const logoHeight = logoWidth / logoAspect;
                    const logoX = 10;
                    const logoY = y + (headerHeight - logoHeight) / 2;
                    doc.addImage(logoImg, 'PNG', logoX, logoY, logoWidth, logoHeight);
                    doc.setFontSize(10);
                    doc.setTextColor(255, 255, 255);
                    doc.setFont("helvetica", "bold");
                    const statusX = logoX + logoWidth + 5;
                    const statusY = logoY + logoHeight / 2 + 2;
                    doc.text(`${globalWatermarkText}`, statusX, statusY);
                    doc.setFontSize(12);
                    const headerText = `Scrap Notice - ${docId}`;
                    const textWidth = doc.getTextWidth(headerText);
                    doc.text(headerText, pageWidth - textWidth - 10, y + 7);
                    y += headerHeight + 5;
                    const infoX = 10;
                    const infoY = y;
                    const infoWidth = 90;
                    const infoHeight = 43;
                    doc.setGState(new doc.GState({ opacity: 0.3 }));
                    doc.setFillColor(255, 255, 255);
                    doc.rect(infoX, infoY, infoWidth, infoHeight, 'F');
                    doc.setGState(new doc.GState({ opacity: 1 }));
                    doc.setDrawColor(0);
                    doc.rect(infoX, infoY, infoWidth, infoHeight);
                    let infoTextY = infoY + 5;
                    doc.setFontSize(10);
                    const padding = 5;
                    doc.setFont("helvetica", "normal");
                    doc.setFontSize(10);
                    doc.setTextColor(0, 0, 0);
                    const colGap = 8;
                    const colW = (infoWidth - padding * 2 - colGap) / 2;
                    const leftX = infoX + padding;
                    const rightX = leftX + colW + colGap;

                    // Row 1
                    doc.text(`Total : ${formatRupiah(summaryRes.TotalValueOverall)}`, leftX, infoTextY);
                    doc.text(`Facility : ${summaryRes.Facility || "N/A"}`, rightX, infoTextY);
                    infoTextY += 7;

                    // Row 2
                    doc.text(`Scrap Code : ${summaryRes.AreaCode || "N/A"}`, leftX, infoTextY);
                    doc.text(`TC : ${summaryRes.TC || "N/A"}`, rightX, infoTextY);
                    infoTextY += 7;

                    // Row 3
                    doc.text(`Date : ${formatDateSimple(summaryRes.CreatedDate)}`, leftX, infoTextY);
                    doc.text(`TC Companion : ${summaryRes.SpecialCodeTcCompanion || "N/A"}`, rightX, infoTextY);
                    infoTextY += 7;

                    // Row 4
                    doc.text(`RN : ${summaryRes.RnNumber || "N/A"}`, leftX, infoTextY);
                    doc.text(`WC : ${summaryRes.WC || "N/A"}`, rightX, infoTextY);
                    infoTextY += 7;

                    // Row 5 (full width)
                    doc.text(`Initiator Name : ${summaryRes.InitiatorName || "N/A"}`, leftX, infoTextY);


                    const qrUrl = `http://ptmi-stage/ScrapNotice/ScrapRecords/DetailScrap?token=${token}`;
                    const qrDataUrl = await QRCode.toDataURL(qrUrl, { margin: 1, width: 100 });
                    const qrX = pageWidth - 50;
                    const qrY = infoY;
                    doc.addImage(qrDataUrl, 'PNG', qrX, qrY, 40, 40);
                    doc.setFontSize(8);
                    doc.setTextColor(0, 102, 204);
                    doc.text("Approved online in Scrap Notice System, no signature required.", qrX, qrY + 42, { maxWidth: 40 });
                    doc.setTextColor(0, 0, 0);
                };
                const drawDetailTable = async (startY) => {
                    let yBase = startY;

                    doc.setFontSize(9);
                    doc.setFont("helvetica", "bold");
                    const col1 = 10;
                    const col2 = 75;
                    const col3 = 140;
                    const qtyOffset = 25;
                    const valueOffset = 40;
                    doc.text("Part No", col1, yBase);
                    doc.text("Qty", col1 + qtyOffset, yBase);
                    doc.text("Commit", col1 + valueOffset, yBase);
                    doc.text("UM", col1 + valueOffset + 15, yBase);
                    doc.text("Part No", col2, yBase);
                    doc.text("Qty", col2 + qtyOffset, yBase);
                    doc.text("Commit", col2 + valueOffset, yBase);
                    doc.text("UM", col2 + valueOffset + 15, yBase);

                    doc.text("Part No", col3, yBase);
                    doc.text("Qty", col3 + qtyOffset, yBase);
                    doc.text("Commit", col3 + valueOffset, yBase);
                    doc.text("UM", col3 + valueOffset + 15, yBase);
                    doc.setDrawColor(180);
                    doc.setLineWidth(0.2);
                    const top = yBase - 3;
                    const bottom = yBase + 60;
                    doc.line(col1 - 5, top, col1 - 5, bottom);
                    doc.line(col1 + valueOffset + 20, top, col1 + valueOffset + 20, bottom);
                    doc.line(col2 - 5, top, col2 - 5, bottom);
                    doc.line(col2 + valueOffset + 20, top, col2 + valueOffset + 20, bottom);
                    doc.line(col3 - 5, top, col3 - 5, bottom);
                    doc.line(col3 + valueOffset + 20, top, col3 + valueOffset + 20, bottom);
                    doc.setFont("helvetica", "normal");
                    let rowHeight = 5;
                    let colCount = 0;
                    let rowIndex = 0;

                    detailRes.Data.forEach((part, i) => {
                        if (i >= 30) return;

                        let colX =
                            colCount === 0 ? col1 :
                                colCount === 1 ? col2 :
                                    col3;

                        let rowY = yBase + 5 + (rowIndex * rowHeight);

                        doc.text(part.PartNum.toString(), colX, rowY);
                        doc.text(String(part.Qty), colX + qtyOffset, rowY);
                        doc.text(part.Commit ?? "-", colX + valueOffset, rowY);
                        doc.text(part.Measit ?? "-", colX + valueOffset + 15, rowY);

                        rowIndex++;

                        if (rowIndex === 10) {
                            rowIndex = 0;
                            colCount++;
                        }
                    });
                };
                await drawScrapNotice(10);
                doc.setLineWidth(0.5);
                const dashLength = 2;
                const gap = 2;
                const yDash = halfHeight;
                for (let x = 0; x < pageWidth; x += dashLength + gap) {
                    doc.line(x, yDash, x + dashLength, yDash);
                }
                await drawDetailTable(halfHeight + 10);
                doc.save(`Scrap_${docId}.pdf`);

            } catch (err) {
                console.error("Error generating PDF:", err);
                Swal.fire("Error", "Failed to generate PDF.", "error");
            }
        }

        function openDisposalModal() {
            document.getElementById('modalAddDisposal').classList.remove('hidden');
            loadDisposalItems();
        }

        async function loadDisposalItems() {
            const select = document.getElementById("disposalSelect");
            select.innerHTML = '<option value="">-- Select Disposal --</option>';

            try {
                const response = await fetch('@Url.Action("GetAllDisposalItems", "ListOfData")');
                const result = await response.json();

                if (result.success && result.data.length > 0) {
                    result.data.forEach(item => {
                        const option = document.createElement("option");
                        option.value = item.Disposal_ID; // value = ID
                        option.textContent = `${item.Disposal_Code} - ${item.Disposal_Desc} - ${item.Disposal_Unit}`;
                        select.appendChild(option);
                    });
                }
            } catch (err) {
                console.error("Error loading disposal items:", err);
            }
        }

        function closeModal(modalId) {
            document.getElementById(modalId).classList.add('hidden');
        }

        async function saveDisposal() {
            const disposalData = {
                Scrap_ID: document.getElementById('documentID').textContent,
                Disposal_ID: parseInt(document.getElementById('disposalSelect').value),
                Disposal_Quantity: parseFloat(document.getElementById('disposalQty').value) || 0,
                Disposal_Remarks: document.getElementById('disposalRemarks').value,
                Disposal_In: document.getElementById('chkIn').checked,
                Disposal_Out: document.getElementById('chkOut').checked,
                Disposal_B3: document.getElementById('chkB3').checked,
                Disposal_NonB3: document.getElementById('chkNonB3').checked
            };
            try {
                const url = '@Url.Action("AddScrapDisposal", "DataForms")';

                const response = await fetch(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(disposalData)
                });

                const result = await response.json();

                if (result.success) {
                    closeModal('modalAddDisposal');
                    Swal.fire('Success', result.message, 'success');
                    loadScrapDisposals(docId);
                    checkAndRenderApproveReject(docId);
                } else {
                    Swal.fire('Error', result.message, 'error');
                }
            } catch (err) {
                console.error(err);
                Swal.fire('Error', 'Something went wrong', 'error');
            }
        }

        function loadScrapDisposals(scrapId) {
            $.ajax({
                url: '@Url.Action("GetScrapDisposalDetails", "ListOfData")',
                type: 'GET',
                data: { scrapId: scrapId },
                success: function(result) {
                    const tableBody = $("#disposalTable");
                    tableBody.empty();

                    if (result.success && result.data.length > 0) {
                        result.data.forEach(item => {
                            const row = `<tr>
                                <td>${item.Code || '-'}</td>
                                <td>${item.Description || '-'}</td>
                                <td>${item.Quantity ?? 0}</td>
                                <td>${item.Unit || '-'}</td>
                            </tr>`;
                            tableBody.append(row);
                        });
                    } else {
                        tableBody.append('<tr class="text-muted"><td colspan="4" class="text-center">No data available</td></tr>');
                    }
                },
                error: function(xhr, status, error) {
                    console.error("Error fetching scrap disposal details:", error);
                    $("#disposalTable").html('<tr class="text-muted"><td colspan="4" class="text-center">Error loading data</td></tr>');
                }
            });
        }

    </script>
