@{
    ViewBag.Title = "Material Control Center";
    ViewBag.pTitle = "MCC Code";
    ViewBag.xData = "change";
    ViewBag.ActiveItem = "ScrapCode";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<!-- Start All Card -->
<div class="flex flex-col gap-4 min-h-[calc(100vh-212px)]">
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-3">
        <div class="flex items-center justify-between gap-6 p-5 bg-white border rounded dark:bg-darklight dark:border-darkborder border-black/10">
            <div>
                <p class="text-base dark:text-white/80">Total Code </p>
                <h4 id="totalValueAll" class="flex items-center gap-4 mt-3 text-2xl font-semibold text-black dark:text-white">
                    <span class="skeleton w-12 h-6 bg-muted/50 animate-pulse rounded"></span>
                </h4>
                <p class="text-muted">Overall Total</p>
            </div>
            <div>
                <p class="text-base dark:text-white/80">P1</p>
                <h4 id="totalCodeP1" class="flex items-center gap-4 mt-3 text-2xl font-semibold text-black dark:text-white">
                    <span class="skeleton w-12 h-6 bg-muted/50 animate-pulse rounded"></span>
                </h4>
                <p class="text-muted">Code</p>
            </div>
        </div>
        <div class="flex items-center justify-between gap-6 p-5 bg-white border rounded dark:bg-darklight dark:border-darkborder border-black/10">
            <div>
                <p class="text-base dark:text-white/80">P2</p>
                <h4 id="totalCodeP2" class="flex items-center gap-4 mt-3 text-2xl font-semibold text-black dark:text-white">
                    <span class="skeleton w-12 h-6 bg-muted/50 animate-pulse rounded"></span>
                </h4>
                <p class="text-muted">Code</p>
            </div>
            <div>
                <p class="text-base dark:text-white/80">P2S3</p>
                <h4 id="totalCodeP2S3" class="flex items-center gap-4 mt-3 text-2xl font-semibold text-black dark:text-white">
                    <span class="skeleton w-12 h-6 bg-muted/50 animate-pulse rounded"></span>
                </h4>
                <p class="text-muted">Code</p>
            </div>

        </div>
        <div class="flex items-center justify-between gap-6 p-5 bg-white border rounded dark:bg-darklight dark:border-darkborder border-black/10">

            <div>
                <p class="text-base dark:text-white/80">P2S4</p>
                <h4 id="totalCodeP2S4" class="flex items-center gap-4 mt-3 text-2xl font-semibold text-black dark:text-white">
                    <span class="skeleton w-12 h-6 bg-muted/50 animate-pulse rounded"></span>
                </h4>
                <p class="text-muted">Code</p>
            </div>
            <div>
                <p class="text-base dark:text-white/80">P2S5</p>
                <h4 id="totalCodeP2S5" class="flex items-center gap-4 mt-3 text-2xl font-semibold text-black dark:text-white">
                    <span class="skeleton w-12 h-6 bg-muted/50 animate-pulse rounded"></span>
                </h4>
                <p class="text-muted">Code</p>
            </div>

        </div>
       


    </div>
    <div class="grid grid-cols-1 gap-4 md:grid-cols-1 xl:grid-cols-1">
        <div class="card">
            <div class="flex items-center gap-3 mb-4">
                <h2 class="text-base font-semibold text-black capitalize dark:text-white/80 grow">List Code</h2>
                <a href="#" id="filtersScrapNotice" class="px-3 py-1.5 rounded-md text-xs border border-black/20 dark:border-darkborder text-muted"><i class="align-bottom ltr:mr-1 rtl:ml-1 ri-filter-line"></i> Filters</a>
            </div>
            <div id="filterList" class="flex flex-wrap gap-4 justify-between hidden">
                <!-- Card 1 -->
                <div class="card flex-1 basis-1/4 min-w-[200px] p-3">
                    <h2 class="mb-2 text-sm font-semibold text-black capitalize dark:text-white/80">Scrap Code</h2>
                    <form class="space-y-2">
                        <div class="space-y-1">
                            <input id="scrapCodeFilter" type="text" class="form-input w-full text-sm p-2" placeholder="Scrap Code">
                        </div>
                    </form>
                </div>

                <!-- Card 2 -->
                <div class="card flex-1 basis-1/4 min-w-[200px] p-3">
                    <h2 class="mb-2 text-sm font-semibold text-black capitalize dark:text-white/80">Location</h2>
                    <form class="space-y-2">
                        <div class="space-y-1">
                            <input id="scrapLocationFilter" type="text" class="form-input w-full text-sm p-2" placeholder="Location">
                        </div>
                    </form>
                </div>
                <div class="flex w-full justify-end gap-2 mt-2">
                    <!-- Apply Filters icon -->
                    <button id="applyFiltersButton"
                            class="px-2 py-1 bg-success text-white rounded shadow hover:bg-success/[0.85] transition flex items-center justify-center text-sm mb-2">
                        <i class="ri-check-line text-sm mr-1"></i>
                        Apply
                    </button>

                    <!-- Reset Filters icon -->
                    <button id="resetFiltersButton"
                            class="px-2 py-1 bg-danger text-white rounded shadow hover:bg-danger/[0.85] transition flex items-center justify-center text-sm mb-2">
                        <i class="ri-refresh-line text-sm mr-1"></i>
                        Reset
                    </button>
                </div>



            </div>
            <div class="flex justify-end">
                <button type="button" id="addRemarksButton" class="btn bg-purple border-purple text-white hover:bg-purple/[0.85] hover:border-purple/[0.85] mb-2">
                <i class="fas fa-plus mr-2"></i> Add Code
                </button>
            </div>
            <div class="overflow-auto">
                <table class="min-w-[640px] w-full">
                    <thead>
                        <tr class="text-black text-left">
                            <th class="px-3 py-2">ID</th>
                            <th class="px-3 py-2">Application</th>
                            <th class="px-3 py-2">Code</th>
                            <th class="px-3 py-2">Description</th>
                            <th class="px-3 py-2">Location</th>
                            <th class="px-3 py-2">Action</th>
                        </tr>
                    </thead>
                    <tbody id="listOfScrap">
                        <tr class="text-muted">
                            <td colspan="3" class="py-6 text-center">
                                <div class="flex justify-center items-center gap-2">
                                    <div class="animate-spin inline-block size-8 border-[3px] border-l-transparent border-muted rounded-full"></div>
                                    <span>Loading...</span>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

    </div>

    <div>
        <ul id="buttonPagination" class="inline-flex items-center gap-1 m-auto mb-4">
        </ul>
    </div>
</div>
<!-- End All Card -->

<div id="addRemarksModals" class="fixed inset-0 bg-black/80 z-[99999] hidden overflow-y-auto">
    <div class="flex items-start justify-center min-h-screen px-4" onclick="closeModalsRemarks(event)">
        <div class="relative w-full max-w-lg p-0 my-8 overflow-hidden bg-white border rounded-xl shadow-lg border-black/10"
             onclick="event.stopPropagation()">
            <!-- Header -->
            <div class="flex items-center justify-between px-5 py-3 bg-white border-b border-black/10">
                <h5 class="text-lg font-semibold">Add New Code</h5>
                <button type="button" class="text-black hover:bg-danger/[0.85]" onclick="closeModalsRemarks()">
                    ✕
                </button>
            </div>

            <!-- Body -->
            <div class="p-5 space-y-5">


                <!-- Facilities & TC (Side by Side) -->
                <div id="addFacilityCheckboxes" class="grid grid-flow-col auto-cols-max gap-4 overflow-x-auto">
                    <!-- Checkbox facility diinject dari JS -->
                </div>
                <!-- Role -->
                <div>
                    <p class="mb-2 text-sm font-semibold">Application Code</p>
                    <select id="inputApplication" class="form-input w-full" required>
                        <option value="" disabled selected>Select Application</option>
                        <option value="SCRAP">Scrap</option>
                        <option value="PIA">PIA</option>
                        <option value="TPR">TPR</option>
                    </select>
                </div>
                <div id="areaContainer" style="display: none;">
                    <p class="mb-2 text-sm font-semibold">Area</p>
                    <input id="inputArea" type="text" class="form-input" placeholder="Enter New Area">
                </div>
                <div>
                    <p class="mb-2 text-sm font-semibold">Code</p>
                    <input id="inputCode" type="text" class="form-input" placeholder="Enter New Code" required>
                </div>
                <div>
                    <p class="mb-2 text-sm font-semibold">Description</p>
                    <input id="inputDescription" type="text" class="form-input" placeholder="Enter Description Code" required>
                </div>


                <!-- Action buttons -->
                <div class="flex items-center justify-end gap-3">
                    <button type="button" class="btn bg-danger border-danger text-white hover:bg-danger/[0.85]"
                            onclick="closeModalsRemarks()">
                        Discard
                    </button>
                    <button type="button"
                            id="saveAddUser"
                            class="btn bg-purple border-purple text-white hover:bg-purple/[0.85]">
                        Save
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>


@section scripts{


    <script src="~/assets/js/main.js"></script>

    <script>

        const urlDeleteScrapCode = '@Url.Action("DeleteScrapCode", "DataForms")';


        $(document).ready(function () {
            loadData(1, pageSize);
            loadScrapCodeSummaryTotal();

        });
       async function loadData(pageNumber = 1, pageSize = 10) {
            currentPage = pageNumber;
            const tbody = document.getElementById("listOfScrap");
            const scrapCode = document.getElementById("scrapCodeFilter")?.value || "";
            const location = document.getElementById("scrapLocationFilter")?.value || "";

            tbody.innerHTML = `
                <tr>
                    <td colspan="5" class="py-6 text-center">
                        <div class="flex justify-center items-center gap-2">
                            <div class="animate-spin inline-block size-8 border-[3px] border-l-transparent border-purple rounded-full"></div>
                            <span>Loading data...</span>
                        </div>
                    </td>
                </tr>
            `;

            try {
                const res = await fetch(
                    `@Url.Action("GetAllScrapCode", "DataForms")?pageNumber=${pageNumber}&pageSize=${pageSize}&scrapCode=${encodeURIComponent(scrapCode)}&location=${encodeURIComponent(location)}`
                );
                const result = await res.json();

                if (!result.success || !Array.isArray(result.data)) {
                    tbody.innerHTML = `<tr><td colspan="5" class="text-center text-red-500 py-4">❌ Failed to load data.</td></tr>`;
                    return;
                }

                const pagedData = result.data;
                const totalCount = result.totalCount;

                if (pagedData.length === 0) {
                    tbody.innerHTML = `<tr><td colspan="5" class="text-center text-gray-500 py-4">No data found.</td></tr>`;
                    renderPagination(totalCount, pageNumber, pageSize);
                    return;
                }

                tbody.innerHTML = pagedData.map(r => `
                    <tr class="border-b border-gray-200 hover:bg-gray-50 transition">
                        <td class="px-3 py-2">${r.IdRemarks ?? "-"}</td>
                        <td class="px-3 py-2">${r.Location ?? "-"}</td>
                        <td class="px-3 py-2 font-semibold text-purple">${r.Code ?? "-"}</td>
                        <td class="px-3 py-2">${r.Name ?? "-"}</td>
                        <td class="px-3 py-2">
                            <button type="button"
                                class="btn bg-danger border-danger text-white hover:bg-danger/[0.85] hover:border-danger/[0.85] flex items-center justify-center gap-2 px-3 py-1 rounded"
                                onclick="deleteRemark(${r.IdRemarks ?? 0})">
                                <i class="fas fa-trash-alt"></i>
                                <span>Delete</span>
                            </button>
                        </td>
                    </tr>
                `).join("");

                renderPagination(totalCount, pageNumber, pageSize);

            } catch (error) {
                console.error("Error loading scrap codes:", error);
                tbody.innerHTML = `<tr><td colspan="5" class="text-center text-red-500 py-4">Error loading data.</td></tr>`;
            }
       }

        const addRemarksButton = document.getElementById("addRemarksButton");
        if (addRemarksButton) {
            addRemarksButton.addEventListener("click", () => {
                const facilityContainer = document.getElementById("addFacilityCheckboxes");
                if (facilityContainer) {
                    facilityContainer.innerHTML = facilities.map(fac => `
                    <label class="inline-flex items-center gap-2 cursor-pointer">
                        <input type="checkbox" value="${fac}" class="form-checkbox text-purple addFacilityCb"/>
                        <span>${fac}</span>
                    </label>
                `).join("");

                }
                const scrapContainer = document.getElementById("addUserScrapCodeResponsible");
                if (scrapContainer) {
                    scrapContainer.innerHTML = `
                        <div class="sm:col-span-2 md:col-span-4 text-gray-500 text-sm flex justify-center items-center py-6">
                            Select facility to codes...
                        </div>
                    `;

                }
                const modal = document.getElementById("addRemarksModals");
                if (modal) {
                    modal.classList.remove("hidden");
                }
            });
        }
        filterButton.addEventListener('click', function (e) {
            e.preventDefault();
            filterList.classList.toggle('hidden');
        });
        function closeModalsRemarks(event) {
    const modal = document.getElementById("addRemarksModals");
    if (!modal) return;

    if (!event || event.target.id === "addRemarksModals") {
        modal.classList.add("hidden");

        const appSelect = document.getElementById("inputApplication");
        const areaInput = document.getElementById("inputArea");
        const codeInput = document.getElementById("inputCode");
        const descInput = document.getElementById("inputDescription");
        const areaContainer = document.getElementById("areaContainer");

        if (appSelect) appSelect.value = "";
        if (areaInput) {
            areaInput.value = "";
            areaInput.removeAttribute("required");
        }
        if (codeInput) codeInput.value = "";
        if (descInput) descInput.value = "";
        if (areaContainer) areaContainer.style.display = "none";

        document.querySelectorAll(".addFacilityCb").forEach(cb => cb.checked = false);
    }
}

        let isSavingCode = false;

        document.getElementById("saveAddUser").addEventListener("click", async function () {
            if (isSavingCode) return;

            const saveButton = document.getElementById("saveAddUser");
            const application = (document.getElementById("inputApplication")?.value || "").trim();
            const code = (document.getElementById("inputCode")?.value || "").trim();
            const description = (document.getElementById("inputDescription")?.value || "").trim();
            const area = (document.getElementById("inputArea")?.value || "").trim();

            const checkedFacilities = Array.from(document.querySelectorAll(".addFacilityCb:checked"))
                .map(cb => cb.value);

            if (!application) {
                Swal.fire({
                    icon: "warning",
                    title: "Validation",
                    text: "Please select Application first."
                });
                return;
            }

            if (checkedFacilities.length === 0) {
                Swal.fire({
                    icon: "warning",
                    title: "Validation",
                    text: "Please select at least one Facility."
                });
                return;
            }

            if (!code) {
                Swal.fire({
                    icon: "warning",
                    title: "Validation",
                    text: "Code is required."
                });
                return;
            }

            if (!description) {
                Swal.fire({
                    icon: "warning",
                    title: "Validation",
                    text: "Description is required."
                });
                return;
            }

            if (application === "PIA" && !area) {
                Swal.fire({
                    icon: "warning",
                    title: "Validation",
                    text: "Area is required for PIA."
                });
                return;
            }

            const confirmation = await Swal.fire({
                title: "Confirm Save",
                text: `Do you want to save this ${application} code?`,
                icon: "question",
                showCancelButton: true,
                confirmButtonText: "Yes, Save",
                cancelButtonText: "Cancel"
            });

            if (!confirmation.isConfirmed) return;

            const mappedLocations = checkedFacilities.map(fac => {
                switch (fac) {
                    case "P1": return "MIDC";
                    case "P2": return "Fashion Dolls";
                    default: return fac;
                }
            });

            const payload = {
                Application: application,
                Facility: checkedFacilities.join(", "),
                Area: application === "PIA" ? area : "",
                Code: code,
                Description: description,
                Name: description,
                Location: mappedLocations.join(", ")
            };

            try {
                isSavingCode = true;
                if (saveButton) saveButton.disabled = true;

                Swal.fire({
                    title: "Saving Data...",
                    text: "Please wait, data is being submitted.",
                    allowOutsideClick: false,
                    allowEscapeKey: false,
                    didOpen: () => {
                        Swal.showLoading();
                    }
                });

                const res = await fetch("@Url.Action("SubmitScrapCode", "DataForms")", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify(payload)
                });

                const result = await res.json();
                Swal.close();

                if (result.success) {
                    closeModalsRemarks();
                    Swal.fire({
                        icon: "success",
                        title: "Success!",
                        text: `${application} Code has been saved successfully.`,
                        timer: 2000,
                        showConfirmButton: false
                    }).then(() => {
                        loadData();
                    });
                } else {
                    Swal.fire({
                        icon: "error",
                        title: "Failed!",
                        text: result.message || "Failed to save data."
                    });
                }
            } catch (err) {
                Swal.close();
                console.error("Error submitting data:", err);
                Swal.fire({
                    icon: "error",
                    title: "Error",
                    text: "An error occurred while saving. Please try again."
                });
            } finally {
                isSavingCode = false;
                if (saveButton) saveButton.disabled = false;
            }
        });

        const applicationSelect = document.getElementById("inputApplication");
        if (applicationSelect) {
            applicationSelect.addEventListener("change", function () {
                const areaContainer = document.getElementById("areaContainer");
                const inputArea = document.getElementById("inputArea");

                if (!areaContainer || !inputArea) return;

                if (this.value === "PIA") {
                    areaContainer.style.display = "block";
                    inputArea.setAttribute("required", "required");
                } else {
                    areaContainer.style.display = "none";
                    inputArea.removeAttribute("required");
                    inputArea.value = "";
                }
            });
        }
    </script>
}
