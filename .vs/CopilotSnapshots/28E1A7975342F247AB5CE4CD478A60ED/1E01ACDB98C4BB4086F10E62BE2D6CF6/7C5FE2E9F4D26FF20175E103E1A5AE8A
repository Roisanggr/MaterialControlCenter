    function drawPageWatermark(doc, watermarkImg) {

        const pageW = doc.internal.pageSize.getWidth();
        const pageH = doc.internal.pageSize.getHeight();

        doc.setGState(new doc.GState({ opacity: 0.08 }));

        const wmW = pageW * 0.85;
        const wmH = (watermarkImg.height / watermarkImg.width) * wmW;

        doc.addImage(
            watermarkImg,
            "PNG",
            (pageW - wmW) / 2,
            (pageH - wmH) / 2,
            wmW,
            wmH
        );

        doc.setGState(new doc.GState({ opacity: 1 }));
    }

    async function downloadPDFMultiple() {

        if (!selectedPdfDocIds.length) {
            Swal.fire("Warning", "Select at least 1 document", "warning");
            return;
        }

        $("#pdfFilterForm").addClass("hidden");

        Swal.fire({
            title: "Generating PDF",
            text: "Please wait…",
            allowOutsideClick: false,
            allowEscapeKey: false,
            didOpen: () => Swal.showLoading()
        });

        await new Promise(resolve => setTimeout(resolve, 50));

        try {

            const { jsPDF } = window.jspdf;

            const doc = new jsPDF({
                orientation: "landscape",
                unit: "mm",
                format: "a4"
            });
            const pageW = doc.internal.pageSize.getWidth();
            const pageH = doc.internal.pageSize.getHeight();
            const qrColW   = pageW * 0.15;
            const contentW = pageW - qrColW;
            const blockW = contentW / 2;
            const blockH = pageH / 2;

            const qrColumnX = contentW;
            const [logoImg, watermarkImg] = await Promise.all([
                loadImage('@Url.Content("~/assets/images/mattel-logo.png")'),
                loadImage(watermarkUrl)
            ]);
            const requests = selectedPdfDocIds.map(id =>
                $.get(urlGetSourceDataScrap, {
                    documentId: id,
                    pageNumber: 1,
                    pageSize: 1
                })
            );

            const results = await Promise.all(requests);
            let index = 0;

            for (let i = 0; i < results.length; i++) {

                if (index === 0) {

                    if (i > 0) doc.addPage();

                    drawPageWatermark(doc, watermarkImg);
                    await drawQrColumn(
                        doc,
                        selectedPdfDocIds,
                        i,
                        qrColumnX,
                        pageH
                    );
                }

                const item = results[i].Data?.[0];
                if (!item) continue;

                const col = index % 2;
                const row = Math.floor(index / 2);

                const offsetX = col * blockW;
                const offsetY = row * blockH;

                await drawSingleScrapNotice(
                    doc,
                    selectedPdfDocIds[i],
                    item,
                    offsetX,
                    offsetY,
                    blockW,
                    blockH,
                    logoImg,
                    watermarkImg
                );

                index++;
                if (index === 4) index = 0;
            }

            doc.save(`Scrap_${Date.now()}.pdf`);
            resetPdfForm();
            Swal.close();

        } catch (err) {

            console.error(err);
            Swal.fire("Error", err.message, "error");

        }
    }

    async function drawQrColumn(doc, docIds, startIndex, qrColumnX, pageH) {

        const colWidth = 60;
        const qrSize = 22;
        const spacing = 6;
        let y = 8;

        const headerH = 8;
        for (let i = 0; i < 4; i++) {

            const idx = startIndex + i;
            if (!docIds[idx]) break;

            const docId = docIds[idx];
            const scrapHeaderH = 6;

            doc.setFillColor(0, 51, 102);
            doc.rect(
                qrColumnX + 3,
                y - 4,
                colWidth - 6,
                scrapHeaderH,
                "F"
            );

            doc.setFont("helvetica", "bold");
            doc.setFontSize(7);
            doc.setTextColor(255);

            doc.text(
                `Scrap Notice - ${docId}`,
                qrColumnX + colWidth / 2,
                y,
                { align: "center" }
            );
            doc.setTextColor(0);
            y += scrapHeaderH + 1;
            const qrImg = await QRCode.toDataURL(
                `http://ptmi-stage/ScrapNotice/ScrapRecords/DetailScrap?token=${btoa(docId)}`,
                { width: 80 }
            );

            doc.addImage(
                qrImg,
                "PNG",
                qrColumnX + (colWidth - qrSize) / 2,
                y,
                qrSize,
                qrSize
            );

            y += qrSize + 2;
            doc.setFont("helvetica", "normal");
            doc.setFontSize(7);
            doc.setTextColor(0, 102, 204);

            doc.text(
                "Approved online\nNo signature required",
                qrColumnX + colWidth / 2,
                y,
                {
                    align: "center",
                    lineHeightFactor: 1.05,
                    maxWidth: colWidth - 6
                }
            );

            doc.setTextColor(0);

            y += 9;
            doc.setDrawColor(170);
            doc.setLineWidth(0.3);
            doc.setLineDash([2, 2]);

            doc.line(
                qrColumnX + 4,
                y,
                qrColumnX + colWidth - 4,
                y
            );

            doc.setLineDash([]);

            y += spacing;
        }
    }

    async function drawSingleScrapNotice(
        doc,
        docId,
        item,
        offsetX,
        offsetY,
        w,
        h,
        logoImg,
        watermarkImg
    ) {
        const padding = 5;

        // Outer border
        doc.setDrawColor(160);
        doc.setLineWidth(0.3);
        doc.rect(offsetX, offsetY, w, h);

        const y = offsetY + padding;
        const headerH = 8;

        // Header background
        doc.setFillColor(0, 51, 102);
        doc.rect(offsetX, y, w, headerH, "F");

        // Logo
        const logoW = 10;
        const logoH = (logoImg.height / logoImg.width) * logoW;
        doc.addImage(
            logoImg,
            "PNG",
            offsetX + 4,
            y + (headerH - logoH) / 2,
            logoW,
            logoH
        );

        // Header text
        doc.setTextColor(255);
        doc.setFont("helvetica", "bold");
        doc.setFontSize(8);
        doc.text("STORE APPROVAL", offsetX + 20, y + 5);

        const title = `Scrap Notice - ${docId}`;
        doc.text(
            title,
            offsetX + w - doc.getTextWidth(title) - 5,
            y + 5
        );

        const sy = y + headerH + 4;
        const boxW = w - 60;
        const boxH = 28;

        doc.setDrawColor(0);
        doc.rect(offsetX + padding, sy, boxW, boxH);
        doc.setTextColor(0);
        doc.setFont("helvetica", "normal");
        doc.setFontSize(8);
        const colGap = 6;
        const colW = (boxW - colGap) / 2;
        const leftX = offsetX + padding + 3;
        const rightX = leftX + colW + colGap;

        let ty = sy + 5;

        // Row 1
        doc.text(`Total : ${formatRupiah(item.TotalValue)}`, leftX, ty);
        doc.text(`Facility : ${item.Facility || "-"}`, rightX, ty);
        ty += 5;

        // Row 2
        doc.text(`Scrap Code : ${item.ScrapCode || "-"}`, leftX, ty);
        doc.text(`TC : ${item.TC || "-"}`, rightX, ty);
        ty += 5;

        // Row 3
        doc.text(`Date : ${formatDateSimple(item.CreatedDate)}`, leftX, ty);
        doc.text(`TC Companion : ${item.SpecialCodeTcCompanion || "-"}`, rightX, ty);
        ty += 5;
        doc.text(`WC : ${item.WC || "-"}`, rightX, ty);
        ty += 5;
        // Row 4 (full width)
        doc.text(`Initiator : ${item.InitiatorName || "-"}`, leftX, ty);



        // QR Code
        const qrImg = await QRCode.toDataURL(
            `http://ptmi-stage/ScrapNotice/ScrapRecords/DetailScrap?token=${btoa(docId)}`,
            { width: 80 }
        );

        const qrSize = 26;
        const qrX = offsetX + w - qrSize - 6;
        const qrY = sy;

        doc.addImage(qrImg, "PNG", qrX, qrY, qrSize, qrSize);

        doc.setFontSize(7);
        doc.setTextColor(0, 102, 204);
        doc.text(
            "Approved online\nno signature required",
            qrX,
            qrY + qrSize + 1.2,
            { maxWidth: qrSize, lineHeightFactor: 0.9 }
        );

        // Divider line
        const tableStartY = Math.max(sy + boxH + 10, qrY + qrSize + 12);
        const cutLineY = tableStartY - 4;

        doc.setDrawColor(180);
        doc.setLineWidth(0.2);
        doc.setLineDash([2, 2]);
        doc.line(
            offsetX + padding,
            cutLineY,
            offsetX + w - padding,
            cutLineY
        );
        doc.setLineDash([]);
        doc.setTextColor(0);

        // Detail table
        drawDetailTableInsideBlock(
            doc,
            item.ScrapParts || [],
            offsetX,
            tableStartY,
            w,
            h
        );
    }


    function drawDetailTableInsideBlock(
        doc,
        scrapParts,
        offsetX,
        startY,
        w,
        h
    ) {
        if (!scrapParts.length) return;

        const padding = 5;

        const usableW = w - padding * 2;
        const colWidth = usableW / 3;
        const colX = [
            offsetX + padding,
            offsetX + padding + colWidth,
            offsetX + padding + colWidth * 2
        ];
        const partColW = colWidth * 0.45;
        const qtyColW = colWidth * 0.18;
        const commitColW = colWidth * 0.22;
        const umColW = colWidth * 0.15;
        const partX = 0;
        const qtyX = partColW;
        const commitX = partColW + qtyColW;
        const umX = partColW + qtyColW + commitColW;
        doc.setFont("helvetica", "bold");
        doc.setFontSize(7);

        colX.forEach(x => {
            doc.text("Part No", x + partX, startY);
            doc.text("Qty", x + qtyX + qtyColW / 2, startY, { align: "center" });
            doc.text("Commit", x + commitX + commitColW / 2, startY, { align: "center" });
            doc.text("UM", x + umX + umColW / 2, startY, { align: "center" });
        });
        doc.setFont("helvetica", "normal");
        doc.setFontSize(6);

        const rowHeight = 4;
        const maxRows = 10;

        let col = 0;
        let row = 0;

        for (let part of scrapParts) {

            if (col > 2) break;

            const x = colX[col];
            const y = startY + 7 + row * rowHeight;
            doc.text(
                String(part.PartNum || "-"),
                x + partX,
                y,
                {
                    maxWidth: partColW - 1,
                    lineHeightFactor: 1
                }
            );
            doc.text(
                String(part.Qty || "0"),
                x + qtyX + qtyColW / 2,
                y,
                { align: "center" }
            );

            doc.text(
                String(part.Commit || "-"),
                x + commitX + commitColW / 2,
                y,
                { align: "center" }
            );

            doc.text(
                String(part.Measit || "-"),
                x + umX + umColW / 2,
                y,
                { align: "center" }
            );

            row++;

            if (row >= maxRows) {
                row = 0;
                col++;
            }
        }
    }



