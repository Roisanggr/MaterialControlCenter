                    // Download functions
                    function extractServerMessage(text, fallbackMessage) {
                        if (!text) return fallbackMessage;
                        const cleanText = text
                            .replace(/<[^>]*>/g, " ")
                            .replace(/\s+/g, " ")
                            .trim();

                        if (!cleanText) return fallbackMessage;
                        return cleanText.length > 220
                            ? fallbackMessage
                            : cleanText;
                    }

                    function getFileNameFromDisposition(contentDisposition, fallbackName) {
                        if (!contentDisposition) return fallbackName;

                        const utfMatch = contentDisposition.match(/filename\*=UTF-8''([^;]+)/i);
                        if (utfMatch && utfMatch[1]) {
                            try {
                                return decodeURIComponent(utfMatch[1]);
                            } catch (e) {
                            }
                        }

                        const normalMatch = contentDisposition.match(/filename[^;=\n]*=((['"]).*?\2|[^;\n]*)/i);
                        if (normalMatch && normalMatch[1]) {
                            return normalMatch[1].replace(/['"]/g, "").trim();
                        }

                        return fallbackName;
                    }

                    async function downloadExcelFromUrl(url, fallbackName) {
                        const response = await fetch(url, {
                            method: "GET",
                            cache: "no-store",
                            credentials: "same-origin"
                        });

                        if (!response.ok) {
                            let errorMessage = "Failed to download the report. Please try again.";
                            try {
                                const errorText = await response.text();
                                errorMessage = extractServerMessage(errorText, errorMessage);
                            } catch (e) {
                            }
                            throw new Error(errorMessage);
                        }

                        const contentType = (response.headers.get("Content-Type") || "").toLowerCase();
                        const isExcelContent = contentType.indexOf("application/vnd.openxmlformats-officedocument.spreadsheetml.sheet") >= 0
                            || contentType.indexOf("application/octet-stream") >= 0;

                        if (!isExcelContent) {
                            const responseText = await response.text();
                            throw new Error(extractServerMessage(responseText, "Invalid file format received from server."));
                        }

                        const blob = await response.blob();
                        if (!blob || blob.size === 0) {
                            throw new Error("No data available for the selected criteria.");
                        }

                        const contentDisposition = response.headers.get("Content-Disposition");
                        const filename = getFileNameFromDisposition(contentDisposition, fallbackName);

                        const downloadUrl = window.URL.createObjectURL(blob);
                        const a = document.createElement("a");
                        a.style.display = "none";
                        a.href = downloadUrl;
                        a.download = filename;
                        document.body.appendChild(a);
                        a.click();
                        window.URL.revokeObjectURL(downloadUrl);
                        document.body.removeChild(a);
                    }

                    async function downloadWeeklyReport(weekNum) {
                        const now = new Date();
                        const year = now.getFullYear();
                        const month = now.getMonth(); // 0-based (0 = January)
                        const monthDisplay = month + 1; // 1-based for display

                        // Logika week berdasarkan tanggal dalam bulan
                        // W1: 1-7, W2: 8-14, W3: 15-21, W4: 22-28, W5: 29-31
                        let startDay, endDay;

                        if (weekNum === 1) {
                            startDay = 1;
                            endDay = 7;
                        } else if (weekNum === 2) {
                            startDay = 8;
                            endDay = 14;
                        } else if (weekNum === 3) {
                            startDay = 15;
                            endDay = 21;
                        } else if (weekNum === 4) {
                            startDay = 22;
                            endDay = 28;
                        } else if (weekNum === 5) {
                            startDay = 29;
                            const lastDay = new Date(year, month + 1, 0);
                            endDay = lastDay.getDate(); // 29, 30, atau 31
                        }

                        const startDate = new Date(year, month, startDay);
                        const endDate = new Date(year, month, endDay);

                        Swal.fire({
                            title: "Preparing Weekly Report...",
                            text: `Generating Week ${weekNum} report (${startDay}-${endDay})`,
                            allowOutsideClick: false,
                            allowEscapeKey: false,
                            didOpen: () => Swal.showLoading()
                        });

                        const url = '@Url.Action("DownloadScrapReport", "DataReporting")'
                            + `?type=weekly&week=${weekNum}`
                            + `&year=${year}`
                            + `&month=${monthDisplay}`
                            + `&startDate=${startDate.toISOString().split('T')[0]}`
                            + `&endDate=${endDate.toISOString().split('T')[0]}`;

                        try {
                            const fallbackName = `ScrapReport_${year}-${String(monthDisplay).padStart(2, '0')}-W${weekNum}.xlsx`;
                            await downloadExcelFromUrl(url, fallbackName);

                            Swal.close();

                            Swal.fire({
                                icon: 'success',
                                title: 'Download Complete!',
                                text: `Your weekly report (W${weekNum}) has been downloaded successfully.`,
                                timer: 2000,
                                showConfirmButton: false
                            });
                        } catch (error) {
                            console.error('Download error:', error);
                            Swal.fire({
                                icon: 'error',
                                title: 'Download Failed',
                                text: error.message || 'Failed to download the report. Please try again.'
                            });
                        }
                    }

