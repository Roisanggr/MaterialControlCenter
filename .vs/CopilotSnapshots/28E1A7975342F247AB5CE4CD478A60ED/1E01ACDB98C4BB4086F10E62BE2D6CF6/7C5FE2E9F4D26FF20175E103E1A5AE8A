    function formatRupiah(num) {
        if (!num || isNaN(num)) return "Rp 0,00";
        return new Intl.NumberFormat("id-ID", {
            style: "currency",
            currency: "IDR",
            minimumFractionDigits: 2
        }).format(num);
    }
    function formatRupiahShort(num) {
        if (!num || isNaN(num)) return "Rp 0";

        const thresholds = [
            { value: 1_000_000_000_000, suffix: " Trillion" },
            { value: 1_000_000_000, suffix: " Billion" },
            { value: 1_000_000, suffix: " Million" }
        ];

        const absNum = Math.abs(num);
        const threshold = thresholds.find(t => absNum >= t.value);

        let result;
        if (threshold) {
            result = (num / threshold.value)
                .toFixed(1)
                .replace('.', ',') + threshold.suffix;
        } else {
            result = new Intl.NumberFormat("id-ID", {
                maximumFractionDigits: 0
            }).format(num);
        }
        return "Rp " + result;
    }


