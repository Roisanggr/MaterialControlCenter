                    async function downloadYearlyReport() {
                        // Get values from inputs
                        const dateFrom = document.getElementById("yearlyDateFrom").value;
                        const dateTo = document.getElementById("yearlyDateTo").value;
                        const status = document.getElementById("yearlyStatusSelect").value;

                        // Validation
                        if (!dateFrom || !dateTo) {
                            Swal.fire({
                                icon: "warning",
                                title: "No Data",
                                text: "Please select date range"
                            });
                            return;
                        }

                        const start = new Date(dateFrom);
                        const end = new Date(dateTo);

                        // Check if start date is greater than end date
                        if (start > end) {
                            Swal.fire({
                                icon: "warning",
                                title: "Invalid Date Range",
                                text: "Start date must be before or equal to end date"
                            });
                            return;
                        }

                        // Optional: Check if date range is too large (e.g., more than 1 year)
                        const daysDiff = Math.ceil((end - start) / (1000 * 60 * 60 * 24));
                        if (daysDiff > 365) {
                            Swal.fire({
                                icon: "warning",
                                title: "Date Range Too Large",
                                text: "Please select a date range within 1 year",
                                confirmButtonText: "OK"
                            });
                            return;
                        }

                        // Get status text for display
                        const statusSelect = document.getElementById("yearlyStatusSelect");
                        const statusText = status ? statusSelect.options[statusSelect.selectedIndex].text : "All Status";

                        Swal.fire({
                            title: "Preparing Yearly Report...",
