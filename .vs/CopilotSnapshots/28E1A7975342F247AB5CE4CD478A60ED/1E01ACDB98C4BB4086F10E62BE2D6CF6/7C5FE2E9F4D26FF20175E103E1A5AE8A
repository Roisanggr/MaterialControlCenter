    function formatDate(dotNetDate) {
        if (!dotNetDate) return "-";
        const timestamp = parseInt(dotNetDate.replace(/[^0-9]/g, ""), 10);
        const date = new Date(timestamp);

        const options = {
            year: 'numeric',
            month: 'long',
            day: '2-digit',
            hour: '2-digit',
            minute: '2-digit'
        };
        return date.toLocaleDateString("en-US", options).replace(",", "");
    }
    function parseDotNetDate(dotNetDate) {
        if (!dotNetDate) return null;
        const match = /\/Date\((\d+)\)\//.exec(dotNetDate);
        if (!match) return null;
        return new Date(parseInt(match[1], 10));
    }
    function formatDateSimple(dotNetDate) {
        if (!dotNetDate) return "-";

        const timestamp = parseInt(dotNetDate.replace(/[^0-9]/g, ""), 10);
        const d = new Date(timestamp);

        const day = String(d.getDate()).padStart(2, "0");
        const month = String(d.getMonth() + 1).padStart(2, "0");
        const year = d.getFullYear();

        return `${day}-${month}-${year}`;
    }

    function parseDotNetDateChart(dotNetDate) {
        if (!dotNetDate) return null;
        const match = /\/Date\((\d+)\)\//.exec(dotNetDate);
        if (match) {
            return new Date(parseInt(match[1], 10));
        }
        const parsed = new Date(dotNetDate);
        if (isNaN(parsed.getTime())) {
            console.warn("⚠️ Invalid date format:", dotNetDate);
            return null;
        }
        return parsed;
    }

    function isSameDay(d1, d2) {
        return d1 && d2 &&
            d1.getFullYear() === d2.getFullYear() &&
            d1.getMonth() === d2.getMonth() &&
            d1.getDate() === d2.getDate();
    }
    function normalizeText(text) {
        return text
            .toString()
            .trim()
            .replace(/^['"]+|['"]+$/g, "")
            .replace(/\s+/g, " ")
            .toLowerCase();
    }
    function getColorByName(name) {
        if (!name) return "#CCCCCC";
        var hash = 0;
        for (var i = 0; i < name.length; i++) {
            hash = name.charCodeAt(i) + ((hash << 5) - hash);
        }
        var color = "#";
        for (var j = 0; j < 3; j++) {
            var value = (hash >> (j * 8)) & 0xFF;
            value = Math.min(200, Math.max(60, value));

            color += ("00" + value.toString(16)).substr(-2);
        }
        return color;
    }

    function getFirstAndLastName(fullName) {
        if (!fullName) return "-";

        const parts = fullName.trim().split(/\s+/);

        if (parts.length === 1) return parts[0];

        return `${parts[0]} ${parts[parts.length - 1]}`;
    }

    function getCurrentApproverNameForShowInList(masterStatus, approvals) {

        if (masterStatus !== 1) return "-";
        if (!approvals || approvals.length === 0) return "-";

        const pending = approvals.filter(a => a.Centralized_StatusList_ID === 1);
        if (pending.length === 0) return "-";

        pending.sort(
            (a, b) => a.Centralized_ApprovalList_Step - b.Centralized_ApprovalList_Step
        );

        return getFirstAndLastName(pending[0].ApproverName);
    }

