    function renderStoreApprovalDocuments(dataList) {
        const grid = $("#pdfDocumentGrid");
        const container = $("#pdfResultList");
        grid.html("");
        container.hide();
        selectedPdfDocIds = [];
        const filtered = dataList.filter(x => {
            if (!Array.isArray(x.Approvals)) return false;

            const total = x.Approvals.length;
            if (!total) return false;

            const pending = x.Approvals.filter(a => a.Centralized_StatusList_ID === 1).length;
            const approved = x.Approvals.filter(a => a.Centralized_StatusList_ID === 2).length;

            return approved === (total - 1) && pending === 1;
        });

        if (!filtered.length) {
            grid.append(`
            <div class="col-span-10 text-center text-muted py-4">
                No STORE APPROVAL document found
            </div>
        `);
            container.show();
            return;
        }
        filtered.forEach(row => {
            grid.append(`
            <div
                class="pdf-doc-item"
                data-id="${row.Centralized_SourceData_Master_ID_Str}"
                style="
                    width:100%;
                    min-width:0;
                    display:flex;
                    align-items:center;
                    justify-content:center;
                    height:32px;
                    font-size:10px;
                    border:1px solid #cbd5e1;
                    border-radius:4px;
                    cursor:pointer;
                    user-select:none;
                ">
                ${row.Centralized_SourceData_Master_ID_Str}
            </div>
        `);
        });

        container.show();
        updateDownloadButton();
        $("#downloadPdfBtn").off("click").on("click", function () {
            downloadPDFMultiple();
        });
        $(".pdf-doc-item").on("click", function () {

            const id = $(this).data("id");

            if ($(this).hasClass("bg-success")) {
                $(this)
                    .removeClass("bg-success text-white")
                    .css("border-color", "#cbd5e1");

                selectedPdfDocIds = selectedPdfDocIds.filter(x => x !== id);

            } else {
                $(this)
                    .addClass("bg-success text-white")
                    .css("border-color", "#22c55e");

                if (!selectedPdfDocIds.includes(id)) {
                    selectedPdfDocIds.push(id);
                }
            }
            syncSelectAllCheckbox();
            updateDownloadButton();
        });

        $("#selectAllPdfDocs").off("change").on("change", function () {
            const isChecked = $(this).prop("checked");
            selectedPdfDocIds = [];
            $(".pdf-doc-item").each(function () {

                const id = $(this).data("id");

                if (isChecked) {


                    $(this)
                        .addClass("bg-success text-white")
                        .css("border-color", "#22c55e");

                    selectedPdfDocIds.push(id);

                } else {


                    $(this)
                        .removeClass("bg-success text-white")
                        .css("border-color", "#cbd5e1");
                }

            });
            updateDownloadButton();
        });
    }

