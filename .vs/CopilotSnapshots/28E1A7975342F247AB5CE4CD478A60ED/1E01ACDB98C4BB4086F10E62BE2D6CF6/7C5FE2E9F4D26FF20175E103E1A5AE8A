                            allowOutsideClick: false,
                            allowEscapeKey: false,
                            didOpen: () => Swal.showLoading()
                        });

                        // Build URL with parameters
                        let url = '@Url.Action("DownloadScrapReport", "DataReporting")'
                            + `?type=yearly`
                            + `&startDate=${dateFrom}`
                            + `&endDate=${dateTo}`;

                        // Add status if selected
                        if (status) {
                            url += `&status=${status}`;
                        }

                        try {
                            const fallbackName = `ScrapReport_${dateFrom.replace(/-/g, '')}_${dateTo.replace(/-/g, '')}.xlsx`;
                            await downloadExcelFromUrl(url, fallbackName);

                            Swal.close();

                            Swal.fire({
                                icon: 'success',
                                title: 'Download Complete!',
                                text: 'Your yearly report has been downloaded successfully.',
                                timer: 2000,
                                showConfirmButton: false
                            });
                        } catch (error) {
