    function checkApprovalChain(application, partsData, options = {}) {
const initiatorKpk = typeof kpk !== "undefined" ? kpk : null;
if (!initiatorKpk) {
    detectedKPKGlobal = [];
    renderApprovalBadges([]);
    return;
}

const app = String(application || "").toUpperCase();
const defaultCodeSelectorByApp = {
    SCRAP: "#scrapCodeDropdown",
    PIA: "#piaCodeDropdown",
    TPR: "#tprCodeDropdown"
};

const defaultCodeSelectors = [
    defaultCodeSelectorByApp[app],
    "#scrapCodeDropdown",
    "#piaCodeDropdown",
    "#tprCodeDropdown"
].filter(Boolean);

const selectedCodeFromDom = defaultCodeSelectors
    .map(selector => document.querySelector(selector)?.value?.trim())
    .find(v => !!v) || "";

const facilitySelector = options.facilitySelector || "#facilityInitiator";
const facility = (options.facility
    || document.querySelector(facilitySelector)?.value?.trim()
    || "");

const documentCode = (options.documentCode
    || document.querySelector(options.codeSelector || "")?.value?.trim()
    || selectedCodeFromDom
    || "");

const partsJson = JSON.stringify(partsData || []);

$.ajax({
    url : '@Url.Action("GetApprovalChain", "DataForms")',
    type: "GET",
    data: {
        application  : application,
        initiatorKpk : initiatorKpk,
        facility     : facility,
        scrapCode    : documentCode,
        partsJson    : partsJson
    },
    success: function (res) {
        if (res.success && res.data && res.data.length > 0) {
            detectedKPKGlobal = res.data;
            renderApprovalBadges(res.data);
        } else {
            detectedKPKGlobal = [];
            renderApprovalBadges([]);
            console.warn("[ApprovalChain] No approvers resolved:", res?.message);
        }
    },
    error: function (xhr, status, err) {
        detectedKPKGlobal = [];
        renderApprovalBadges([]);
        console.error("[ApprovalChain] Failed:", err);
    }
});
}

    function renderApprovalBadges(approvers) {
        const container = document.getElementById("approvalBadgesContainer");
        if (!container) return;

        if (!approvers || approvers.length === 0) {
            container.innerHTML = `
            <span class="text-xs text-muted italic px-1">
                Approvers will appear here once parts are added.
            </span>`;
            return;
        }

        // Warna default per priority tier
        const tierColors = {
            1: "bg-info",
            2: "bg-warning",
            3: "bg-danger"
        };

        const badges = approvers.map((a, i) => {
            const color = tierColors[a.priority] || "bg-muted";
            return `
            <span class="inline-flex items-center gap-1 text-white text-xs
                         px-2 py-1 rounded-full ${color}">
                <b>Step ${i + 1}</b>&nbsp;
                ${a.role}&nbsp;
                <span class="opacity-80">(${a.kpk})</span>
            </span>`;
        }).join("");

        container.innerHTML = `
        <span class="text-xs font-semibold mr-1">Approval Chain:</span>
        ${badges}`;
    }


