    function loadScrapCodeSummaryTotal() {
        $.ajax({
            url: totalScrapCodeUrl,
            type: 'GET',
            dataType: 'json',
            success: function (response) {
                if (!response.success) {
                    console.error("Failed to load summary:", response.message);
                    return;
                }

                const data = response.data;
                const locationMap = {
                    "midc": "#totalCodeP1",
                    "fashion dolls": "#totalCodeP2",
                    "p2s3": "#totalCodeP2S3",
                    "p2s4": "#totalCodeP2S4",
                    "p2s5": "#totalCodeP2S5"
                };

                $("#totalValueAll, #totalCodeP1, #totalCodeP2, #totalCodeP2S3, #totalCodeP2S4, #totalCodeP2S5")
                    .empty()
                    .append('<span class="skeleton w-12 h-6 bg-muted/50 animate-pulse rounded"></span>');

                let overallTotal = 0;

                data.forEach(item => {
                    const loc = item.Location.toLowerCase();
                    const count = item.TotalScrap;

                    if (loc === "overall total") {
                        overallTotal = count;
                        return;
                    }
                    for (const key in locationMap) {
                        if (loc.includes(key)) {
                            $(locationMap[key]).text(count);
                            break;
                        }
                    }
                });
                $("#totalValueAll").text(overallTotal);
            },
            error: function (xhr, status, error) {
                console.error("AJAX Error:", error);
            }
        });
    }

