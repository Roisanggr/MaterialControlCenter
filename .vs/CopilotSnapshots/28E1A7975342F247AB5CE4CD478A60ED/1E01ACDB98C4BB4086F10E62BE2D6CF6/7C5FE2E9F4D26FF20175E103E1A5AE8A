    function renderPagination(totalCount, pageNumber, pageSize) {
        const totalPages = Math.ceil(totalCount / pageSize);
        const pagination = document.getElementById("buttonPagination");
        pagination.innerHTML = "";
        if (totalPages === 0) return;
        const buttons = [];
        buttons.push({ text: "First", page: 1, disabled: pageNumber === 1 });
        buttons.push({ text: "Prev", page: pageNumber - 1, disabled: pageNumber === 1 });
        let startPage = Math.max(1, pageNumber - 2);
        let endPage = startPage + 4;
        if (endPage > totalPages) {
            endPage = totalPages;
            startPage = Math.max(1, endPage - 4);
        }

        for (let i = startPage; i <= endPage; i++) {
            buttons.push({ text: i, page: i, active: i === pageNumber });
        }

        buttons.push({ text: "Next", page: pageNumber + 1, disabled: pageNumber === totalPages });
        buttons.push({ text: "Last", page: totalPages, disabled: pageNumber === totalPages });

        buttons.forEach(btn => {
            pagination.innerHTML += `
        <li>
            <button type="button"
                class="flex justify-center px-3.5 py-2 rounded transition
                    ${btn.active ? "text-white bg-purple border border-purple" : "text-purple hover:text-white hover:bg-purple border border-purple/5 hover:border-purple bg-purple/10"}
                    ${btn.disabled ? "opacity-50 cursor-not-allowed" : ""}"
                onclick="loadData(${btn.page}, ${pageSize})"
                ${btn.disabled ? "disabled" : ""}>
                ${btn.text}
            </button>
        </li>`;
        });
    }

