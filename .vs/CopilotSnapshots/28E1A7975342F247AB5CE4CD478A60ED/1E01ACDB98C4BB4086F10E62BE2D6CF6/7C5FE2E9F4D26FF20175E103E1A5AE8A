    $("#saveAddUserCreateScrap").on("click", function () {
        const users = [];

        $("#listOfUsersCreateScrapModals tr").each(function () {
            const $tds = $(this).find("td");

            users.push({
                Kpk: $tds.eq(1).text().trim(),
                Name: $tds.eq(2).text().trim(),
                RoleId: 2,
                Facility: plant,
                TC: TC,
                ScrapCodeResponsible: null
            });
        });

        if (users.length === 0) {
            Swal.fire({
                icon: "warning",
                title: "No Data",
                text: "No users to save"
            });
            return;
        }
        Swal.fire({
            title: "Processing...",
            text: "Please wait",
            allowOutsideClick: false,
            didOpen: () => Swal.showLoading()
        });

        const successUsers = [];
        const failedUsers = [];
        const requests = users.map(user =>
            sendAddOrReactivateUser(user)
                .done(res => {
                    if (res && res.success) {
                        successUsers.push(user.Kpk);
                    } else {
                        failedUsers.push(user.Kpk);
                    }
                })
                .fail(() => {
                    failedUsers.push(user.Kpk);
                })
        );
        $.when(...requests).always(function () {
            Swal.fire({
                icon: failedUsers.length ? "warning" : "success",
                title: "Process Finished",
                html: `
                <p><b>Success:</b> ${successUsers.length}</p>
                <p><b>Failed:</b> ${failedUsers.length}</p>
            `
            });
            if (successUsers.length > 0) {
                resetAddUserCreateScrapModal();
            }
        });
    });


